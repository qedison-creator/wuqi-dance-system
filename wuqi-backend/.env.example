PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/wuqi_dance
JWT_SECRET=请生成32位以上随机字符串替换此处
JWT_EXPIRES_IN=7d

# 微信小程序（会员端）- 必填，用于会员微信登录和订阅消息
WX_MEMBER_APPID=你的会员端小程序AppID
WX_MEMBER_SECRET=你的会员端小程序Secret

# 微信小程序（管理端）- 可选，用于管理端微信登录和订阅消息
WX_ADMIN_APPID=你的管理端小程序AppID
WX_ADMIN_SECRET=你的管理端小程序Secret

# 腾讯云COS配置（可选，用于图片/视频云存储）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou