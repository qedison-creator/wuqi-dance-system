PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/wuqi_dance
JWT_SECRET=请生成32位以上随机字符串替换此处
JWT_EXPIRES_IN=7d

# 微信小程序（管理端 wx4b7897d88694954c）
# 用于订阅消息推送，access_token 通过小程序 AppID/Secret 获取
WX_APPID=wx4b7897d88694954c
WX_SECRET=你的小程序Secret

# 腾讯云COS配置（可选，用于图片/视频云存储）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou