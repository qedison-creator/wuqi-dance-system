<view class="pre-member-page">
  <!-- 门店筛选栏 -->
  <view class="store-bar">
    <text class="store-bar-label">门店</text>
    <scroll-view class="store-scroll" scroll-x enhanced show-scrollbar="{{false}}" enable-flex>
      <view class="store-chips">
        <view class="store-chip {{currentStoreId === '' ? 'store-chip-active' : ''}}" data-id="" bindtap="onStoreFilterChange">
          <text class="store-chip-text">全部</text>
        </view>
        <view class="store-chip {{currentStoreId === item._id ? 'store-chip-active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-id="{{item._id}}" bindtap="onStoreFilterChange">
          <text class="store-chip-text">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作栏：搜索 + 批量管理 + 批量导入 + 新建 -->
  <view class="action-bar">
    <view class="search-input-wrap">
      <text class="search-icon">搜</text>
      <input class="search-input" placeholder="搜索姓名/手机号" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="onSearch" />
      <view class="search-clear" wx:if="{{keyword}}" catchtap="onClearSearch">
        <text>×</text>
      </view>
    </view>
    <view class="action-btns">
      <!-- 批量管理模式下隐藏这些按钮，避免与底部操作栏冲突 -->
      <block wx:if="{{!batchMode}}">
        <view class="btn-import" bindtap="onEnterBatchMode">
          <text class="btn-import-text">批量管理</text>
        </view>
        <view class="btn-import" bindtap="onGoImport">
          <text class="btn-import-text">批量导入</text>
        </view>
        <view class="btn-create" bindtap="onCreatePreMember">
          <text class="btn-create-text">+ 新建</text>
        </view>
      </block>
      <block wx:else>
        <view class="btn-exit-batch" bindtap="onExitBatchMode">
          <text class="btn-import-text">退出管理</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 状态筛选标签 -->
  <view class="status-tabs">
    <view class="status-tab {{currentStatus === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="onStatusTabChange">
      <text>待认领</text>
      <view class="tab-badge" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
    </view>
    <view class="status-tab {{currentStatus === 'claimed' ? 'active' : ''}}" data-status="claimed" bindtap="onStatusTabChange">
      <text>已认领</text>
    </view>
    <view class="status-tab {{currentStatus === 'all' ? 'active' : ''}}" data-status="all" bindtap="onStatusTabChange">
      <text>全部</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="member-list {{batchMode ? 'member-list-batch' : ''}}" wx:if="{{!loading && list.length > 0}}">
    <view class="member-card {{batchMode && item.member_status === 'pending_claim' ? 'member-card-selectable' : ''}} {{batchMode && item._selected ? 'member-card-selected' : ''}}" wx:for="{{list}}" wx:key="_id" data-id="{{item._id}}" catchtap="onCardTap">
      <view class="member-card-top">
        <!-- 批量管理模式下，仅 pending_claim 状态显示复选框；其他状态显示禁用占位以保持对齐 -->
        <view class="batch-checkbox-wrap" wx:if="{{batchMode}}">
          <view class="batch-checkbox {{item.member_status === 'pending_claim' ? (item._selected ? 'checked' : '') : 'disabled'}}">
            <text class="batch-checkbox-tick" wx:if="{{item.member_status === 'pending_claim' && item._selected}}">✓</text>
          </view>
        </view>
        <view class="member-avatar-placeholder">
          <image wx:if="{{item.avatar_url}}" class="member-avatar-img" src="{{item.avatar_url}}" mode="aspectFill" lazy-load decoding="async"></image>
          <text wx:else class="avatar-text">{{item.real_name ? item.real_name[0] : '?'}}</text>
        </view>
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{item.real_name || '未知'}}</text>
            <view class="member-tags">
              <view class="store-tag" wx:if="{{item.store_name}}">
                <text class="store-tag-text">{{item.store_name}}</text>
              </view>
              <view class="status-tag {{item.member_status === 'pending_claim' ? 'status-pending' : 'status-claimed'}}">
                <text class="status-tag-text">{{item.status_text}}</text>
              </view>
            </view>
          </view>
          <view class="member-phone-line">
            <text class="phone-item">{{(item._showPhone && !isReviewer) ? (item.reserve_phone_raw || '未绑定') : (item.reserve_phone || '未绑定')}}</text>
            <view class="phone-eye-btn" wx:if="{{!isReviewer}}" catchtap="onTogglePhone" data-index="{{index}}">
              <image class="phone-eye-icon" src="{{item._showPhone ? '/images/icons/eye-close.svg' : '/images/icons/eye-open.svg'}}" mode="aspectFit" decoding="async" />
            </view>
            <text class="created-time">{{item.created_at_text}}</text>
          </view>
          <view class="package-info" wx:if="{{item.has_package}}">
            <text class="package-text">{{item.package_text}}</text>
          </view>
          <view class="package-info no-package" wx:else>
            <text class="package-text">未录套餐</text>
          </view>
        </view>
      </view>
      <!-- 批量管理模式下隐藏操作按钮，避免与卡片选中冲突 -->
      <view class="member-actions" wx:if="{{!batchMode}}">
        <block wx:if="{{item.member_status === 'pending_claim'}}">
          <view class="action-btn action-edit" catchtap="onEditPreMember" data-id="{{item._id}}">
            <text>编辑</text>
          </view>
          <view class="action-btn action-delete" catchtap="onDeletePreMember" data-id="{{item._id}}">
            <text>删除</text>
          </view>
          <view class="action-btn action-detail" catchtap="onViewDetail" data-id="{{item._id}}">
            <text>详情</text>
          </view>
        </block>
        <block wx:else>
          <view class="action-btn action-detail" catchtap="onViewOfficialMember" data-id="{{item._id}}">
            <text>查看正式会员</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-text">暂无预建档记录</text>
    <text class="empty-desc">点击右上角「新建」创建预建档</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 底部批量操作栏：仅批量管理模式下显示 -->
  <view class="batch-action-bar" wx:if="{{batchMode}}">
    <view class="batch-select-all-btn" catchtap="onToggleSelectAll">
      <view class="batch-checkbox {{allSelected ? 'checked' : ''}}">
        <text class="batch-checkbox-tick" wx:if="{{allSelected}}">✓</text>
      </view>
      <text class="batch-select-all-text">全选</text>
    </view>
    <view class="batch-action-right">
      <text class="batch-selected-count">已选 {{selectedIds.length}} 项</text>
      <view class="batch-delete-btn {{selectedIds.length === 0 ? 'disabled' : ''}}" catchtap="onBatchDelete">
        <text class="batch-delete-btn-text">删除选中</text>
      </view>
    </view>
  </view>
</view>

<!-- 新建/编辑预建档弹窗 -->
<view class="modal-mask" wx:if="{{showFormModal}}" catchtouchmove="onModalTouchMove">
  <view class="form-modal-content" catchtap="onModalTap" catchtouchmove="onModalTouchMove">
    <view class="modal-header">
      <text class="modal-title">{{editingId ? '编辑预建档' : '新建预建档'}}</text>
      <text class="modal-close" bindtap="onCloseFormModal">×</text>
    </view>
    <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="form-body">
      <!-- 基本信息 -->
      <view class="form-group">
        <text class="form-label">所属门店 *</text>
        <view class="picker-field {{form.store_id ? '' : 'placeholder'}}" bindtap="onOpenStorePicker">
          <text>{{form.store_id ? form.store_name : '请选择门店'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">会员姓名 *</text>
        <input class="input-field" placeholder="请输入会员姓名" placeholder-class="input-placeholder" maxlength="20" value="{{form.real_name}}" bindinput="onFormInput" data-field="real_name" />
      </view>
      <view class="form-group">
        <text class="form-label">性别 *</text>
        <view class="gender-picker">
          <view class="gp-option {{form.gender === 1 ? 'active' : ''}}" data-gender="1" bindtap="onGenderSelect">男</view>
          <view class="gp-option {{form.gender === 2 ? 'active' : ''}}" data-gender="2" bindtap="onGenderSelect">女</view>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">预留手机号 *</text>
        <input class="input-field" type="number" placeholder="11位手机号" placeholder-class="input-placeholder" maxlength="11" value="{{form.reserve_phone}}" bindinput="onFormInput" data-field="reserve_phone" />
      </view>

      <view class="form-divider"></view>
      <view class="form-section-title">套餐信息（选填）</view>

      <view class="form-group">
        <text class="form-label">会员身份 *</text>
        <view class="package-type-selector">
          <view class="type-option {{form.member_identity === 'new' ? 'active' : ''}}" data-identity="new" bindtap="onMemberIdentityChange">
            <text>新会员</text>
          </view>
          <view class="type-option {{form.member_identity === 'old' ? 'active' : ''}}" data-identity="old" bindtap="onMemberIdentityChange">
            <text>老会员</text>
          </view>
        </view>
        <view class="form-hint" wx:if="{{form.member_identity === 'new'}}">
          <text class="form-hint-text">套餐录入后进入待激活状态，录入后2个月未激活将自动强制激活</text>
        </view>
        <view class="form-hint" wx:elif="{{form.member_identity === 'old'}}">
          <text class="form-hint-text">套餐录入后直接生效，无待激活环节</text>
        </view>
      </view>

      <!-- 套餐列表：循环渲染每个套餐 -->
      <view class="package-section" wx:for="{{form.packages}}" wx:key="index" wx:for-item="pkg" wx:for-index="pkgIdx">
        <view class="package-section-header">
          <text class="package-section-title">套餐 {{pkgIdx + 1}}</text>
          <view class="package-remove-btn" catchtap="onRemovePackage" data-index="{{pkgIdx}}">删除</view>
        </view>

        <view class="form-group">
          <text class="form-label">套餐类型</text>
          <view class="package-type-selector">
            <view class="type-option {{pkg.package_type === 'count_card' ? 'active' : ''}}" data-type="count_card" data-index="{{pkgIdx}}" bindtap="onPackageTypeChange">
              <text>次卡</text>
            </view>
            <view class="type-option {{pkg.package_type === 'time_card' ? 'active' : ''}}" data-type="time_card" data-index="{{pkgIdx}}" bindtap="onPackageTypeChange">
              <text>时间卡</text>
            </view>
            <view class="type-option {{pkg.package_type === '' ? 'active' : ''}}" data-type="" data-index="{{pkgIdx}}" bindtap="onPackageTypeChange">
              <text>不录套餐</text>
            </view>
          </view>
        </view>

        <block wx:if="{{pkg.package_type}}">
          <!-- 新会员：只填时长，不填起止日期 -->
          <block wx:if="{{form.member_identity === 'new'}}">
            <block wx:if="{{pkg.package_type === 'count_card'}}">
              <view class="form-group">
                <text class="form-label">总次数 *</text>
                <input class="input-field" type="number" placeholder="请输入总次数" placeholder-class="input-placeholder" value="{{pkg.total_credits}}" bindinput="onFormInput" data-field="total_credits" data-index="{{pkgIdx}}" />
              </view>
              <view class="form-group">
                <text class="form-label">服务有效期 *</text>
                <view class="duration-input-row">
                  <input class="input-field duration-input" type="number" placeholder="请输入时长" placeholder-class="input-placeholder" value="{{pkg.duration_value}}" bindinput="onFormInput" data-field="duration_value" data-index="{{pkgIdx}}" />
                  <view class="duration-unit-selector">
                    <view class="unit-option {{pkg.duration_unit === 'month' ? 'active' : ''}}" data-unit="month" data-index="{{pkgIdx}}" bindtap="onDurationUnitChange">
                      <text>月</text>
                    </view>
                    <view class="unit-option {{pkg.duration_unit === 'day' ? 'active' : ''}}" data-unit="day" data-index="{{pkgIdx}}" bindtap="onDurationUnitChange">
                      <text>天</text>
                    </view>
                  </view>
                </view>
              </view>
            </block>

            <block wx:if="{{pkg.package_type === 'time_card'}}">
              <view class="form-group">
                <text class="form-label">有效时长 *</text>
                <view class="duration-input-row">
                  <input class="input-field duration-input" type="number" placeholder="请输入时长" placeholder-class="input-placeholder" value="{{pkg.duration_value}}" bindinput="onFormInput" data-field="duration_value" data-index="{{pkgIdx}}" />
                  <view class="duration-unit-selector">
                    <view class="unit-option {{pkg.duration_unit === 'month' ? 'active' : ''}}" data-unit="month" data-index="{{pkgIdx}}" bindtap="onDurationUnitChange">
                      <text>月</text>
                    </view>
                    <view class="unit-option {{pkg.duration_unit === 'day' ? 'active' : ''}}" data-unit="day" data-index="{{pkgIdx}}" bindtap="onDurationUnitChange">
                      <text>天</text>
                    </view>
                  </view>
                </view>
              </view>
              <view class="form-group">
                <text class="form-label">周期限制 *</text>
                <view class="period-picker">
                  <view class="period-option {{pkg.period_type === 'weekly' ? 'active' : ''}}" data-period="weekly" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">每周</view>
                  <view class="period-option {{pkg.period_type === 'daily' ? 'active' : ''}}" data-period="daily" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">每天</view>
                  <view class="period-option {{pkg.period_type === 'unlimited' ? 'active' : ''}}" data-period="unlimited" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">不限</view>
                </view>
                <view class="period-count-row" wx:if="{{pkg.period_type !== 'unlimited'}}">
                  <text class="period-count-label">限制次数</text>
                  <input class="input-field period-count-input" type="number" placeholder="0" placeholder-class="input-placeholder" value="{{pkg.period_count}}" bindinput="onFormInput" data-field="period_count" data-index="{{pkgIdx}}" />
                  <text class="period-count-unit">次</text>
                </view>
              </view>
            </block>
          </block>

          <!-- 老会员：只填起止日期，不填时长 -->
          <block wx:else>
            <view class="form-group">
              <text class="form-label">有效期开始日期 *</text>
              <view class="picker-field {{pkg.start_date ? '' : 'placeholder'}}" bindtap="onOpenDatePicker" data-field="start_date" data-index="{{pkgIdx}}">
                <text>{{pkg.start_date || '请选择开始日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </view>
            <view class="form-group">
              <text class="form-label">有效期结束日期 *</text>
              <view class="picker-field {{pkg.end_date ? '' : 'placeholder'}}" bindtap="onOpenDatePicker" data-field="end_date" data-index="{{pkgIdx}}">
                <text>{{pkg.end_date || '请选择结束日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </view>

            <block wx:if="{{pkg.package_type === 'count_card'}}">
              <view class="form-group">
                <text class="form-label">总次数 *</text>
                <input class="input-field" type="number" placeholder="请输入总次数" placeholder-class="input-placeholder" value="{{pkg.total_credits}}" bindinput="onFormInput" data-field="total_credits" data-index="{{pkgIdx}}" />
              </view>
            </block>

            <block wx:if="{{pkg.package_type === 'time_card'}}">
              <view class="form-group">
                <text class="form-label">周期限制 *</text>
                <view class="period-picker">
                  <view class="period-option {{pkg.period_type === 'weekly' ? 'active' : ''}}" data-period="weekly" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">每周</view>
                  <view class="period-option {{pkg.period_type === 'daily' ? 'active' : ''}}" data-period="daily" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">每天</view>
                  <view class="period-option {{pkg.period_type === 'unlimited' ? 'active' : ''}}" data-period="unlimited" data-index="{{pkgIdx}}" bindtap="onPeriodTypeChange">不限</view>
                </view>
                <view class="period-count-row" wx:if="{{pkg.period_type !== 'unlimited'}}">
                  <text class="period-count-label">限制次数</text>
                  <input class="input-field period-count-input" type="number" placeholder="0" placeholder-class="input-placeholder" value="{{pkg.period_count}}" bindinput="onFormInput" data-field="period_count" data-index="{{pkgIdx}}" />
                  <text class="period-count-unit">次</text>
                </view>
              </view>
            </block>
          </block>

          <!-- 附加门店（跨店使用）：每个套餐独立配置 -->
          <view class="form-group" wx:if="{{pkg.package_type}}">
            <text class="form-label">附加门店（可跨店使用）</text>
            <view class="extra-store-list">
              <view class="extra-store-switch-row"
                    wx:for="{{formExtraStoreOptions[pkgIdx]}}" wx:key="_id" wx:for-item="storeItem">
                <text class="extra-store-switch-label">{{storeItem.name}}</text>
                <switch class="extra-store-switch" checked="{{storeItem.checked}}"
                        data-id="{{storeItem._id}}" data-index="{{pkgIdx}}" bindchange="onToggleExtraStore" color="#C4663E" />
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 添加套餐按钮 -->
      <view class="add-package-btn" bindtap="onAddPackage">
        <text>+ 添加套餐</text>
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <textarea class="textarea-field" placeholder="补充说明（选填）" placeholder-class="input-placeholder" maxlength="200" value="{{form.remark}}" bindinput="onFormInput" data-field="remark"></textarea>
      </view>
    </scroll-view>

    <view class="form-actions">
      <view class="btn-cancel" bindtap="onCloseFormModal">取消</view>
      <view class="btn-submit" bindtap="onSubmitForm">确认</view>
    </view>
  </view>
</view>

<!-- 自定义门店选择弹窗 -->
<view class="modal-mask" wx:if="{{showStorePicker}}" catchtouchmove="onModalTouchMove">
  <view class="store-picker-modal" catchtap="onModalTap" catchtouchmove="onModalTouchMove">
    <view class="spm-header">
      <text class="spm-title">选择门店</text>
      <text class="spm-close" bindtap="onCloseStorePicker">×</text>
    </view>
    <scroll-view class="spm-list" scroll-y>
      <view class="spm-item {{form.store_id === item._id ? 'spm-active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onSelectStore">
        <text class="spm-name">{{item.name}}</text>
        <view class="spm-check" wx:if="{{form.store_id === item._id}}"></view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 自定义日期选择器 -->
<date-picker visible="{{showDatePicker}}" value="{{datePickerValue}}" title="{{datePickerTitle}}" bind:confirm="onDatePickerConfirm" bind:cancel="onDatePickerCancel" />
