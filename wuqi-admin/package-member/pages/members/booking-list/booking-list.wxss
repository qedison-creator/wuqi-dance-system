.booking-list-page {
  padding: 20rpx;
  background-color: var(--bg-input);
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
}

.filter-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  border-radius: var(--radius-lg);
  transition: all 0.3s;
}

.filter-item.active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.list-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
}

.booking-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.booking-course {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.booking-header {
  margin-bottom: 16rpx;
}

.booking-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.booking-detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-icon {
  font-size: 28rpx;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  min-width: 120rpx;
}

.detail-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}

.detail-value.coach {
  color: var(--color-primary);
}

.detail-value.booking-time-text {
  color: var(--text-tertiary);
}

.course-time-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.course-date {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.course-weekday {
  font-size: 26rpx;
  color: var(--color-primary);
}

.course-time {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.booking-status {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-xl);
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.booking-status.booked {
  background-color: rgba(197, 116, 75, 0.2);
  color: var(--color-primary);
}

.booking-status.completed {
  background-color: rgba(91, 140, 90, 0.2);
  color: var(--color-success);
}

.booking-status.cancelled {
  background-color: rgba(196, 75, 75, 0.2);
  color: var(--color-danger);
}

.empty-state {
  padding: 120rpx 20rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
}