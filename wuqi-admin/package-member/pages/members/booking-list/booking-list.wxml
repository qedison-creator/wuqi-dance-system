<view class="booking-list-page">
  <!-- 筛选栏 -->
  <view class="filter-bar card">
    <view class="filter-item {{statusFilter === '' ? 'active' : ''}}" bindtap="onFilterChange" data-status="">
      <text>全部</text>
    </view>
    <view class="filter-item {{statusFilter === 'booked' ? 'active' : ''}}" bindtap="onFilterChange" data-status="booked">
      <text>待上课</text>
    </view>
    <view class="filter-item {{statusFilter === 'completed' ? 'active' : ''}}" bindtap="onFilterChange" data-status="completed">
      <text>已完成</text>
    </view>
    <view class="filter-item {{statusFilter === 'cancelled' ? 'active' : ''}}" bindtap="onFilterChange" data-status="cancelled">
      <text>已取消</text>
    </view>
  </view>

  <!-- 预约记录列表 -->
  <view class="list-container" wx:if="{{filteredBookings.length > 0}}">
    <view class="booking-item card" wx:for="{{filteredBookings}}" wx:key="_id">
      <view class="booking-info">
        <view class="booking-header">
          <text class="booking-course">{{item.schedule_id ? item.schedule_id.course_name : '未知课程'}}</text>
        </view>
        <view class="booking-details">
          <view class="booking-detail-row">
            <text class="detail-icon">📅</text>
            <text class="detail-label">课程时间</text>
            <view class="detail-value course-time-wrap">
              <text class="course-date">{{item.schedule_id ? item.schedule_id.date : item.booking_date}}</text>
              <text class="course-weekday">{{item._weekday}}</text>
              <text class="course-time">{{item.schedule_id ? item.schedule_id.start_time : item.booking_time}}-{{item.schedule_id ? item.schedule_id.end_time : ''}}</text>
            </view>
          </view>
          <view class="booking-detail-row" wx:if="{{item.schedule_id && item.schedule_id.coach_id && item.schedule_id.coach_id.name}}">
            <text class="detail-icon">👤</text>
            <text class="detail-label">授课教练</text>
            <text class="detail-value coach">{{item.schedule_id.coach_id.name}}</text>
          </view>
          <view class="booking-detail-row" wx:if="{{item.created_at_display}}">
            <text class="detail-icon">🕐</text>
            <text class="detail-label">预约时间</text>
            <text class="detail-value booking-time-text">{{item.created_at_display}}</text>
          </view>
        </view>
      </view>
      <view class="booking-status {{item.status}}">
        <text>{{item.status === 'booked' ? '待上课' : (item.status === 'completed' ? '已完成' : '已取消')}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text>暂无预约记录</text>
  </view>
</view>