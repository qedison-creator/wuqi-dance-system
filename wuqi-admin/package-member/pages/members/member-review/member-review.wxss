.review-page {
  padding: 32rpx;
  padding-bottom: 60rpx;
  background-color: var(--bg-root);
  min-height: 100vh;
}

/* ========== 顶部Tab ========== */
.tab-bar {
  display: flex;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.review-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.review-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.review-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.review-card {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-top {
  display: flex;
  margin-bottom: 20rpx;
}

.card-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: var(--border);
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  gap: 12rpx;
}

.card-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-right: 12rpx;
}

/* 手机号行 */
.phone-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.phone-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.h-phone-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* 小眼睛图标 */
.eye-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.eye-sm {
  width: 30rpx;
  height: 30rpx;
}

.h-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag-orange {
  background-color: var(--color-primary-bg);
}

.tag-orange .tag-text {
  color: var(--color-primary);
  font-size: 22rpx;
}

.card-phone-line {
  display: flex;
  gap: 20rpx;
  margin-bottom: 4rpx;
}

.card-phone-line .phone-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-phone-line .phone-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-right: 6rpx;
}

.card-phone {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.card-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.card-store {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.action-approve {
  background: linear-gradient(135deg, #5B8C5A, #4A7A49);
  box-shadow: 0 4rpx 12rpx rgba(91, 140, 90, 0.25);
}

.action-approve .btn-text {
  color: #FFFFFF;
}

.action-approve:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.action-reject {
  background: #F5F0EB;
  border: 1rpx solid #E8D5C8;
}

.action-reject .btn-text {
  color: #D4786E;
}

.action-reject:active {
  background: #EDE4DA;
}

.action-delete {
  background: rgba(255, 59, 48, 0.08);
}

.action-delete .btn-text {
  color: #C0392B;
}

.action-delete:active {
  background: rgba(255, 59, 48, 0.15);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.store-modal-content {
  width: 80%;
  background-color: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx;
}

.store-modal-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  position: relative;
  padding-right: 40rpx;
}

.modal-close {
  position: absolute;
  right: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.store-modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.store-modal-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.store-modal-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.store-modal-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.store-modal-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.store-modal-item:last-child {
  border-bottom: none;
}

.store-modal-confirm {
  margin-top: 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
}

.store-modal-confirm.disabled {
  background-color: var(--border);
  color: var(--text-tertiary);
}

/* ========== 审核记录 ========== */
.history-scroll {
  height: calc(100vh - 200rpx);
}

.history-item {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.h-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border);
}

.h-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.h-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.h-status.approved {
  background: rgba(91, 140, 90, 0.1);
  color: #5B8C5A;
}

.h-status.rejected {
  background: rgba(212, 120, 110, 0.1);
  color: #D4786E;
}

.h-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.h-phone {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.h-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.h-time {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.h-operator {
  font-size: 20rpx;
  color: var(--text-tertiary);
}
