<view class="member-card">
  <!-- 头像 + 名称 + 状态 + 门店 -->
  <view class="card-header">
    <image class="member-avatar" src="{{member.avatar || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
    <view class="member-info">
      <view class="name-row">
        <text class="member-name">{{member.real_name || member.nickname || member.name || '未知'}}</text>
        <view class="tags-row">
          <view class="status-tag {{member.status === 'active' ? 'tag-green' : member.status === 'pending' ? 'tag-orange' : 'tag-gray'}}">
            <text class="tag-text">{{member.status === 'active' ? '正式会员' : member.status === 'pending' ? '待审核' : '已过期'}}</text>
          </view>
          <view class="store-tag {{member.store_id && member.store_id.name ? '' : 'store-tag-empty'}}">
            <text class="store-tag-text">{{member.store_id && member.store_id.name ? member.store_id.name : '未匹配门店'}}</text>
          </view>
        </view>
      </view>
      <text class="member-phone">{{member.phone || '未绑定'}}</text>
    </view>
  </view>

  <!-- 注册日期 + 套餐信息（同一行） -->
  <view class="card-meta-row" wx:if="{{member.created_at || (member.status === 'active' && member.package_info)}}">
    <text class="meta-text" wx:if="{{member.created_at}}">注册 {{member.created_at}}</text>
    <view class="meta-package" wx:if="{{member.status === 'active' && member.package_info}}">
      <text class="package-icon">👑</text>
      <text class="package-text">{{member.package_info}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="card-actions">
    <!-- 待审核：通过 + 拒绝 -->
    <block wx:if="{{member.member_status === 'registered'}}">
      <view class="action-btn btn-approve" catchtap="onReview">
        <text class="btn-text">通过</text>
      </view>
      <view class="action-btn btn-reject" catchtap="onReject">
        <text class="btn-text">拒绝</text>
      </view>
    </block>
    <!-- 正式会员 -->
    <block wx:if="{{member.member_status === 'official'}}">
      <view class="action-btn btn-package" wx:if="{{!member.has_package}}" catchtap="onAddPackage">
        <text class="btn-text">录入套餐</text>
      </view>
      <view class="action-btn btn-package" wx:if="{{member.has_package}}" catchtap="onAddPackage">
        <text class="btn-text">编辑套餐</text>
      </view>
      <view class="action-btn btn-detail" catchtap="onViewDetail">
        <text class="btn-text">详情</text>
      </view>
    </block>
    <!-- 其他状态：详情 -->
    <block wx:if="{{member.member_status !== 'registered' && member.member_status !== 'official'}}">
      <view class="action-btn btn-detail" catchtap="onViewDetail">
        <text class="btn-text">详情</text>
      </view>
    </block>
  </view>
</view>
