.member-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E8E2D8;
  box-shadow: 0 2rpx 8rpx rgba(44, 36, 22, 0.04), 0 8rpx 24rpx rgba(44, 36, 22, 0.06);
  transition: all 150ms ease-out;
}

.member-card:active {
  background: #F0ECE6;
  transform: scale(0.98);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #F0ECE6;
  flex-shrink: 0;
  border: 2rpx solid rgba(197, 116, 75, 0.2);
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.member-name {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  letter-spacing: 0.5rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.status-tag {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-text {
  font-size: 22rpx;
  font-weight: 600;
}

.tag-green {
  background: #EDF5EE;
}
.tag-green .tag-text {
  color: #5B8C5A;
}

.tag-orange {
  background: #FAEEE4;
}
.tag-orange .tag-text {
  color: #C4663E;
}

.tag-gray {
  background: rgba(184, 175, 158, 0.12);
}
.tag-gray .tag-text {
  color: #B8AF9E;
}

.store-tag {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #FAEEE4;
  flex-shrink: 0;
}
.store-tag-empty {
  background: rgba(184, 175, 158, 0.08);
}
.store-tag-text {
  font-size: 22rpx;
  color: #C5744B;
}
.store-tag-empty .store-tag-text {
  color: #8B7E6A;
}

.member-phone {
  font-size: 24rpx;
  color: #8B7E6A;
}

.card-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-left: 116rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #8B7E6A;
}

.meta-package {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.package-icon {
  font-size: 22rpx;
}

.package-text {
  font-size: 22rpx;
  color: #C5744B;
  font-weight: 500;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E2D8;
}

.action-btn {
  flex: 1;
  min-width: 140rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 150ms;
}

.action-btn:active {
  transform: scale(0.95);
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.btn-approve {
  background: #C5744B;
  box-shadow: 0 2rpx 8rpx rgba(197, 116, 75, 0.15);
}
.btn-approve .btn-text {
  color: #FFFFFF;
}

.btn-reject {
  background: transparent;
  border: 1rpx solid #C44B4B;
}
.btn-reject:active {
  background: #FDF0F0;
}
.btn-reject .btn-text {
  color: #C44B4B;
}

.btn-package {
  background: transparent;
  border: 1rpx solid #C5744B;
}
.btn-package:active {
  background: #FAEEE4;
}
.btn-package .btn-text {
  color: #C5744B;
}

.btn-detail {
  background: #F0ECE6;
  border: 1rpx solid #E8E2D8;
}
.btn-detail:active {
  background: #EDF5EE;
}
.btn-detail .btn-text {
  color: #8B7E6A;
}