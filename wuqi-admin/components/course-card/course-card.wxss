.course-card {
  padding: 24rpx;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.course-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.course-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 6rpx;
  letter-spacing: 0.5rpx;
}

.course-dance {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.course-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-active {
  background: var(--color-success-bg);
}
.status-cancelled {
  background: var(--color-danger-bg);
}
.status-upcoming {
  background: var(--color-info-bg);
}

.status-text {
  font-size: 22rpx;
  font-weight: 600;
}
.status-active .status-text { color: var(--color-success); }
.status-cancelled .status-text { color: var(--color-danger); }
.status-upcoming .status-text { color: var(--color-info); }

.course-details {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.detail-row:last-child { margin-bottom: 0; }

.detail-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  width: 36rpx;
  text-align: center;
}

.detail-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.course-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 150ms;
}
.action-btn:active { transform: scale(0.95); }

.btn-view {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border: 1rpx solid rgba(197, 116, 75, 0.2);
}

.btn-attendance {
  background: var(--color-success-bg);
  color: var(--color-success);
  border: 1rpx solid rgba(91, 140, 90, 0.2);
}

.btn-edit {
  background: var(--color-info-bg);
  color: var(--color-info);
  border: 1rpx solid rgba(123, 158, 179, 0.2);
}

.btn-cancel {
  background: var(--color-danger-bg);
  color: var(--color-danger);
  border: 1rpx solid rgba(196, 75, 75, 0.2);
}