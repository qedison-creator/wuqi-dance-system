.store-picker {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: var(--bg-input);
  border-radius: 50rpx;
  height: 60rpx;
  border: 1rpx solid var(--border);
  transition: all 150ms ease-out;
}

.store-picker:active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.store-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.store-name {
  font-size: 24rpx;
  color: var(--text-primary);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.store-arrow {
  font-size: 18rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.store-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.35);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 250ms ease-out;
}

.store-modal {
  width: min(80%, 560rpx);
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 36rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(44, 36, 22, 0.04), 0 8rpx 24rpx rgba(44, 36, 22, 0.06);
  animation: modalSlideUp 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 50%;
  background: var(--bg-input);
}

.modal-close:active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.store-list {
  display: flex;
  flex-direction: column;
}

.store-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(232, 226, 216, 0.6);
  transition: all 150ms;
}

.store-item:last-child {
  border-bottom: none;
}

.store-item:active {
  background: var(--bg-input);
  margin: 0 -36rpx;
  padding-left: 36rpx;
  padding-right: 36rpx;
  border-radius: 12rpx;
}

.store-item.active .store-item-name {
  color: var(--color-primary);
  font-weight: 700;
}

.store-item-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 400;
}

.store-item-check {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  flex-shrink: 0;
  transition: all 200ms;
}

.store-item-check.checked {
  background: var(--color-primary);
  border-color: transparent;
  color: var(--bg-card);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modalSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}