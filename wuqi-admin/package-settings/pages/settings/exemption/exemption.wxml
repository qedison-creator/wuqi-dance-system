<view class="exemption-page">
  <!-- 全局默认设置 -->
  <view class="section card">
    <view class="section-title">
      <text class="title-icon"></text>
      <text class="title-text">全局默认设置</text>
    </view>
    <view class="section-desc">
      <text>新注册会员的默认豁免次数</text>
    </view>
    <view class="config-item">
      <text class="config-label">默认豁免次数</text>
      <view class="config-value">
        <input type="number" value="{{defaultExemption}}" bindinput="onDefaultChange" placeholder="请输入次数" />
        <text class="unit">次</text>
      </view>
    </view>
    <view class="save-btn" bindtap="saveDefaultExemption">
      <text>保存默认设置</text>
    </view>
  </view>

  <!-- 会员豁免次数设置 -->
  <view class="section card">
    <view class="section-title">
      <text class="title-icon"></text>
      <text class="title-text">会员豁免次数</text>
    </view>
    <view class="section-desc">
      <text>搜索并设置单个会员的豁免次数</text>
    </view>
    
    <!-- 搜索框 -->
    <view class="search-box">
      <input type="text" placeholder="输入会员姓名或手机号搜索" value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="searchMembers" />
      <view class="search-btn" bindtap="searchMembers">
        <text></text>
      </view>
    </view>

    <!-- 会员列表 -->
    <view class="member-list" wx:if="{{memberList.length > 0}}">
      <view class="member-item" wx:for="{{memberList}}" wx:key="_id">
        <view class="member-info">
          <text class="member-name">{{item.real_name || item.nick_name || '未设置昵称'}}</text>
          <text class="member-phone">{{item.phone || ''}}</text>
        </view>
        <view class="member-exemption">
          <text class="exemption-label">剩余豁免:</text>
          <view class="exemption-control">
            <view class="control-btn minus" bindtap="changeExemption" data-id="{{item._id}}" data-delta="-1">-</view>
            <text class="exemption-count">{{item.exemption_count || 0}}</text>
            <view class="control-btn plus" bindtap="changeExemption" data-id="{{item._id}}" data-delta="1">+</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{hasSearched && memberList.length === 0}}">
      <text>未找到匹配的会员</text>
    </view>

    <!-- 提示 -->
    <view class="tips">
      <text>提示：豁免次数用于会员超时取消预约时免除扣次数</text>
    </view>
  </view>
</view>