.container {
  padding: 20rpx;
}

.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 200ms ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 20rpx 24rpx 10rpx;
  line-height: 1.5;
}

.config-list {
  padding: 0;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.config-item:last-child {
  border-bottom: none;
}

.config-info {
  flex: 1;
}

.config-desc {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
}

.config-key {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}

.config-value {
  display: flex;
  align-items: center;
}

.value-text {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-right: 20rpx;
}

.edit-icon {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

/* Hero 配置样式 */
.hero-config-list {
  padding: 0;
}

.hero-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.hero-item:last-child {
  border-bottom: none;
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.hero-preview {
  width: 160rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: var(--bg-tertiary);
  border: 1rpx solid var(--border);
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-btn {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.hero-btn.upload-btn {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
  margin: 0;
  padding: 16rpx 32rpx;
  border: none;
  line-height: inherit;
}

.hero-btn.upload-btn::after {
  border: none;
}

.hero-btn.reset-btn {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}
