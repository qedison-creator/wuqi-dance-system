.container {
  padding: 20rpx;
}

.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 200ms ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 20rpx 24rpx 10rpx;
  line-height: 1.5;
}

.config-list {
  padding: 0;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.config-item:last-child {
  border-bottom: none;
}

.config-info {
  flex: 1;
}

.config-desc {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
}

.config-key {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}

.config-value {
  display: flex;
  align-items: center;
}

.value-text {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-right: 4rpx;
}

.edit-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(196, 102, 62, 0.08);
  margin-left: 12rpx;
}

.edit-icon:active {
  background: rgba(196, 102, 62, 0.18);
}

.edit-icon-text {
  font-size: 30rpx;
  color: var(--color-primary);
  line-height: 1;
}

/* Hero 配置样式 */
.hero-config-list {
  padding: 0;
}

.hero-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.hero-item:last-child {
  border-bottom: none;
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.hero-preview {
  width: 160rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: var(--bg-tertiary);
  border: 1rpx solid var(--border);
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-btn {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.hero-btn.upload-btn {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
  margin: 0;
  padding: 16rpx 32rpx;
  border: none;
  line-height: inherit;
}

.hero-btn.upload-btn::after {
  border: none;
}

.hero-btn.reset-btn {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

/* ========== 编辑参数弹窗（遵循管理端 schedule 规范） ========== */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 36, 22, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx 0;
}

.modal-content {
  width: 88%;
  max-height: 75vh;
  background-color: var(--bg-card);
  border-radius: 32rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: var(--shadow-modal);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: var(--radius-full);
  background: var(--bg-elevated);
  transition: all var(--transition-fast);
}

.modal-close:active {
  background: var(--border);
  transform: scale(0.9);
}

.form-item {
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
  flex-shrink: 0;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  transition: var(--transition-fast);
}

.btn-secondary:active {
  background-color: var(--bg-card-hover);
  border-color: var(--color-primary);
}

.btn-secondary text {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-hover), var(--color-primary));
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-fab);
  transition: var(--transition-fast);
}

.btn-primary:active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
  transform: scale(0.98);
}

.btn-primary text {
  font-size: var(--font-md);
  color: var(--text-inverse);
  font-weight: bold;
}
