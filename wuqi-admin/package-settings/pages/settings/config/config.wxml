<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'general' ? 'active' : ''}}" data-tab="general" bindtap="onTabChange">
      <text>系统配置</text>
    </view>
    <view class="tab-item {{activeTab === 'hero' ? 'active' : ''}}" data-tab="hero" bindtap="onTabChange">
      <text>首页背景</text>
    </view>
  </view>

  <view class="card config-list" wx:if="{{!loading && activeTab === 'general'}}">
    <view class="config-item" wx:for="{{configs}}" wx:key="config_key">
      <view class="config-info">
        <text class="config-desc">{{item.description}}</text>
        <text class="config-key">{{item.config_key}}</text>
      </view>
      <view class="config-value">
        <text class="value-text">{{item.config_value}}</text>
        <view class="edit-icon" bindtap="onEditConfig" data-index="{{index}}" data-type="general">
          <text class="edit-icon-text">✎</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card hero-config-list" wx:if="{{!loading && activeTab === 'hero'}}">
    <view class="section-desc">自定义首页不同时段显示的背景图，上传后自动保存</view>
    <view class="hero-item" wx:for="{{heroConfigs}}" wx:key="config_key">
      <view class="hero-left">
        <text class="hero-label">{{item.label}}</text>
        <image class="hero-preview" src="{{item.config_value}}" mode="aspectFill" decoding="async"></image>
      </view>
      <view class="hero-actions">
        <button id="agree-btn" class="hero-btn upload-btn" open-type="agreePrivacyAuthorization" bindagreeprivacyauthorization="onPrivacyAgreed" bindtap="onChooseHeroImage" data-index="{{index}}">
          <text wx:if="{{!item.uploading}}">选择图片</text>
          <text wx:else>上传中...</text>
        </button>
        <view class="hero-btn reset-btn" bindtap="onResetHeroImage" data-index="{{index}}" wx:if="{{item.config_value}}">
          <text>重置</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title">编辑参数</text>
        <text class="modal-close" bindtap="onCloseModal">×</text>
      </view>

      <view class="form-item">
        <text class="form-label">{{editingConfig.description}}</text>
        <input class="input-field" value="{{configValue}}" bindinput="onValueChange" placeholder="请输入参数值" />
      </view>

      <view class="modal-buttons">
        <view class="btn-secondary" bindtap="onCloseModal">
          <text>取消</text>
        </view>
        <view class="btn-primary" bindtap="onSaveConfig">
          <text>确认</text>
        </view>
      </view>
    </view>
  </view>
</view>