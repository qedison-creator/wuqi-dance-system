.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F3F0;
}

/* ========== 固定筛选区 ========== */
.filter-bar {
  flex-shrink: 0;
  background: #FFFFFF;
  padding: 0 28rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,36,22,0.06);
  z-index: 10;
}

/* 门店筛选 */
.store-filter {
  padding: 16rpx 0 12rpx;
}

.store-scroll {
  white-space: nowrap;
}

.store-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.store-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #F6F3F0;
  font-size: 24rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.store-tab.active {
  background: #D4786E;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(212,120,110,0.3);
}

/* 日期筛选 */
.date-filter {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0 12rpx;
}

.date-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: #F6F3F0;
  font-size: 22rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.date-tab.active {
  background: #D4786E;
  color: #FFFFFF;
}

/* 汇总行 */
.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 8rpx;
  border-top: 1rpx solid #F0EBE4;
}

.summary-text {
  font-size: 22rpx;
  color: #6B5D5E;
  line-height: 1.6;
}

.summary-num {
  font-weight: 700;
  color: #2C2416;
  margin: 0 2rpx;
}

.summary-num.summary-green {
  color: #5B8C5A;
}

.summary-num.summary-red {
  color: #D4786E;
}

/* ========== 可滚动内容区 ========== */
.content {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 12rpx 28rpx 40rpx;
}

/* 年份 */
.year-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.year-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0;
  box-shadow: 0 2rpx 12rpx rgba(44,36,22,0.04);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.year-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.year-label {
  font-size: 34rpx;
  color: #2C2416;
  font-weight: 700;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.year-count {
  font-size: 24rpx;
  color: #948284;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 月份 */
.month-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.month-group {
  background: transparent;
  border-radius: 0;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.month-header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.month-toggle {
  font-size: 24rpx;
  color: #B8AFA4;
  margin-right: 12rpx;
  transition: transform 200ms ease;
}

.month-toggle.expanded {
  transform: rotate(90deg);
}

.month-label {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.month-count {
  font-size: 24rpx;
  color: #948284;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.month-content {
  padding: 0 0 16rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 日期 */
.date-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.date-group {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0;
  border: 1rpx solid #F0EBE4;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 16rpx;
  border-bottom: 1rpx solid #F0EBE4;
  width: 100%;
  box-sizing: border-box;
}

.date-header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.date-label {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.date-weekday {
  font-size: 20rpx;
  color: #D4786E;
  font-weight: 500;
  background: rgba(212,120,110,0.1);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.date-count {
  font-size: 22rpx;
  color: #948284;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 课程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 12rpx 0;
}

.course-item {
  background: #FAF8F5;
  border-radius: 16rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.course-main {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.course-name {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.course-time {
  font-size: 22rpx;
  color: #948284;
}

.course-store {
  font-size: 20rpx;
  color: #D4786E;
  background: rgba(212,120,110,0.08);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.course-capacity {
  font-size: 20rpx;
  color: #948284;
}

.course-stats {
  display: flex;
  gap: 8rpx;
  margin-right: 8rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  min-width: 56rpx;
}

.stat-item.completed {
  background: rgba(91,140,90,0.1);
}

.stat-item.cancelled {
  background: rgba(212,120,110,0.1);
}

.stat-item.booked {
  background: rgba(148,130,132,0.1);
}

.stat-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #2C2416;
}

.stat-label {
  font-size: 16rpx;
  color: #6B5D5E;
  margin-top: 2rpx;
}

.course-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

/* 全局导出按钮（顶部汇总栏右侧） */
.export-btn-global {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #D4786E, #C05D53);
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(212,120,110,0.3);
  flex-shrink: 0;
}

.export-btn-global:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.toggle-icon {
  font-size: 22rpx;
  color: #B8AFA4;
  transition: transform 200ms ease;
}

.toggle-icon.expanded {
  transform: rotate(180deg);
}

/* ========== 课程详情：三区块 ========== */
.course-detail {
  padding: 0 0 16rpx;
}

/* 区块容器 */
.member-section {
  margin-bottom: 12rpx;
  padding: 0 24rpx;
}

.member-section:last-child {
  margin-bottom: 0;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 0 12rpx;
}

.section-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.section-dot.dot-completed {
  background: #5B8C5A;
}

.section-dot.dot-cancelled {
  background: #D4786E;
}

.section-dot.dot-booked {
  background: #A0A0A0;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C2416;
}

.section-count {
  font-size: 20rpx;
  color: #948284;
  margin-left: 4rpx;
}

/* 会员卡片 */
.member-cards {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.member-card {
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 14rpx 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(44,36,22,0.03);
}

.member-card.status-completed {
  border-left: 4rpx solid #5B8C5A;
}

.member-card.status-cancelled {
  border-left: 4rpx solid #D4786E;
}

.member-card.status-booked {
  border-left: 4rpx solid #A0A0A0;
}

/* 会员卡片头部 */
.mc-header {
  display: flex;
  align-items: center;
}

.mc-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  background: #F0EBE4;
  flex-shrink: 0;
}

.mc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.mc-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-width: 0;
}

.mc-name {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
  min-width: 0;
}

.mc-nick {
  font-size: 20rpx;
  color: #948284;
  min-width: 0;
}

.mc-phone-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 2rpx;
  min-width: 0;
}

.mc-phone-item {
  font-size: 20rpx;
  color: #B8AFA4;
  min-width: 0;
}

/* 状态徽章 */
.mc-status-badge {
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.badge-completed {
  background: rgba(91,140,90,0.12);
  color: #5B8C5A;
}

.badge-checked-in {
  background: rgba(91,140,90,0.08);
  color: #5B8C5A;
}

.badge-booked {
  background: rgba(148,130,132,0.12);
  color: #6B5D5E;
}

.badge-course-cancel {
  background: rgba(230,126,34,0.12);
  color: #E67E22;
}

/* 取消类型标签 */
.mc-cancel-tag {
  font-size: 20rpx;
  color: #D4786E;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* 重复预约标记 */
.mc-repeat {
  font-size: 18rpx;
  color: #D4786E;
  font-weight: 500;
  background: rgba(212,120,110,0.08);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* 操作区 */
.mc-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.checkin-btn {
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  background: #5B8C5A;
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 展开箭头 */
.mc-expand {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 4rpx;
}

.mc-expand-arrow {
  font-size: 22rpx;
  color: #B8AFA4;
  transition: transform 200ms ease;
}

.mc-expand.expanded .mc-expand-arrow {
  transform: rotate(180deg);
}

/* 时间线 */
.mc-timeline {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0EBE4;
  padding-left: 0;
}

.timeline-item {
  display: flex;
  padding-bottom: 14rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.tl-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 14rpx;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.tl-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.tl-dot.dot-booked {
  background: #5B8C5A;
}

.tl-dot.dot-completed {
  background: #5B6BA3;
}

.tl-dot.dot-cancelled {
  background: #D4786E;
}

.tl-line {
  width: 2rpx;
  flex: 1;
  background: #E8E2DA;
  margin-top: 4rpx;
}

.tl-content {
  flex: 1;
  padding-bottom: 2rpx;
}

.tl-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-action {
  font-size: 26rpx;
  font-weight: 600;
}

.tl-action.action-booked {
  color: #5B8C5A;
}

.tl-action.action-completed {
  color: #5B6BA3;
}

.tl-action.action-cancelled {
  color: #D4786E;
}

.tl-time {
  font-size: 24rpx;
  color: #B8AFA4;
}

.tl-detail {
  margin-top: 2rpx;
}

.tl-text {
  font-size: 24rpx;
  color: #948284;
}

.tl-warn {
  color: #D4786E;
}

/* ========== 空状态 ========== */
.empty-section {
  text-align: center;
  padding: 24rpx 0;
  font-size: 22rpx;
  color: #B8AFA4;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #B8AFA4;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #B8AFA4;
}