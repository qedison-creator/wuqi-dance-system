<view class="checkin-page">
  <view class="page-header">
    <text class="page-title">签到管理</text>
  </view>

  <view class="top-bar">
    <scroll-view scroll-x class="schedule-scroll" wx:if="{{schedules.length > 0}}">
      <view class="schedule-item {{selectedSchedule && selectedSchedule._id === item._id ? 'active' : ''}}"
            wx:for="{{schedules}}" wx:key="_id"
            data-schedule="{{item}}" bindtap="onScheduleSelect">
        <text class="schedule-time">{{item.timeStr}}</text>
        <text class="schedule-name">{{item.className}}</text>
        <text class="schedule-coach">{{item.coachName || ''}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="search-bar" wx:if="{{selectedSchedule}}">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="输入会员编号或手机号查询" value="{{memberCode}}"
             bindinput="onMemberCodeInput" bindconfirm="onMemberCodeConfirm"
             confirm-type="search" />
    </view>
    <view class="search-btn" bindtap="onMemberCodeConfirm">
      <text>搜索</text>
    </view>
  </view>

  <view class="stats-bar card" wx:if="{{records.length > 0}}">
    <view class="stat-item">
      <text class="stat-num">{{records.length}}</text>
      <text class="stat-label">预约总数</text>
    </view>
    <view class="stat-item checked">
      <text class="stat-num">{{checkedInCount}}</text>
      <text class="stat-label">已签到</text>
    </view>
    <view class="stat-item pending">
      <text class="stat-num">{{pendingCount}}</text>
      <text class="stat-label">待签到</text>
    </view>
  </view>

  <scroll-view scroll-y class="record-list" wx:if="{{records.length > 0}}">
    <view class="record-card card" wx:for="{{records}}" wx:key="booking_id">
      <view class="record-main" data-index="{{index}}" bindtap="onToggleExpand">
        <view class="record-avatar {{item.checkInClass}}">
          <text>{{item.userInitial}}</text>
        </view>
        <view class="record-info">
          <view class="record-name-row">
            <text class="record-name">{{item.userName}}</text>
            <text class="record-nick" wx:if="{{item.userNickName}}">（{{item.userNickName}}）</text>
            <view class="source-tag {{item.checkInClass}}" wx:if="{{item.checked_in}}">
              <text>{{item.checkInLabel}}</text>
            </view>
          </view>
          <text class="record-phone">{{item.userPhone || '暂无手机号'}}</text>
        </view>
        <view class="record-status {{item.checkInClass}}">
          <text>{{item.checkInLabel}}</text>
        </view>
        <view class="record-arrow">
          <text>{{expandedIndex === index ? '▲' : '▼'}}</text>
        </view>
      </view>

      <view class="record-detail" wx:if="{{expandedIndex === index}}">
        <view class="detail-section">
          <text class="detail-section-title">会员信息</text>
          <view class="detail-row">
            <text class="detail-label">姓名</text>
            <text class="detail-value">{{item.userName}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">编号</text>
            <text class="detail-value">{{item.memberCode || '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">手机</text>
            <text class="detail-value">{{item.userPhone || '-'}}</text>
          </view>
          <view class="detail-row" wx:if="{{item.checkInTime}}">
            <text class="detail-label">签到时间</text>
            <text class="detail-value">{{item.checkInTime}}</text>
          </view>
          <view class="detail-row" wx:if="{{item.attendance}}">
            <text class="detail-label">签到来源</text>
            <text class="detail-value">{{item.attendance.source === 'onsite' ? '现场签到' : '预约签到'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">消耗课时</text>
            <text class="detail-value">{{item.credits_deducted || 0}}次</text>
          </view>
        </view>
        <button class="load-profile-btn" wx:if="{{item.user_id && item.user_id._id}}"
                bindtap="onViewFullProfile" data-uid="{{item.user_id._id}}">
          查看完整档案
        </button>
      </view>
    </view>
  </scroll-view>

  <view class="empty-state card" wx:elif="{{!loading && selectedSchedule}}">
    <text>该课程暂无预约记录</text>
  </view>
  <view class="empty-state card" wx:elif="{{!loading && !selectedSchedule}}">
    <text>请选择排课或扫码签到</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 签到确认弹窗 -->
  <view class="modal-mask" wx:if="{{showProfileModal}}" bindtap="onCloseProfileModal" catchtouchmove="preventTouchMove">
    <view class="profile-modal" catchtap="onProfileModalTap">

      <view class="modal-warning" wx:if="{{isOnsiteMode}}">
        <text class="warning-icon">!</text>
        <text class="warning-text">该会员未预约当前课程，可进行临时签到</text>
      </view>

      <view class="profile-section" wx:if="{{profileData.member}}">
        <view class="profile-member">
          <image class="profile-avatar" src="{{profileData.member.avatar_url || '/images/default-avatar.svg'}}" mode="aspectFill"></image>
          <view class="profile-member-info">
            <text class="profile-member-name">{{profileData.member.display_name || '会员'}}</text>
            <view class="profile-member-meta">
              <text class="profile-member-code" wx:if="{{profileData.member.member_code}}">编号：{{profileData.member.member_code}}</text>
              <text class="profile-member-store" wx:if="{{profileData.member.store_name}}">门店：{{profileData.member.store_name}}</text>
            </view>
            <view class="profile-member-phones">
              <view class="phone-row" wx:if="{{profileData.member.phone}}">
                <text class="phone-label">登记手机</text>
                <text class="phone-value">{{profileData.member.phone}}</text>
              </view>
              <view class="phone-row" wx:if="{{profileData.member.wechat_phone}}">
                <text class="phone-label">微信手机</text>
                <text class="phone-value">{{profileData.member.wechat_phone}}</text>
              </view>
              <view class="phone-row" wx:if="{{profileData.member.reserve_phone}}">
                <text class="phone-label">备用手机</text>
                <text class="phone-value">{{profileData.member.reserve_phone}}</text>
              </view>
              <text class="phone-empty" wx:if="{{!profileData.member.phone && !profileData.member.wechat_phone && !profileData.member.reserve_phone}}">暂无手机号</text>
            </view>
          </view>
        </view>
      </view>

      <view class="profile-section" wx:if="{{profileData.packages && profileData.packages.length > 0}}">
        <text class="section-title">当前套餐</text>
        <view class="pkg-item" wx:for="{{profileData.packages}}" wx:key="id">
          <view class="pkg-main">
            <text class="pkg-name">{{item.name}}</text>
            <text class="pkg-type">{{item.type === 'count_card' ? '次卡' : (item.type === 'time_card' ? '时间卡' : '未知')}}</text>
          </view>
          <view class="pkg-detail">
            <view wx:if="{{item.type === 'count_card'}}">
              <text>剩余 {{item.credits_remaining}} 次 / 共 {{item.credits_total}} 次</text>
              <view class="pkg-validity" wx:if="{{item.valid_until}}">
                <text wx:if="{{item.remaining_days}}">剩余 {{item.remaining_days}} 天，有效期至 {{item.valid_until}}</text>
                <text wx:else>有效期至 {{item.valid_until}}</text>
              </view>
            </view>
            <view wx:if="{{item.type === 'time_card'}}">
              <text wx:if="{{item.remaining_days}}">剩余 {{item.remaining_days}} 天</text>
              <text wx:if="{{item.valid_until}}">，有效期至 {{item.valid_until}}</text>
              <view class="pkg-usage" wx:if="{{item.time_card_usage}}">
                <text wx:if="{{item.time_card_usage.daily_limit}}">今日已用 {{item.time_card_usage.daily_used}}/{{item.time_card_usage.daily_limit}} 次，剩余 {{item.time_card_usage.daily_remaining}} 次</text>
                <text wx:if="{{item.time_card_usage.weekly_limit && !item.time_card_usage.daily_limit}}">本周已用 {{item.time_card_usage.weekly_used}}/{{item.time_card_usage.weekly_limit}} 次，剩余 {{item.time_card_usage.weekly_remaining}} 次</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="profile-section" wx:else>
        <text class="no-pkg-text">暂无有效套餐</text>
      </view>

      <view class="profile-section" wx:if="{{!isOnsiteMode && profileData.today_bookings && profileData.today_bookings.length > 0}}">
        <text class="section-title">当天预约课程（勾选需签到的）</text>
        <view class="booking-check-item {{item.checked ? 'checked' : ''}}"
              wx:for="{{profileData.today_bookings}}" wx:key="booking_id"
              data-id="{{item.booking_id}}" bindtap="onToggleBookingCheck">
          <view class="check-box {{item.checked ? 'checked' : ''}}">
            <text wx:if="{{item.checked}}">√</text>
          </view>
          <view class="booking-check-info">
            <text class="booking-check-time">{{item.start_time}} - {{item.end_time}}</text>
            <text class="booking-check-course">{{item.course_name || '课程'}}</text>
            <text class="booking-check-coach">{{item.coach_name || ''}} | {{item.dance_style_name || ''}}</text>
          </view>
        </view>
      </view>
      <view class="profile-section" wx:elif="{{!isOnsiteMode}}">
        <text class="no-pkg-text">该会员今天没有预约课程</text>
      </view>

      <view class="modal-buttons">
        <view class="btn-cancel" bindtap="onCloseProfileModal" wx:if="{{checkedBookingIds.length > 0 || isOnsiteMode}}">
          <text>取消</text>
        </view>
        <view class="btn-confirm" bindtap="onCloseProfileModal" wx:else>
          <text>关闭</text>
        </view>
        <view class="btn-confirm {{isOnsiteMode ? 'onsite' : ''}}" bindtap="onConfirmCheckIn" wx:if="{{checkedBookingIds.length > 0 || isOnsiteMode}}">
          <text wx:if="{{isOnsiteMode}}">临时签到</text>
          <text wx:else>确认签到({{checkedBookingIds.length}}人)</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 临时签到二次确认 -->
  <view class="modal-mask" wx:if="{{showOnsiteConfirm}}" bindtap="onCancelOnsiteConfirm" catchtouchmove="preventTouchMove">
    <view class="onsite-confirm-modal" catchtap="onProfileModalTap">
      <view class="onsite-confirm-icon">!</view>
      <text class="onsite-confirm-title">确认临时签到</text>
      <text class="onsite-confirm-desc">该会员未预约当前课程，确认后系统将：</text>
      <view class="onsite-confirm-steps">
        <text>• 自动创建预约记录</text>
        <text>• 扣减套餐 1 次</text>
        <text>• 完成签到</text>
      </view>
      <view class="onsite-confirm-info" wx:if="{{selectedSchedule}}">
        <text>课程：{{selectedSchedule.timeStr}} {{selectedSchedule.className}}</text>
      </view>
      <view class="onsite-confirm-info" wx:if="{{profileData.member}}">
        <text>会员：{{profileData.member.display_name || '会员'}}</text>
      </view>
      <view class="modal-buttons">
        <view class="btn-cancel" bindtap="onCancelOnsiteConfirm">
          <text>取消</text>
        </view>
        <view class="btn-confirm onsite" bindtap="doConfirmCheckIn">
          <text>确认临时签到</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部固定扫码签到按钮 -->
  <view class="bottom-scan-btn" bindtap="onScanCode">
    <view class="scan-icon">
      <svg width="44rpx" height="44rpx" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 5V3H5V5H3ZM7 5V3H9V5H7ZM11 5V3H13V5H11ZM15 5V3H17V5H15ZM19 5V3H21V5H19ZM21 7V5H19V7H21ZM21 11V9H19V11H21ZM21 15V13H19V15H21ZM21 19V17H19V19H21ZM19 21V19H21V21H19ZM15 21V19H17V21H15ZM11 21V19H13V21H11ZM7 21V19H9V21H7ZM5 21V19H3V21H5ZM3 17V15H5V17H3ZM3 13V11H5V13H3ZM3 9V7H5V9H3ZM5 7H7V9H5V7ZM9 7H11V9H9V7ZM13 7H15V9H13V7ZM17 7H19V9H17V7ZM19 9V11H17V9H19ZM17 13V15H15V13H17ZM13 15H15V17H13V15ZM11 15H13V17H11V15ZM9 15H11V17H9V15ZM7 15H9V17H7V15ZM7 13H9V15H7V13ZM9 11H11V13H9V11ZM13 11H15V13H13V11ZM15 9H17V11H15V9Z" fill="#FAF8F5"/>
      </svg>
    </view>
    <text class="scan-text">扫码签到</text>
  </view>
</view>