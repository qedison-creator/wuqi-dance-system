<view class="salary-page">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'hours' ? 'active' : ''}}" bindtap="onTabChange" data-tab="hours">
      <text>课时统计</text>
    </view>
    <view class="tab-item {{activeTab === 'config' ? 'active' : ''}}" bindtap="onTabChange" data-tab="config">
      <text>薪酬配置</text>
    </view>
    <view class="tab-item {{activeTab === 'stats' ? 'active' : ''}}" bindtap="onTabChange" data-tab="stats">
      <text>薪酬统计</text>
    </view>
  </view>

  <!-- ========== 课时统计 Tab ========== -->
  <view class="tab-content" wx:if="{{activeTab === 'hours'}}">
    <view class="hours-year-list" wx:if="{{classHoursYears.length > 0}}">
      <view class="hours-year-group" wx:for="{{classHoursYears}}" wx:key="year" wx:for-index="yi">
        <!-- 年份纯文字 -->
        <text class="hours-year-label">{{item.yearLabel}}</text>

        <!-- 月份横条 -->
        <view class="hours-month-group" wx:for="{{item.months}}" wx:for-item="month" wx:key="monthKey" wx:for-index="mi">
          <view class="hours-month-header" bindtap="onToggleHoursMonth" data-yi="{{yi}}" data-mi="{{mi}}">
            <text class="hours-month-toggle {{month._expanded ? 'expanded' : ''}}">▸</text>
            <text class="hours-month-label">{{month.monthLabel}}</text>
          </view>

          <!-- 展开：教练卡片 -->
          <view class="hours-month-coaches" wx:if="{{month._expanded}}">
            <view class="hours-coach-card" wx:for="{{month.coaches}}" wx:for-item="coach" wx:key="coach_id">
              <!-- 教练头部 -->
              <view class="hours-coach-header" bindtap="onToggleHoursCoach" data-yi="{{yi}}" data-mi="{{mi}}" data-ci="{{index}}">
                <view class="hours-coach-info">
                  <text class="hours-coach-name">{{coach.coach_name}} <text class="hours-coach-total">{{coach.total_classes}}节课</text></text>
                </view>
                <text class="hours-coach-toggle {{coach._expanded ? 'expanded' : ''}}">▸</text>
              </view>

              <!-- 展开：门店分组 -->
              <view class="hours-coach-stores" wx:if="{{coach._expanded}}">
                <view class="hours-store-group" wx:for="{{coach.stores}}" wx:for-item="store" wx:key="store_id">
                  <view class="hours-store-header">
                    <text class="hours-store-tag">{{store.store_name}}</text>
                    <text class="hours-store-summary">
                      <text wx:for="{{store.durations}}" wx:for-item="d" wx:key="duration">{{d.duration}}分钟×{{d.count}}节<text wx:if="{{index < store.durations.length - 1}}"> | </text></text>
                    </text>
                  </view>
                  <view class="hours-store-records">
                    <view class="hours-record-row" wx:for="{{store.records}}" wx:for-item="rec" wx:key="class_date">
                      <text class="hours-rec-seq">{{index + 1}}</text>
                      <text class="hours-rec-date">{{rec.class_date}}</text>
                      <text class="hours-rec-weekday">{{rec.weekday}}</text>
                      <text class="hours-rec-time">{{rec.start_time}}-{{rec.end_time}}</text>
                      <text class="hours-rec-store">{{rec.store_name}}</text>
                      <text class="hours-rec-dur">{{rec.duration}}分钟</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && classHoursYears.length === 0}}" text="暂无课时记录"></empty-state>
  </view>

  <!-- 薪酬配置 -->
  <view class="tab-content" wx:if="{{activeTab === 'config'}}">
    <view class="header-actions">
      <text class="page-title text-heading">薪酬配置</text>
      <view class="add-btn" bindtap="onAddConfig">
        <text>+ 添加配置</text>
      </view>
    </view>

    <view class="config-list" wx:if="{{salaryConfigList.length > 0}}">
      <view class="config-item card" wx:for="{{salaryConfigList}}" wx:key="_id">
        <view class="config-header">
          <text class="config-name">{{item.coach_name}}</text>
          <text class="config-status {{item.is_active ? 'status-active' : 'status-inactive'}}">{{item.is_active ? '生效中' : '已停用'}}</text>
        </view>
        <view class="config-summary">
          <text class="summary-text" wx:for="{{item.configs}}" wx:key="_id" wx:for-item="cfg">{{cfg.duration}}分钟 · ¥{{cfg.salary_rate}}/节</text>
        </view>
        <view class="config-actions">
          <view class="action-btn edit" bindtap="onEditConfig" data-item="{{item}}">编辑</view>
          <view class="action-btn delete" bindtap="onDeleteConfig" data-id="{{item.configs[0]._id}}">删除</view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && salaryConfigList.length === 0}}" icon="" text="暂无薪酬配置"></empty-state>
  </view>

  <!-- 薪酬统计 -->
  <view class="tab-content" wx:if="{{activeTab === 'stats'}}">
    <!-- ======== 上半部分：月度薪酬列表 ======== -->
    <view class="salary-section-title">月度薪酬明细</view>
    <view class="salary-year-list" wx:if="{{salaryMonthlyYears.length > 0}}">
      <view class="salary-year-group" wx:for="{{salaryMonthlyYears}}" wx:key="year" wx:for-index="yi">
        <text class="salary-year-label">{{item.yearLabel}}</text>
        <view class="salary-month-group" wx:for="{{item.months}}" wx:for-item="month" wx:key="monthKey" wx:for-index="mi">
          <view class="salary-month-header" bindtap="onToggleSalaryMonth" data-yi="{{yi}}" data-mi="{{mi}}">
            <text class="salary-month-toggle {{month._expanded ? 'expanded' : ''}}">▸</text>
            <text class="salary-month-label">{{month.monthLabel}}</text>
            <text class="salary-month-coach-count">{{month.coaches.length}}位教练</text>
            <text class="salary-month-total">¥{{month.totalAmount}}</text>
          </view>
          <view class="salary-month-coaches" wx:if="{{month._expanded}}">
            <view class="salary-coach-card" wx:for="{{month.coaches}}" wx:for-item="coach" wx:key="coach_id">
              <view class="salary-card-header">
                <text class="salary-card-name">{{coach.coach_name}}</text>
                <text class="salary-card-total">¥{{coach.total_amount}}</text>
              </view>
              <view class="salary-card-rows">
                <view class="salary-card-row" wx:for="{{coach.durations}}" wx:for-item="d" wx:key="duration">
                  <text class="salary-row-dur">{{d.duration}}分钟</text>
                  <text class="salary-row-count">{{d.count}}节</text>
                  <text class="salary-row-mul">×</text>
                  <text class="salary-row-rate">¥{{d.rate}}/节</text>
                  <text class="salary-row-eq">=</text>
                  <text class="salary-row-amount">¥{{d.amount}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && salaryMonthlyYears.length === 0}}" text="暂无薪酬记录"></empty-state>

    <!-- ======== 下半部分：账单管理 ======== -->
    <view class="salary-section-title" style="margin-top:32rpx">账单管理</view>

    <!-- 日期选择 + 预览（始终可见） -->
    <view class="date-range-selector">
      <view class="date-item">
        <text class="date-label">开始日期</text>
        <picker mode="date" value="{{statForm.startDate}}" bindchange="onStatStartDateChange">
          <view class="date-picker"><text>{{statForm.startDate || '选择日期'}}</text></view>
        </picker>
      </view>
      <view class="date-separator">~</view>
      <view class="date-item">
        <text class="date-label">结束日期</text>
        <picker mode="date" value="{{statForm.endDate}}" bindchange="onStatEndDateChange">
          <view class="date-picker"><text>{{statForm.endDate || '选择日期'}}</text></view>
        </picker>
      </view>
      <view class="generate-btn" bindtap="onGenerateBill">
        <text>生成账单</text>
      </view>
    </view>

    <!-- 预览内容 -->
    <view class="bill-form-panel" wx:if="{{billPreview && !billGenerated}}">
      <view class="bill-preview-header">
        <text class="bill-preview-title">账单预览: {{statForm.startDate}} ~ {{statForm.endDate}}</text>
        <text class="bill-preview-close" bindtap="onCloseBillContent">×</text>
      </view>
      <view class="bill-coaches" wx:for="{{billPreview}}" wx:key="coach_id" wx:for-index="bi" wx:for-item="item">
        <view class="bill-coach-header" bindtap="onToggleBillCoach" data-index="{{bi}}">
          <view class="bill-coach-check {{item._selected ? 'checked' : ''}}">
            <text class="check-mark" wx:if="{{item._selected}}">√</text>
          </view>
          <text class="coach-name">{{item.coach_name}}</text>
          <text class="coach-total">¥{{item.total_amount}}</text>
        </view>
        <view class="bill-items" wx:for="{{item.items}}" wx:key="duration" wx:for-item="detail">
          <view class="bill-item-row">
            <text class="bill-item-label">{{detail.duration}}分钟 × {{detail.count}}节</text>
            <text class="bill-item-value">¥{{detail.amount}}</text>
          </view>
        </view>
      </view>
      <view class="bill-total-row">
        <text class="bill-total-label">已选 {{billSelectedCount}} 位教练 · 合计</text>
        <text class="bill-total-value">¥{{billSelectedAmount}}</text>
      </view>
      <view class="bill-warning" wx:if="{{settledWarning}}">
        <text class="warning-text">{{settledWarning}}</text>
      </view>
      <view class="bill-inline-actions">
        <view class="modal-btn cancel" bindtap="onCloseBillContent">取消</view>
        <view class="modal-btn confirm" bindtap="onConfirmGenerateBill">确认生成({{billSelectedCount}}人)</view>
      </view>
    </view>

    <!-- 已生成的账单列表 -->
    <view class="bill-list-section">
      <view class="bill-card card" wx:for="{{billList}}" wx:key="_id" wx:for-index="bi">
        <!-- 标题：06/01-06/13 教练薪酬结算 -->
        <view class="bill-card-header" bindtap="onToggleBillCard" data-index="{{bi}}">
          <view class="bill-card-hd-left">
            <text class="bill-card-title">{{item._title}}</text>
            <view class="bill-card-info">
              <text class="bill-card-period">周期 {{item._start}} ~ {{item._end}}</text>
              <text class="bill-card-gen">{{item._gen}} 生成</text>
            </view>
            <text class="bill-card-coaches">{{item._coaches}}</text>
          </view>
          <view class="bill-card-hd-right">
            <text class="bill-card-amount">¥{{item.total_amount}}</text>
            <text class="bill-card-arrow {{item._expanded ? 'expanded' : ''}}">▾</text>
          </view>
        </view>
        <!-- 展开详情 -->
        <view class="bill-card-body" wx:if="{{item._expanded}}">
          <!-- 教练明细 -->
          <block wx:for="{{item.coaches}}" wx:for-item="coach" wx:key="coach_id">
            <view class="bill-body-row">
              <text class="bill-body-coach">{{coach.coach_name}}</text>
              <text class="bill-body-coach-total">¥{{coach.total_amount}}</text>
            </view>
            <view class="bill-body-item" wx:for="{{coach.items}}" wx:for-item="di" wx:key="duration">
              <text class="bill-body-dur">{{di.duration}}分钟</text>
              <text class="bill-body-calc">{{di.count}}节 · ¥{{di.rate}}/节</text>
              <text class="bill-body-amt">¥{{di.amount}}</text>
            </view>
          </block>
          <!-- 合计 -->
          <view class="bill-body-total">
            <text>合计金额</text>
            <text class="bill-total-num">¥{{item.total_amount}}</text>
          </view>
          <!-- 操作按钮 -->
          <view class="bill-body-actions">
            <view class="bill-action-btn" bindtap="onExportBillCard" data-index="{{bi}}">导出</view>
            <view class="bill-action-btn danger" bindtap="onDeleteBill" data-index="{{bi}}">删除</view>
          </view>
        </view>
      </view>
      <empty-state wx:if="{{billList.length === 0}}" text="暂无结算单，选择日期后点击「生成账单」创建"></empty-state>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="load-more">加载中...</text>
  </view>

  <!-- 配置弹窗 -->
  <view class="modal-mask" wx:if="{{showConfigModal}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{editConfig ? '编辑薪酬配置' : '添加薪酬配置'}}</text>
        <text class="modal-close" bindtap="onCloseModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">教练</text>
          <picker mode="selector" range="{{coachNames}}" bindchange="onCoachChange">
            <view class="form-picker">
              <text>{{selectedCoachName || '请选择教练'}}</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label-row">
            <text class="form-label">时长配置</text>
            <view class="add-item-btn" bindtap="addConfigItem">
              <text>+ 添加</text>
            </view>
          </view>
          
          <view class="config-items-list">
            <view class="config-item-row" wx:for="{{configItems}}" wx:key="index">
              <view class="item-left">
                <picker mode="selector" range="{{durationOptions}}" bindchange="onDurationItemChange" data-index="{{index}}">
                  <view class="form-picker small">
                    <text>{{item.duration}}分钟</text>
                  </view>
                </picker>
                <text class="divider">/</text>
                <input class="form-input small" type="digit" placeholder="薪酬" value="{{item.salary_rate}}" bindinput="onSalaryRateChange" data-index="{{index}}" />
                <text class="unit">元/节</text>
              </view>
              <view class="item-right" wx:if="{{configItems.length > 1}}" bindtap="removeConfigItem" data-index="{{index}}">
                <text class="remove-icon">×</text>
              </view>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">生效日期</text>
          <picker mode="date" value="{{commonForm.effective_from}}" bindchange="onEffectiveFromChange">
            <view class="form-picker">
              <text>{{commonForm.effective_from || '请选择日期'}}</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">备注</text>
          <input class="form-input" type="text" placeholder="请输入备注" value="{{commonForm.remark}}" bindinput="onCommonInputChange" data-field="remark" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="onCloseModal">取消</view>
        <view class="modal-btn confirm" bindtap="onSaveConfig">保存</view>
      </view>
    </view>
  </view>

  <!-- 统计详情弹窗 -->
  <view class="modal-mask" wx:if="{{showStatModal && currentStat}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">薪酬详情</text>
        <text class="modal-close" bindtap="onCloseModal">×</text>
      </view>
      <view class="modal-body">
        <view class="detail-row">
          <text class="detail-label">教练</text>
          <text class="detail-value">{{currentStat.coach_id && currentStat.coach_id.name ? currentStat.coach_id.name : '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">课程名称</text>
          <text class="detail-value">{{currentStat.schedule_id && currentStat.schedule_id.course_name ? currentStat.schedule_id.course_name : '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">上课时间</text>
          <text class="detail-value">{{currentStat.class_date ? currentStat.class_date.split('T')[0] : '-'}} {{currentStat.schedule_id && currentStat.schedule_id.start_time ? currentStat.schedule_id.start_time : '-'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">课程时长</text>
          <text class="detail-value">{{currentStat.duration || 0}}分钟</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">薪酬单价</text>
          <text class="detail-value">¥{{currentStat.salary_rate || 0}}/节</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">签到人数</text>
          <text class="detail-value">{{currentStat.attendance_count || 0}}人</text>
        </view>
        <view class="detail-row total">
          <text class="detail-label">应发金额</text>
          <text class="detail-value">¥{{currentStat.total_salary || 0}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">状态</text>
          <text class="detail-value {{currentStat.status === 'settled' ? 'text-green' : currentStat.status === 'cancelled' ? 'text-red' : 'text-orange'}}">
            {{currentStat.status === 'settled' ? '已结算' : currentStat.status === 'cancelled' ? '已取消' : '待结算'}}
          </text>
        </view>
        <view class="detail-row" wx:if="{{currentStat.settled_at}}">
          <text class="detail-label">结算时间</text>
          <text class="detail-value">{{currentStat.settled_at ? currentStat.settled_at.split('T')[0] : '-'}}</text>
        </view>
        <view class="detail-row" wx:if="{{currentStat.remark}}">
          <text class="detail-label">备注</text>
          <text class="detail-value">{{currentStat.remark}}</text>
        </view>
      </view>
      <view class="modal-footer" wx:if="{{currentStat.status !== 'settled' && currentStat.status !== 'cancelled'}}">
        <view class="modal-btn cancel" bindtap="onCancelStat">取消统计</view>
        <view class="modal-btn confirm" bindtap="onSettleStat">确认结算</view>
      </view>
    </view>
  </view>

  <!-- 自定义时长弹窗 -->
  <view class="modal-mask" wx:if="{{showCustomDurationModal}}" bindtap="onCloseCustomDurationModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">自定义时长</text>
        <text class="modal-close" bindtap="onCloseCustomDurationModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">请输入时长（分钟）</text>
          <input class="form-input" type="digit" placeholder="例如：75" value="{{customDurationValue}}" bindinput="onCustomDurationInput" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="onCloseCustomDurationModal">取消</view>
        <view class="modal-btn confirm" bindtap="onConfirmCustomDuration">确认</view>
      </view>
    </view>
  </view>
</view>