.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(20rpx + env(safe-area-inset-top)) 28rpx 100rpx;
  background: var(--bg-input);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.top-btn {
  display: flex;
  align-items: center;
  background: var(--color-primary);
  color: var(--text-inverse);
  padding: 14rpx 28rpx;
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  font-weight: 600;
}

.top-btn:active {
  opacity: 0.85;
}

.top-btn-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
  margin-right: 8rpx;
}

.top-btn-icon::before,
.top-btn-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  background: var(--text-inverse);
}

.top-btn-icon::before {
  width: 20rpx;
  height: 3rpx;
  transform: translate(-50%, -50%);
}

.top-btn-icon::after {
  width: 3rpx;
  height: 20rpx;
  transform: translate(-50%, -50%);
}

.controls {
  margin-bottom: 24rpx;
}

.picker-wrap {
  display: inline-flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.picker-label {
  margin-right: 12rpx;
}

.picker-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid var(--text-secondary);
  border-bottom: 2rpx solid var(--text-secondary);
  transform: rotate(45deg);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  border: 1rpx solid var(--border);
}

.list-item.inactive {
  opacity: 0.5;
}

.item-main {
  margin-bottom: 20rpx;
}

.item-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-status {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.item-status.on {
  background: var(--color-success);
}

.item-status.off {
  background: var(--text-tertiary);
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.item-store {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  margin-left: 12rpx;
}

.item-store.global {
  color: var(--color-success);
  background: var(--color-success-bg);
}

.item-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.action-btn.edit {
  color: var(--color-primary);
  background: var(--color-primary-bg);
}

.action-btn.pause {
  color: var(--color-danger);
  background: var(--color-danger-bg);
}

.action-btn.resume {
  color: var(--color-success);
  background: var(--color-success-bg);
}

.action-btn.del {
  color: var(--text-secondary);
  background: var(--bg-elevated);
  margin-left: auto;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.empty-action {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  padding: 16rpx 40rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-lg);
}

.loading-area {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 0;
  width: 580rpx;
  max-height: 80vh;
  overflow-y: auto;
  animation: modalPop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalPop {
  from { transform: scale(0.88); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mc-x {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.mc-x::before,
.mc-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 2rpx;
  background: var(--text-secondary);
  border-radius: 1rpx;
}

.mc-x::before { transform: translate(-50%,-50%) rotate(45deg); }
.mc-x::after { transform: translate(-50%,-50%) rotate(-45deg); }

.modal-body {
  padding: 28rpx 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 20rpx;
}

.form-picker-text {
  font-size: 26rpx;
  color: var(--text-primary);
}

.form-switch-row {
  display: flex;
  align-items: center;
}

.form-switch {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  position: relative;
  transition: background 0.3s ease;
  margin-right: 16rpx;
}

.form-switch.on {
  background: var(--color-success);
}

.form-switch.off {
  background: var(--text-tertiary);
}

.form-switch-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--text-inverse);
  position: absolute;
  top: 4rpx;
  transition: left 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.form-switch.on .form-switch-dot {
  left: 40rpx;
}

.form-switch.off .form-switch-dot {
  left: 4rpx;
}

.form-switch-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

.mf-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 600;
}

.mf-btn.cancel {
  background: var(--bg-elevated);
  color: var(--text-secondary);
}

.mf-btn.confirm {
  background: var(--color-primary);
  color: var(--text-inverse);
}

.mf-btn:active {
  opacity: 0.85;
}