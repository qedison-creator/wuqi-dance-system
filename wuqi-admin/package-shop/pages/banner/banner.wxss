.banner-page {
  padding: 24rpx;
  padding-bottom: 40rpx;
  background-color: var(--bg-input);
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.header-left {
  flex: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-primary);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(197, 116, 75, 0.3);
}

.add-btn text {
  font-size: 28rpx;
  color: var(--text-inverse);
  font-weight: 600;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 700;
}

/* 轮播图列表 */
.banner-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.banner-item {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.banner-preview {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.65));
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.banner-info {
  flex: 1;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

.banner-status {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-xl);
  font-size: 22rpx;
}

.banner-status.active {
  background: rgba(91, 140, 90, 0.9);
  color: var(--text-inverse);
}

.banner-status.disabled {
  background: rgba(139, 126, 106, 0.9);
  color: var(--text-inverse);
}

.banner-meta {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 40rpx;
  border-bottom: 1rpx solid var(--border);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.meta-value {
  font-size: 24rpx;
  color: var(--text-primary);
}

.meta-value.link {
  color: var(--color-primary);
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-actions {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: var(--radius-lg);
  text-align: center;
}

.action-btn text {
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: var(--color-primary-bg);
}

.action-btn.primary text {
  color: var(--color-primary);
}

.action-btn.warning {
  background: var(--color-warning-bg);
}

.action-btn.warning text {
  color: var(--color-warning);
}

.action-btn.success {
  background: var(--color-success-bg);
}

.action-btn.success text {
  color: var(--color-success);
}

.action-btn.danger {
  background: var(--color-danger-bg);
}

.action-btn.danger text {
  color: var(--color-danger);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 40rpx;
}

.empty-btn {
  background: var(--color-primary);
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 28rpx;
  color: var(--text-inverse);
  font-weight: 600;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  -webkit-overflow-scrolling: touch;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

/* 上传区域 */
.upload-section {
  padding: 24rpx 32rpx;
}

.upload-area {
  width: 100%;
  height: 320rpx;
  border: 3rpx dashed var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: inherit;
}

.upload-area::after {
  border: none;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.upload-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.upload-status {
  text-align: center;
  padding: 16rpx;
  color: var(--color-primary);
  font-size: 26rpx;
}

/* 表单 */
.form-group {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  padding: 0 32rpx;
  gap: 24rpx;
}

.form-group.half {
  flex: 1;
  padding: 0;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
}

.switch-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 弹窗按钮 */
.modal-buttons {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 32rpx;
  flex-shrink: 0;
  border-top: 1rpx solid var(--border);
  background: var(--bg-card);
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-secondary {
  background: transparent;
  border: 2rpx solid var(--color-primary);
}

.btn-secondary text {
  font-size: 30rpx;
  color: var(--color-primary);
}

.btn-secondary:active {
  background: rgba(197, 116, 75, 0.15);
}

.btn-primary {
  background: var(--color-primary);
  box-shadow: 0 8rpx 24rpx rgba(197, 116, 75, 0.3);
}

.btn-primary text {
  font-size: 30rpx;
  color: var(--text-inverse);
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}