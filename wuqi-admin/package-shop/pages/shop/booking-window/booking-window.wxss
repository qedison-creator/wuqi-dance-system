.page {
  padding: 20rpx 30rpx 60rpx;
  background: #F6F3F0;
  min-height: 100vh;
  box-sizing: border-box;
}

.guide-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.guide-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.guide-icon {
  font-size: 40rpx;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.guide-text {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.form-hint {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  margin-bottom: 16rpx;
}

/* 保存状态标记 */
.save-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.save-status.saved {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
}

.save-status.modified {
  color: #fa8c16;
  background: rgba(250, 140, 22, 0.1);
}

.status-icon {
  font-size: 24rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fa8c16;
}

.status-text {
  font-size: 22rpx;
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-field {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.unit-input {
  max-width: 200rpx;
}

.unit-text {
  font-size: 28rpx;
  color: #888;
}

.preview-box {
  background: #F6F3F0;
  border-radius: 12rpx;
  padding: 24rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  margin-bottom: 12rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.highlight {
  color: #C5744B;
  font-weight: 600;
}

/* 保存按钮 - 使用管理端全局规范 */
.btn-row {
  display: flex;
  justify-content: center;
  padding: 0 30rpx;
}

.btn-primary {
  flex: 1;
  max-width: 600rpx;
}
