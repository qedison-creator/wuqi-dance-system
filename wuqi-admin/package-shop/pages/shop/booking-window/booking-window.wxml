<view class="page">
  <view class="guide-card">
    <view class="guide-header">
      <text class="guide-icon"></text>
      <text class="guide-title">预约开放设置</text>
    </view>
    <text class="guide-text">设置会员可以提前多少天预约课程。例如设置为 1 天，则会员只能预约当天的课程。</text>
  </view>

  <view class="form-card">
    <view class="form-group">
      <view class="form-label-row">
        <text class="form-label">开放预约天数</text>
        <view class="save-status {{saveStatus}}">
          <text wx:if="{{saveStatus === 'saved'}}" class="status-icon">✓</text>
          <text wx:elif="{{saveStatus === 'modified'}}" class="status-dot"></text>
          <text class="status-text">{{saveStatus === 'saved' ? '已保存' : (saveStatus === 'modified' ? '未保存' : '')}}</text>
        </view>
      </view>
      <text class="form-hint">会员只能预约 N 天内的课程（含当天）</text>
      <view class="input-with-unit">
        <input class="input-field unit-input" type="number" placeholder="7" value="{{bookingWindowDays}}" data-field="bookingWindowDays" bindinput="onInput" />
        <text class="unit-text">天</text>
      </view>
    </view>

    <view class="preview-box">
      <text class="preview-label">效果预览</text>
      <text class="preview-text">设置为 <text class="highlight">{{bookingWindowDays || 7}}</text> 天时：</text>
      <text class="preview-text">· 会员可以预约今天 + 未来 {{(bookingWindowDays || 7) - 1}} 天的课程</text>
      <text class="preview-text">· 超出此范围的课程显示"未开放预约"</text>
    </view>
  </view>

  <view class="btn-row">
    <view class="btn-primary {{saveStatus === 'saving' ? 'disabled' : ''}}" bindtap="onSave">
      <text>{{saveStatus === 'saving' ? '保存中...' : '保存设置'}}</text>
    </view>
  </view>
</view>