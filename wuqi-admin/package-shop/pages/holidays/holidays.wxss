.holidays-page {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 新增按钮 */
.add-section {
  margin-bottom: 20rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

/* 放假列表 */
.holiday-list {
  display: flex;
  flex-direction: column;
}

.holiday-item {
  padding: 24rpx;
}

.holiday-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.holiday-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.holiday-status {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-lg);
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-active {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-revoked {
  background-color: var(--color-completed-bg);
  color: var(--text-secondary);
}

.holiday-details {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.detail-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  width: 36rpx;
  text-align: center;
}

.detail-text {
  font-size: 26rpx;
  color: var(--text-primary);
}

.store-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.store-tag {
  padding: 4rpx 12rpx;
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 14rpx;
  font-size: 22rpx;
}

.holiday-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.btn-edit {
  background-color: var(--color-info-bg);
  color: var(--color-info);
}

.btn-revoke {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.btn-delete {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

/* 弹窗 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

.picker-field {
  display: flex;
  align-items: center;
}

.placeholder {
  color: var(--text-tertiary);
}

.submit-btn {
  margin-top: 30rpx;
}

/* 适用范围选择 */
.scope-options {
  display: flex;
  gap: 20rpx;
}

.scope-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-input);
  border-radius: var(--radius-xl);
  border: 2rpx solid transparent;
  transition: all var(--transition-normal);
}

.scope-item.active {
  background-color: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.scope-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.scope-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.scope-item.active .scope-name {
  color: var(--color-primary);
  font-weight: bold;
}

/* 门店列表 */
.store-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.store-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--bg-input);
  border-radius: 14rpx;
  border: 2rpx solid transparent;
}

.store-item.active {
  background-color: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.store-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.store-item.active .store-name {
  color: var(--color-primary);
  font-weight: bold;
}

.store-check {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: bold;
}