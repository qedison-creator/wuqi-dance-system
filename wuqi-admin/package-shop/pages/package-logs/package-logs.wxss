.package-logs-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.filter-bar {
  margin-bottom: 20rpx;
}

.page-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}
.hf-store {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx 8rpx 14rpx;
  background: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(185,130,100,0.2);
  border-radius: 28rpx;
}

.hf-store:active {
  background: rgba(212,120,110,0.08);
}

.hfs-icon {
  font-size: 22rpx;
  color: #D4786E;
  margin-right: 6rpx;
}

.hfs-label {
  font-size: 21rpx;
  color: #6B5D56;
  font-weight: 500;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 4rpx;
}

.hfs-arrow {
  font-size: 18rpx;
  color: #C4B3A4;
}

/* 门店选择弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44,36,22,0.45);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
}

.store-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 56rpx 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,33,34,0.12);
}

.stm-hd {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.stm-title {
  font-size: 34rpx;
  color: #2C2416;
  font-weight: 700;
  text-align: center;
}

.stm-list {
  margin-bottom: 28rpx;
}

.stm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 20rpx;
  background: #F9F7F5;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.stm-item:last-child {
  margin-bottom: 0;
}

.stm-item:active {
  transform: scale(0.98);
}

.stm-active {
  background: #FDF2EF;
  border-color: #D4786E;
}

.stm-name {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 500;
}

.stm-active .stm-name {
  color: #D4786E;
  font-weight: 700;
}

.stm-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #C05D53);
  position: relative;
}

.stm-check::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%) rotate(45deg);
  width: 10rpx;
  height: 18rpx;
  border-bottom: 3rpx solid #FFFFFF;
  border-right: 3rpx solid #FFFFFF;
}

.stm-bottom {
  display: block;
}

.stm-close-btn {
  width: 100%;
  padding: 22rpx 0;
  background: #F9F7F5;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.stm-close-btn:active {
  opacity: 0.7;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.tab-bar {
  display: flex;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all var(--transition-normal);
}

.tab-item.active {
  background: var(--color-primary);
  color: var(--text-inverse);
  font-weight: bold;
}

.tab-content {
  min-height: 400rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.logs-list {
  display: flex;
  flex-direction: column;
}

.log-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.log-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.log-title-wrap {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.log-nick {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: normal;
}

.log-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

/* 状态标签颜色 */
.status-active {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-pending {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-expired, .status-exhausted {
  background: var(--color-error-bg);
  color: var(--color-error);
}

.log-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.log-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-row:last-child {
  margin-bottom: 0;
}

.log-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.log-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.log-value.highlight {
  color: var(--color-primary);
  font-weight: bold;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
}

.load-more {
  font-size: 26rpx;
  color: var(--text-tertiary);
}