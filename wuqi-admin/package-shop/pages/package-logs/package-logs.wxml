<view class="package-logs-page">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'activation' ? 'active' : ''}}" bindtap="onTabChange" data-tab="activation">
      <text>激活记录</text>
    </view>
    <view class="tab-item {{activeTab === 'extension' ? 'active' : ''}}" bindtap="onTabChange" data-tab="extension">
      <text>延长记录</text>
    </view>
    <view class="tab-item {{activeTab === 'entry' ? 'active' : ''}}" bindtap="onTabChange" data-tab="entry">
      <text>套餐录入</text>
    </view>
  </view>

  <view class="tab-content" wx:if="{{activeTab === 'activation'}}">
    <view class="page-header">
      <text class="page-title text-heading">套餐激活记录</text>
      <view class="hf-store" bindtap="onOpenStoreModal">
        <text class="hfs-icon"></text>
        <text class="hfs-label">{{currentStoreName}}</text>
        <text class="hfs-arrow">▾</text>
      </view>
    </view>

    <view class="logs-list" wx:if="{{activationList.length > 0}}">
      <view class="log-item card" wx:for="{{activationList}}" wx:key="_id">
        <view class="log-header">
          <view class="log-title-wrap">
            <text class="log-title">{{item.user_real_name || item.user_nick_name || '未知会员'}}</text>
          </view>
          <text class="log-type">{{item.typeLabel}}</text>
        </view>
        <view class="log-body">
          <view class="log-row">
            <text class="log-label">套餐名称</text>
            <text class="log-value">{{item.package_name || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">激活时间</text>
            <text class="log-value">{{item.activated_at_display || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">生效日期</text>
            <text class="log-value">{{item.effective_date_display || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">到期日期</text>
            <text class="log-value">{{item.expire_date_display || '-'}}</text>
          </view>
          <view class="log-row" wx:if="{{item.operator_name}}">
            <text class="log-label">操作人</text>
            <text class="log-value">{{item.operator_name}}</text>
          </view>
          <view class="log-row" wx:if="{{item.remark}}">
            <text class="log-label">备注</text>
            <text class="log-value">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && activationList.length === 0}}" icon="" text="暂无激活记录"></empty-state>
  </view>

  <view class="tab-content" wx:if="{{activeTab === 'extension'}}">
    <view class="page-header">
      <text class="page-title text-heading">套餐有效期延长记录</text>
      <view class="hf-store" bindtap="onOpenStoreModal">
        <text class="hfs-icon"></text>
        <text class="hfs-label">{{currentStoreName}}</text>
        <text class="hfs-arrow">▾</text>
      </view>
    </view>

    <view class="logs-list" wx:if="{{extensionList.length > 0}}">
      <view class="log-item card" wx:for="{{extensionList}}" wx:key="_id">
        <view class="log-header">
          <view class="log-title-wrap">
            <text class="log-title">{{item.user_real_name || item.user_nick_name || '未知会员'}}</text>
          </view>
          <text class="log-type">{{item.typeLabel}}</text>
        </view>
        <view class="log-body">
          <view class="log-row">
            <text class="log-label">套餐名称</text>
            <text class="log-value">{{item.package_name || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">延长时间</text>
            <text class="log-value">{{item.created_at_display || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">延长天数</text>
            <text class="log-value highlight">+{{item.extend_days}}天</text>
          </view>
          <view class="log-row">
            <text class="log-label">原到期日</text>
            <text class="log-value">{{item.original_expire_display || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">新到期日</text>
            <text class="log-value">{{item.new_expire_display || '-'}}</text>
          </view>
          <view class="log-row" wx:if="{{item.holiday_name}}">
            <text class="log-label">关联放假</text>
            <text class="log-value">{{item.holiday_name}}</text>
          </view>
          <view class="log-row" wx:if="{{item.operator_name}}">
            <text class="log-label">操作人</text>
            <text class="log-value">{{item.operator_name}}</text>
          </view>
          <view class="log-row" wx:if="{{item.remark}}">
            <text class="log-label">备注</text>
            <text class="log-value">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && extensionList.length === 0}}" icon="" text="暂无延长记录"></empty-state>
  </view>

  <view class="tab-content" wx:if="{{activeTab === 'entry'}}">
    <view class="page-header">
      <text class="page-title text-heading">套餐录入记录</text>
      <view class="hf-store" bindtap="onOpenStoreModal">
        <text class="hfs-icon"></text>
        <text class="hfs-label">{{currentStoreName}}</text>
        <text class="hfs-arrow">▾</text>
      </view>
    </view>

    <view class="logs-list" wx:if="{{entryList.length > 0}}">
      <view class="log-item card" wx:for="{{entryList}}" wx:key="_id">
        <view class="log-header">
          <view class="log-title-wrap">
            <text class="log-title">{{item.user_real_name || item.user_nick_name || '未知会员'}}</text>
          </view>
          <text class="log-type status-{{item.status}}">{{item.statusLabel}}</text>
        </view>
        <view class="log-body">
          <view class="log-row">
            <text class="log-label">套餐名称</text>
            <text class="log-value">{{item.package_name || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">录入时间</text>
            <text class="log-value">{{item.created_at_display || '-'}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">套餐类型</text>
            <text class="log-value">{{item.packageTypeLabel}}</text>
          </view>
          <view class="log-row" wx:if="{{item.creditsText}}">
            <text class="log-label">课时/时长</text>
            <text class="log-value">{{item.creditsText}}</text>
          </view>
          <view class="log-row" wx:if="{{item.operator_name}}">
            <text class="log-label">操作人</text>
            <text class="log-value">{{item.operator_name}}</text>
          </view>
          <view class="log-row" wx:if="{{item.remark}}">
            <text class="log-label">备注</text>
            <text class="log-value">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{!loading && entryList.length === 0}}" icon="" text="暂无录入记录"></empty-state>
  </view>

  <!-- 加载更多提示 -->
  <view class="loading-more" wx:if="{{loading && page > 1}}">
    <text class="load-more">加载中...</text>
  </view>
  
  <!-- 无更多数据提示 -->
  <view class="no-more" wx:if="{{!hasMore && !loading && (activationList.length > 0 || extensionList.length > 0 || entryList.length > 0)}}">
    <text class="no-more-text">没有更多数据了</text>
  </view>
  
  <!-- 初始加载提示 -->
  <view class="loading" wx:if="{{loading && page === 1}}">
    <text class="load-more">加载中...</text>
  </view>

  <!-- 门店选择弹窗 -->
  <view class="modal-mask" wx:if="{{showStoreModal}}" bindtap="onCloseStoreModal">
    <view class="store-modal" catchtap="">
      <view class="stm-hd">
        <text class="stm-title">选择门店</text>
      </view>
      <scroll-view class="stm-list" scroll-y>
        <view class="stm-item {{currentStoreIndex === index ? 'stm-active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-index="{{index}}" bindtap="onSelectStore">
          <text class="stm-name">{{item.name}}</text>
          <view class="stm-check" wx:if="{{currentStoreIndex === index}}"></view>
        </view>
      </scroll-view>
      <view class="stm-bottom">
        <view class="stm-close-btn" bindtap="onCloseStoreModal">关闭</view>
      </view>
    </view>
  </view>
</view>