<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar card">
    <view class="filter-item">
      <text class="filter-label">模块</text>
      <picker mode="selector" range="{{moduleOptions}}" range-key="label" value="{{moduleIndex}}" bindchange="onModuleChange">
        <view class="filter-picker">
          <text>{{moduleOptions[moduleIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="filter-label">操作</text>
      <picker mode="selector" range="{{actionOptions}}" range-key="label" value="{{actionIndex}}" bindchange="onActionChange">
        <view class="filter-picker">
          <text>{{actionOptions[actionIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>
  
  <!-- 日志列表 -->
  <view class="log-list">
    <view class="log-item card" wx:for="{{logs}}" wx:key="_id">
      <view class="log-header">
        <view class="log-action-row">
          <text class="log-module-tag">{{item.module}}</text>
          <text class="log-action">{{item.action}}</text>
        </view>
        <text class="log-result {{item.result === 'success' ? 'success' : 'failure'}}">{{item.result === 'success' ? '成功' : '失败'}}</text>
      </view>
      <view class="log-detail">
        <text class="log-operator">{{item.operator_name || '系统'}}</text>
        <text class="log-time">{{item.created_at}}</text>
      </view>
      <view class="log-info" wx:if="{{item.detail}}">
        <text class="log-detail-text">{{item.detail}}</text>
      </view>
    </view>
  </view>
  
  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{logs.length > 0}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">没有更多了</text>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && logs.length === 0}}">
    <text class="empty-text">暂无操作日志</text>
  </view>
</view>