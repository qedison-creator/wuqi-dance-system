.schedule-page {
  padding: 20rpx;
  padding-bottom: 80rpx;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

.store-tabs {
  margin-bottom: 20rpx;
}

.store-scroll {
  white-space: nowrap;
}

.store-list {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.store-item {
  padding: 16rpx 32rpx;
  background-color: var(--bg-card);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.store-item.active {
  background-color: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.store-item text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.store-item.active text {
  color: var(--color-primary);
  font-weight: bold;
}

.view-mode-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border);
}

.view-mode-tabs {
  display: flex;
  gap: 12rpx;
}

.view-mode-item {
  padding: 12rpx 28rpx;
  background-color: var(--bg-input);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.view-mode-item text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.view-mode-item.active {
  background-color: var(--color-primary-bg);
  border-color: var(--color-primary);
}

.view-mode-item.active text {
  color: var(--color-primary);
  font-weight: bold;
}

.today-btn {
  padding: 12rpx 24rpx;
  background-color: var(--color-primary-bg);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.today-btn text {
  font-size: 24rpx;
  color: var(--color-primary);
}

.date-section {
  margin-bottom: 20rpx;
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: flex;
  gap: 12rpx;
  padding: 10rpx 0;
}

.weekday-section {
  margin-bottom: 20rpx;
}

.weekday-list {
  display: flex;
  gap: 12rpx;
  padding: 10rpx 0;
}

.weekday-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 16rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border);
  flex: 1;
  min-width: 0;
  transition: all var(--transition-normal);
}

.weekday-item.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.weekday-item.today {
  border: 1rpx solid var(--color-primary);
}

.weekday-item.today.active {
  border-color: var(--bg-root);
}

.weekday-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.weekday-item.active .weekday-name {
  color: var(--text-inverse);
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border);
  min-width: 90rpx;
  flex-shrink: 0;
  position: relative;
}

.date-item.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.date-item.today {
  border: 1rpx solid var(--color-primary);
}

.date-item.today.active {
  border-color: var(--bg-root);
}

.date-item.past {
  background-color: var(--bg-card);
  opacity: 0.5;
}

.date-item.past .weekday,
.date-item.past .date {
  color: var(--text-tertiary);
}

.date-item.past.active {
  background-color: var(--text-tertiary);
  border-color: var(--text-tertiary);
  opacity: 1;
}

.date-item.past.active .weekday,
.date-item.past.active .date {
  color: var(--text-secondary);
}

.past-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background-color: var(--text-tertiary);
  border-radius: 50%;
}

.date-item.month-start {
  margin-left: 20rpx;
}

.date-item .weekday {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.date-item .date {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.date-item.active .weekday,
.date-item.active .date {
  color: var(--text-inverse);
}

.month-badge {
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 12rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-sm);
  font-size: 18rpx;
  color: var(--text-inverse);
  white-space: nowrap;
}

.month-section {
  background-color: var(--bg-card);
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border);
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.month-nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-elevated);
  border-radius: 50%;
}

.month-nav-btn text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.month-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.weekday-header {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.weekday-header text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 14.28%;
  text-align: center;
}

.month-calendar {
  padding-top: 16rpx;
}

.calendar-week {
  display: flex;
  flex-wrap: nowrap;
}

.calendar-cell {
  width: 14.28%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-cell.empty {
  background-color: transparent;
}

.calendar-cell.date {
  background-color: var(--bg-input);
  border-radius: 12rpx;
  margin: 4rpx;
  width: calc(14.28% - 8rpx);
}

.calendar-cell.date text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.calendar-cell.today {
  background-color: rgba(197, 116, 75, 0.12);
  border: 1rpx solid var(--color-primary);
}

.calendar-cell.today text {
  color: var(--color-primary);
  font-weight: bold;
}

.calendar-cell.selected {
  background-color: var(--color-primary);
}

.calendar-cell.selected text {
  color: var(--text-inverse);
  font-weight: bold;
}

.history-notice {
  background-color: var(--color-info-bg);
  border-left: 4rpx solid var(--text-tertiary);
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.history-notice text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-item.card {
  padding: 24rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--border);
}

.schedule-item.history {
  background-color: var(--bg-elevated);
  opacity: 0.85;
}

.schedule-item.history .course-name {
  color: var(--text-tertiary);
}

.schedule-item.history .info-row .value {
  color: var(--text-secondary);
}

.schedule-item.template-preview {
  border: 2rpx dashed var(--border);
  background-color: var(--bg-page);
}

.schedule-item.template-disabled {
  opacity: 0.55;
}

.schedule-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.course-name {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.schedule-header-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.schedule-source-tag {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background-color: var(--color-info-bg);
  color: var(--color-info);
}

.schedule-source-tag.temp-tag {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.schedule-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.schedule-status.available {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.schedule-status.full {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.schedule-status.cancelled,
.schedule-status.offline {
  background-color: var(--bg-elevated);
  color: var(--text-tertiary);
}

.schedule-status.not_open {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.schedule-status.history-status {
  background-color: var(--color-completed-bg);
  color: var(--color-completed);
}

.schedule-status.template-status {
  background-color: rgba(197, 116, 75, 0.12);
  color: var(--color-primary);
}

.schedule-status.scheduled-status {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.schedule-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
}

.info-row .label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 140rpx;
}

.info-row .value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
}

.cancel-reason {
  color: var(--color-danger) !important;
}

.schedule-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-light);
}

.action-btn {
  padding: 12rpx 24rpx;
  background-color: var(--bg-input);
  border-radius: 12rpx;
  text-align: center;
}

.action-btn text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-btn.primary {
  background-color: var(--color-primary);
}

.action-btn.primary text {
  color: var(--text-inverse);
}

.action-btn.danger {
  background-color: var(--color-danger-bg);
}

.action-btn.danger text {
  color: var(--color-danger);
}

.action-btn.disabled {
  background-color: var(--bg-input);
  opacity: 0.5;
}

.action-btn.disabled text {
  color: var(--text-tertiary);
}

.action-btn.history-action {
  background-color: var(--color-completed-bg);
}

.action-btn.history-action text {
  color: var(--color-completed);
}

.action-btn.toggle-btn {
  background-color: var(--color-success-bg);
}

.action-btn.toggle-btn text {
  color: var(--color-success);
}

.action-btn.disabled-toggle {
  background-color: var(--bg-elevated);
}

.action-btn.disabled-toggle text {
  color: var(--text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 30rpx;
}

.template-preview-hint {
  background-color: var(--color-warning-bg);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.template-preview-hint text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.template-actions-row {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.create-all-btn {
  background-color: var(--color-primary);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.create-all-btn text {
  font-size: 30rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

.schedule-actions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.copy-schedule-btn,
.add-schedule-btn {
  flex: 1;
  min-width: 200rpx;
  padding: 24rpx 48rpx;
  background-color: var(--color-primary);
  border-radius: 48rpx;
  text-align: center;
}

.copy-schedule-btn text,
.add-schedule-btn text {
  font-size: 30rpx;
  color: var(--text-inverse);
  font-weight: bold;
}

.manage-btn {
  padding: 12rpx 24rpx;
  background-color: var(--bg-input);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.manage-btn text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 36, 22, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx 0;
}

.modal-content {
  width: 88%;
  max-height: 75vh;
  background-color: var(--bg-card);
  border-radius: 32rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-content.manage-modal,
.modal-content.copy-modal {
  max-height: 80vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.modal-body-scroll {
  flex: 1;
  overflow-y: auto;
  padding-right: 20rpx;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 30rpx;
  padding: 16rpx 24rpx 24rpx;
  flex-shrink: 0;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  transition: var(--transition-fast);
}

.btn-secondary:active {
  background-color: var(--bg-card-hover);
  border-color: var(--color-primary);
}

.btn-secondary text {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-hover), var(--color-primary));
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-fab);
  transition: var(--transition-fast);
}

.btn-primary:active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
  transform: scale(0.98);
}

.btn-primary text {
  font-size: var(--font-md);
  color: var(--text-inverse);
  font-weight: bold;
}

.btn-primary.disabled {
  opacity: 0.5;
  box-shadow: none;
}

.btn-primary.disabled text {
  color: var(--text-inverse);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  padding: 20rpx 24rpx;
  background-color: var(--bg-input);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-primary);
}

.input-field.disabled {
  background-color: var(--bg-elevated);
  color: var(--text-tertiary);
}

.input-field.picker-field {
  display: flex;
  align-items: center;
}

.picker-field .placeholder {
  color: var(--text-tertiary);
}

.select-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.select-item {
  padding: 16rpx 28rpx;
  background-color: var(--bg-input);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.select-item text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.select-item.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.select-item.active text {
  color: var(--text-inverse);
}

.duration-list,
.credit-cost-list,
.deadtime-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.duration-item,
.credit-cost-item,
.deadtime-item {
  padding: 16rpx 28rpx;
  background-color: var(--bg-input);
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
}

.duration-item text,
.credit-cost-item text,
.deadtime-item text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.duration-item.active,
.credit-cost-item.active,
.deadtime-item.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.duration-item.active text,
.credit-cost-item.active text,
.deadtime-item.active text {
  color: var(--text-inverse);
}

.credit-cost-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 10rpx;
  display: block;
}

.slider {
  margin: 16rpx 0;
}

.slider-value {
  font-size: 24rpx;
  color: var(--color-primary);
  text-align: right;
  display: block;
}

.manage-section {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.manage-section-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.manage-section-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  line-height: 1.5;
}

.manage-options-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.manage-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background-color: var(--bg-input);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.manage-option-info {
  flex: 1;
}

.manage-option-name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.manage-option-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
}

.manage-option-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

.manage-date-picker {
  margin-bottom: 24rpx;
}

.manage-confirm-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.manage-confirm-area {
  background-color: var(--bg-page);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 1rpx solid var(--border);
}

.manage-warning {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.manage-warning-icon {
  font-size: 32rpx;
}

.manage-warning-text {
  font-size: 26rpx;
  color: var(--color-warning);
  flex: 1;
}

.manage-confirm-input {
  margin-top: 12rpx;
}

.manage-bottom-spacing {
  height: 40rpx;
}

.btn-danger {
  flex: 1;
  padding: 24rpx;
  background-color: var(--color-danger);
  border-radius: 20rpx;
  text-align: center;
}

.btn-danger text {
  font-size: 26rpx;
  color: var(--text-inverse);
}

.btn-danger.disabled {
  opacity: 0.5;
}

.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.step-item.active .step-dot {
  background-color: var(--color-primary);
  color: var(--text-inverse);
}

.step-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.step-item.active .step-text {
  color: var(--color-primary);
  font-weight: bold;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background-color: var(--border);
  margin: 0 8rpx;
  margin-bottom: 28rpx;
}

.step-line.active {
  background-color: var(--color-primary);
}

.step-content {
  margin-bottom: 20rpx;
}

.step-desc {
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.source-preview {
  background-color: var(--bg-page);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  border: 1rpx solid var(--border);
}

.preview-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

.preview-value {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: var(--color-success);
  display: block;
}

.preview-hint.warn {
  color: var(--color-warning);
}

.template-preview {
  background-color: var(--bg-page);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border);
}

.template-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

.template-count {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.template-weekdays {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.template-weekday-item {
  padding: 12rpx 20rpx;
  background-color: var(--bg-input);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.template-weekday-item .weekday-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: normal;
}

.weekday-count {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: bold;
}

.copy-mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.copy-mode-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background-color: var(--bg-input);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.copy-mode-item.active {
  background-color: var(--bg-card);
  border-color: var(--color-primary);
}

.mode-icon {
  font-size: 40rpx;
}

.mode-info {
  flex: 1;
}

.mode-name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 12rpx 0;
}

.stepper-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-input);
  border-radius: 50%;
  border: 1rpx solid var(--border);
}

.stepper-btn text {
  font-size: 36rpx;
  color: var(--text-primary);
}

.stepper-value {
  min-width: 80rpx;
  text-align: center;
}

.stepper-value text {
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.stepper-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
  display: block;
  margin-top: 8rpx;
}

.copy-preview-card {
  background-color: var(--color-success-bg);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.copy-preview-card .preview-label {
  font-size: 24rpx;
  color: var(--color-success);
}

.copy-preview-card .preview-value {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 0;
}

.confirm-card {
  background-color: var(--bg-page);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border);
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.confirm-row.highlight {
  padding-top: 16rpx;
}

.confirm-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.confirm-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.confirm-row.highlight .confirm-value {
  color: var(--color-primary);
  font-size: 28rpx;
}

.confirm-divider {
  height: 1rpx;
  background-color: var(--border);
  margin: 12rpx 0;
}

.confirm-notice {
  margin-top: 24rpx;
  padding: 20rpx;
  background-color: var(--bg-page);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-light);
}

.confirm-notice-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.8;
}

/* ========== 取消排课原因选择弹窗 ========== */
.cancel-reason-modal {
  max-height: 60vh;
}

.cancel-reason-modal .modal-body {
  flex: 1;
  overflow-y: auto;
}

.cancel-reason-warning {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background-color: #FFF3E0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 30rpx;
}

.warning-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #E65100;
  line-height: 1.6;
  flex: 1;
}

.cancel-reason-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cancel-reason-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background-color: var(--bg-page);
  border-radius: 16rpx;
  border: 2rpx solid var(--border-light);
  transition: all 0.2s;
}

.cancel-reason-item.active {
  border-color: var(--color-primary);
  background-color: rgba(var(--color-primary-rgb), 0.05);
}

.reason-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-light);
  flex-shrink: 0;
  box-sizing: border-box;
}

.reason-radio.checked {
  border-color: var(--color-primary);
  background-color: var(--color-primary);
  border-width: 0;
}

.reason-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 课程封面上传 */
.cover-upload-wrap {
  margin-top: 12rpx;
}

.cover-upload-box {
  width: 100%;
  height: 280rpx;
  border: 3rpx dashed var(--border);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-input);
  transition: all 0.2s ease;
}

.cover-upload-box:active {
  border-color: var(--color-primary);
  background-color: var(--bg-elevated);
}

.cover-upload-icon {
  font-size: 64rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.cover-upload-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.cover-upload-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.cover-preview-box {
  width: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: var(--bg-input);
}

.cover-preview-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

.cover-action-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background-color: var(--bg-card);
  border-top: 1rpx solid var(--border);
}

.cover-action-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.cover-action-btn:active {
  transform: scale(0.97);
}

.cover-action-change {
  background-color: var(--bg-input);
  border: 1rpx solid var(--border);
}

.cover-action-change .cover-action-text {
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 500;
}

.cover-action-delete {
  background-color: rgba(220, 80, 70, 0.08);
  border: 1rpx solid rgba(220, 80, 70, 0.2);
}

.cover-action-delete .cover-action-text {
  color: #DC5046;
  font-size: 26rpx;
  font-weight: 500;
}