.settings-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.menu-section {
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.menu-item:last-child {
  margin-bottom: 0;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}

.guide-card {
  margin-bottom: 30rpx;
}

.guide-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.guide-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.guide-title {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: bold;
}

.guide-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.guide-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  background-color: rgba(197, 116, 75, 0.15);
  border-radius: 8rpx;
}

.guide-btn text {
  font-size: 24rpx;
  color: var(--color-primary);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.form-card {
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.form-group:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.form-label.required::before {
  content: '*';
  color: var(--color-danger);
  margin-right: 4rpx;
}

.form-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background-color: var(--bg-root);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.unit-input {
  width: 200rpx;
  text-align: center;
}

.unit-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.time-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background-color: var(--bg-root);
  border-radius: 14rpx;
  padding: 0 24rpx;
}

.time-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.time-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 12rpx;
  text-align: center;
}

.btn-secondary {
  background-color: transparent;
  border: 2rpx solid var(--color-primary-hover);
}

.btn-secondary text {
  font-size: 28rpx;
  color: var(--color-primary);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary-hover), var(--color-primary));
  border-radius: 16rpx;
}

.btn-primary text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
