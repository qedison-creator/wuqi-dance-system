<view class="login-page">
  <!-- Logo区域 -->
  <view class="logo-section">
    <image class="logo-img" src="/images/logo.png" mode="aspectFit" />
    <text class="logo-subtitle">会员预约系统管理后台</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="form-item">
      <image class="form-icon" src="/images/icons/login-user.svg" mode="aspectFit" />
      <input class="form-input" type="text" placeholder="请输入管理员账号"
             value="{{username}}" bindinput="onUsernameInput" />
    </view>

    <view class="form-item">
      <image class="form-icon" src="/images/icons/login-lock.svg" mode="aspectFit" />
      <input class="form-input" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入密码"
             value="{{password}}" bindinput="onPasswordInput" />
      <view class="password-eye-btn" catchtap="onTogglePassword">
        <image class="password-eye-icon" src="{{showPassword ? '/images/icons/eye-close.svg' : '/images/icons/eye-open.svg'}}" mode="aspectFit" />
      </view>
    </view>

    <!-- 隐私协议勾选 -->
    <view class="privacy-row">
      <view class="privacy-checkbox-wrap" bindtap="onToggleAgree">
        <view class="privacy-checkbox {{agreed ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{agreed}}">✓</text>
        </view>
      </view>
      <view class="privacy-text">
        <text>我已阅读并同意</text>
        <text class="privacy-link" catchtap="onOpenPrivacy">《隐私保护指引》</text>
        <text>和</text>
        <text class="privacy-link" catchtap="onOpenAgreement">《用户服务协议》</text>
      </view>
    </view>

    <!-- 记住密码 -->
    <view class="remember-row" bindtap="onToggleRemember">
      <view class="remember-checkbox-wrap">
        <view class="privacy-checkbox {{rememberMe ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{rememberMe}}">✓</text>
        </view>
      </view>
      <text class="remember-text">记住密码</text>
    </view>

    <button class="login-btn {{loading || !agreed ? 'disabled' : ''}}"
            bindtap="onLogin" loading="{{loading}}" disabled="{{loading || !agreed}}">
      {{loading ? '登录中...' : '登录'}}
    </button>
  </view>


</view>