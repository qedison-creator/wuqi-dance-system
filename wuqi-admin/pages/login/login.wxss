.login-page {
  min-height: 100vh;
  background-color: var(--bg-root);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
  margin-bottom: 100rpx;
}

.logo-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 48rpx;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 48rpx;
  color: var(--color-primary);
}

.login-form {
  width: 100%;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 96rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.form-item:focus-within {
  border-color: var(--color-primary);
}

.form-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: var(--bg-card);
  font-size: 34rpx;
  font-weight: bold;
  border-radius: var(--radius-lg);
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background var(--transition-normal);
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background-color: var(--text-tertiary);
  color: var(--text-secondary);
}

.login-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}