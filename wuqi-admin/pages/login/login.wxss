.login-page {
  min-height: 100vh;
  background-color: var(--bg-root);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
  margin-bottom: 100rpx;
}

.logo-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 48rpx;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 48rpx;
  color: var(--color-primary);
}

.login-form {
  width: 100%;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 96rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
}

.form-item:focus-within {
  border-color: var(--color-primary);
}

.form-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.password-eye-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.password-eye-btn:active {
  opacity: 0.6;
}

.password-eye-icon {
  width: 36rpx;
  height: 36rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: var(--bg-card);
  font-size: 34rpx;
  font-weight: bold;
  border-radius: var(--radius-lg);
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background var(--transition-normal);
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background-color: var(--text-tertiary);
  color: var(--text-secondary);
}

.login-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.privacy-row {
  display: flex;
  align-items: flex-start;
  margin-top: 30rpx;
  margin-bottom: 10rpx;
}

.privacy-checkbox-wrap {
  flex-shrink: 0;
  margin-right: 10rpx;
  margin-top: 2rpx;
}

.privacy-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #B8AF9E;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 150ms ease;
}

.privacy-checkbox.checked {
  background: linear-gradient(135deg, #D4786E, #C05D53);
  border-color: #C05D53;
}

.privacy-text {
  font-size: 24rpx;
  color: #8E8582;
  line-height: 1.6;
}

.privacy-link {
  color: #D4786E;
  text-decoration: underline;
}

.remember-row {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
  margin-bottom: 14rpx;
}

.remember-checkbox-wrap {
  flex-shrink: 0;
  margin-right: 10rpx;
  margin-top: 2rpx;
}

.check-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.remember-text {
  font-size: 24rpx;
  color: #6B5D56;
  line-height: 1.6;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}