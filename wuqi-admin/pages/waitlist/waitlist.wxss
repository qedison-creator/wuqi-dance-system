.waitlist-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.summary-bar {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 44rpx;
  color: var(--color-primary);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--border);
}

.waitlist-list {
  display: flex;
  flex-direction: column;
}

.waitlist-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.waitlist-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.waitlist-course {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.waitlist-badge {
  background-color: var(--color-warning-bg);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-xl);
  font-size: 22rpx;
  color: var(--color-warning);
}

.waitlist-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.waitlist-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.waitlist-row:last-child {
  margin-bottom: 0;
}

.waitlist-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.waitlist-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.waitlist-footer {
  padding-top: 16rpx;
  text-align: right;
}

.waitlist-arrow {
  font-size: 24rpx;
  color: var(--color-primary);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 36, 22, 0.35);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content-large {
  width: 100%;
  max-height: 80vh;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-card);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.modal-body {
  padding: 24rpx 30rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.modal-info-row:last-child {
  border-bottom: none;
}

.modal-info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.modal-info-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.modal-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 0 16rpx;
}

.modal-section-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.modal-section-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-section-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.export-btn {
  padding: 8rpx 20rpx;
  background: var(--color-success-bg);
  border-radius: var(--radius-sm);
}

.export-btn text {
  font-size: 22rpx;
  color: var(--color-success);
  font-weight: 500;
}

.status-summary-bar {
  display: flex;
  gap: 12rpx;
  margin: 20rpx 0;
}

.summary-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: var(--radius-md);
}

.chip-waiting {
  background: var(--color-warning-bg);
}

.chip-notified {
  background: var(--color-info-bg);
}

.chip-confirmed {
  background: var(--color-success-bg);
}

.chip-num {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.chip-waiting .chip-num {
  color: var(--color-warning);
}

.chip-notified .chip-num {
  color: var(--color-info);
}

.chip-confirmed .chip-num {
  color: var(--color-success);
}

.chip-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.waitlist-detail-list {
  display: flex;
  flex-direction: column;
}

.waitlist-detail-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.waitlist-detail-item:last-child {
  border-bottom: none;
}

.waitlist-detail-rank {
  width: 48rpx;
  height: 48rpx;
  background-color: var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: bold;
  margin-right: 20rpx;
}

.rank-top {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
}

.waitlist-detail-info {
  flex: 1;
}

.waitlist-detail-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.waitlist-detail-phone {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.waitlist-detail-status {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-md);
  margin-right: 16rpx;
}

.status-waiting {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-notified {
  background-color: var(--color-info-bg);
  color: var(--color-info);
}

.status-confirmed {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.status-cancelled {
  background-color: var(--color-completed-bg);
  color: var(--text-secondary);
}

.waitlist-detail-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-right: 16rpx;
}

.waitlist-detail-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
}

.action-btn.promote {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.action-btn.remove {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.empty-state {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.empty-state-small {
  padding: 60rpx 0;
  text-align: center;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
}

.load-more {
  font-size: 26rpx;
  color: var(--text-tertiary);
}