.package-logs-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.tab-bar {
  display: flex;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all var(--transition-normal);
}

.tab-item.active {
  background: var(--color-primary);
  color: var(--text-inverse);
  font-weight: bold;
}

.tab-content {
  min-height: 400rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.logs-list {
  display: flex;
  flex-direction: column;
}

.log-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.log-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.log-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.log-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.log-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.log-row:last-child {
  margin-bottom: 0;
}

.log-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.log-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.log-value.highlight {
  color: var(--color-primary);
  font-weight: bold;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
}

.load-more {
  font-size: 26rpx;
  color: var(--text-tertiary);
}