.transfers-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 200ms ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  color: #FFFFFF;
  font-weight: 600;
}

.transfer-list {
  display: flex;
  flex-direction: column;
}

.transfer-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.transfer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.transfer-user {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.transfer-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-xl);
}

.status-pending {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-approved {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-rejected {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.transfer-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.transfer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.transfer-row:last-child {
  margin-bottom: 0;
}

.transfer-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.transfer-value {
  font-size: 26rpx;
  color: var(--text-primary);
  max-width: 60%;
  text-align: right;
}

.reject-text {
  color: var(--color-danger);
}

.transfer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  padding: 18rpx 0;
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.approve {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.action-btn.reject {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.empty-state {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.loading {
  padding: 60rpx 0;
  text-align: center;
}

.load-more {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.reject-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.reject-modal {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  width: 86%;
  max-width: 620rpx;
  padding: 40rpx 36rpx;
  box-shadow: var(--shadow-card);
}

.modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

.reject-input {
  width: 100%;
  height: 160rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 2rpx solid var(--color-primary);
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.btn-primary {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #C5744B, #A85D3A);
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}