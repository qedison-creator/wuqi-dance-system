.ops-page {
  min-height: 100vh;
  background: #F6F3F0;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.store-tabs {
  padding: 16rpx 0;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E8E2D8;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.04);
}

.store-scroll {
  white-space: nowrap;
}

.store-pills {
  display: flex;
  justify-content: center;
  padding: 0 32rpx;
  gap: 16rpx;
}

.store-pill {
  flex-shrink: 0;
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #8B7E6A;
  background: #F0ECE6;
  border: 1rpx solid #E8E2D8;
  transition: all 0.2s ease;
}

.store-pill.on {
  background: #FAEEE4;
  color: #C5744B;
  font-weight: 600;
  border-color: transparent;
}

.page-head {
  padding: 32rpx 32rpx 16rpx;
}

.page-title {
  font-size: 36rpx;
  color: #2C2416;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.block-head {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.block-head-left {
  display: flex;
  align-items: center;
}

.block-title {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
}

.block-date {
  font-size: 26rpx;
  color: #8B7E6A;
}

.today-block {
  margin-bottom: 32rpx;
}

.course-card {
  margin: 0 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #E8E2D8;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.04), 0 8rpx 24rpx rgba(44,36,22,0.06);
  transition: all 0.2s ease;
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.06);
}

.course-card.cancelled,
.course-card.offline {
  opacity: 0.45;
}

.card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-left {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-time {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 700;
}

.card-coach {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 700;
}

.card-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.schedule-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
}

.card-progress-text {
  font-size: 22rpx;
  color: #8B7E6A;
}

/* 日期课程卡片布局 */
.card-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-progress {
  margin-bottom: 16rpx;
}

.progress-track {
  height: 10rpx;
  background: #F0ECE6;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.fill-warning {
  background: #F5A623;
}

.fill-accent {
  background: #C5744B;
}

.progress-label {
  font-size: 22rpx;
  color: #8B7E6A;
}

.schedule-status.available {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.schedule-status.full {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.schedule-status.cancelled,
.schedule-status.offline {
  background-color: rgba(184, 175, 158, 0.2);
  color: var(--text-tertiary);
}

.schedule-status.not_open {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.schedule-status.completed {
  background-color: rgba(77, 184, 160, 0.1);
  color: #4DB8A0;
}

.card-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-booked {
  color: #5B8C5A;
}

.stat-checked {
  color: #5B8C5A;
}

.stat-cancelled {
  color: #C44B4B;
}

.stat-exempted {
  color: #8B7E6A;
}

.stat-label {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 4rpx;
}



.today-empty {
  margin-bottom: 32rpx;
}

.empty-hint {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #B8AF9E;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 0 24rpx;
  border: 1rpx solid #E8E2D8;
}

.calendar-block {
  margin-bottom: 32rpx;
}

.month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.month-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  font-size: 24rpx;
  color: #8B7E6A;
  border: 1rpx solid #E8E2D8;
}

.month-arrow:active {
  background: #FAEEE4;
  color: #C5744B;
  border-color: #C5744B;
}

.month-name {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 600;
}

.today-btn {
  padding: 12rpx 24rpx;
  background-color: #FAEEE4;
  border-radius: 40rpx;
  border: 1rpx solid #E8E2D8;
  margin-left: 16rpx;
}

.today-btn-text {
  font-size: 24rpx;
  color: #C5744B;
}

.legend-row {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  padding: 0 32rpx 16rpx;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 24rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.dot-normal {
  background: #5B8C5A;
}

.dot-cancelled {
  background: #C44B4B;
}

.dot-mixed {
  background: #4A90D9;
}

.dot-holiday {
  background: #B8AF9E;
}

.legend-text {
  font-size: 22rpx;
  color: #8B7E6A;
}

.weekday-row {
  display: flex;
  padding: 0 32rpx;
  margin-bottom: 12rpx;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #B8AF9E;
  font-weight: 500;
}

.cal-grid {
  padding: 0 32rpx;
}

.cal-week {
  display: flex;
}

.cal-cell {
  flex: 1;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #2C2416;
  position: relative;
  border-radius: 50%;
  margin: 3rpx;
  transition: all 0.15s ease;
}

.cal-cell.empty {
  visibility: hidden;
}

.cal-cell.past {
  color: #B8AF9E;
  opacity: 0.5;
}

.cal-cell.is-today {
  color: #C5744B;
  font-weight: 700;
  background: transparent;
  box-shadow: inset 0 0 0 3rpx #C5744B;
}

.cal-cell.is-selected {
  background: #C5744B;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: none;
}

.cal-cell.is-selected.has-normal,
.cal-cell.is-selected.has-cancelled,
.cal-cell.is-selected.has-mixed,
.cal-cell.is-selected.has-holiday {
  background: #C5744B;
  box-shadow: none;
}

.cal-cell.has-normal {
  position: relative;
}

.cal-cell.has-normal::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #5B8C5A;
}

.cal-cell.has-cancelled {
  position: relative;
}

.cal-cell.has-cancelled::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #C44B4B;
}

.cal-cell.has-mixed {
  position: relative;
}

.cal-cell.has-mixed::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #4A90D9;
}

.cal-cell.has-holiday {
  position: relative;
}

.cal-cell.has-holiday::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #B8AF9E;
}

.cal-cell.is-selected.has-normal::after,
.cal-cell.is-selected.has-cancelled::after,
.cal-cell.is-selected.has-mixed::after,
.cal-cell.is-selected.has-holiday::after {
  background: rgba(255,255,255,0.6);
}

.cal-cell.is-today.has-normal,
.cal-cell.is-today.has-cancelled,
.cal-cell.is-today.has-mixed,
.cal-cell.is-today.has-holiday {
  box-shadow: inset 0 0 0 3rpx #C5744B;
}

.date-block {
  margin-bottom: 32rpx;
}

.date-block-title {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 600;
}

.date-empty {
  padding: 60rpx 32rpx;
  text-align: center;
}

.empty-date-text {
  font-size: 28rpx;
  color: #B8AF9E;
}

.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.sheet-mask.show {
  background: rgba(0, 0, 0, 0.55);
  visibility: visible;
}

.sheet-panel {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 32rpx calc(120rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -4rpx 24rpx rgba(44,36,22,0.08);
  display: flex;
  flex-direction: column;
}

.sheet-mask.show .sheet-panel {
  transform: translateY(0);
}

.sheet-handle {
  width: 56rpx;
  height: 6rpx;
  background: #E8E2D8;
  border-radius: 3rpx;
  margin: 0 auto 28rpx;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #B8AF9E;
  background: #F0ECE6;
  border-radius: 50%;
}

.sheet-close:active {
  background: #FAEEE4;
  color: #C5744B;
}

.sheet-course {
  margin-bottom: 24rpx;
}

.sheet-course-name {
  display: block;
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.sheet-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.sheet-meta-text {
  font-size: 26rpx;
  color: #8B7E6A;
}

.sheet-stats {
  display: flex;
  gap: 48rpx;
}

.sheet-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sheet-stat-num {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
}

.sheet-stat-label {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 4rpx;
}

.sheet-tabs {
  display: flex;
  border-bottom: 1rpx solid #E8E2D8;
  margin-bottom: 16rpx;
}

.sheet-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #8B7E6A;
  position: relative;
  transition: color 0.2s ease;
}

.sheet-tab.on {
  color: #C5744B;
  font-weight: 600;
}

.sheet-tab.on::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 20%;
  right: 20%;
  height: 3rpx;
  background: #C5744B;
  border-radius: 2rpx;
}

.sheet-list {
  flex: 1;
  min-height: 300rpx;
  overflow-y: auto;
}

.booking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E8E2D8;
}

.booking-row.is-cancelled {
  opacity: 0.45;
}

.booking-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.booking-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F0ECE6;
  border: 1rpx solid #E8E2D8;
}

.booking-user-info {
  display: flex;
  flex-direction: column;
}

.booking-user-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.booking-user-name {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 500;
}

.booking-user-nick {
  font-size: 24rpx;
  color: #8B7E6A;
}

.booking-user-phone {
  font-size: 24rpx;
  color: #8B7E6A;
  margin-top: 4rpx;
}

.booking-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.booking-credits {
  font-size: 26rpx;
  color: #C5744B;
  font-weight: 500;
}

.booking-btn {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.15s ease;
}

.btn-checkin {
  background: #EDF5EE;
  color: #5B8C5A;
}

.btn-checkin:active {
  background: #EDF5EE;
}

.btn-cancel {
  background: #FDF0F0;
  color: #C44B4B;
}

.btn-cancel:active {
  background: #FDF0F0;
}

.cancel-info {
  text-align: right;
}

.cancel-time {
  font-size: 24rpx;
  color: #8B7E6A;
  display: block;
}

.cancel-reason {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 4rpx;
  display: block;
}

.checked-in-tag {
  font-size: 24rpx;
  color: #5B8C5A;
  background: #EDF5EE;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.sheet-empty {
  padding: 80rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #B8AF9E;
}
