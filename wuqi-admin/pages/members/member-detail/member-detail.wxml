<view class="member-detail-page">
  <!-- 会员头部卡片 -->
  <view class="member-header card">
    <image class="member-avatar" src="{{member.avatar_url || '/images/default-avatar.svg'}}" mode="aspectFill"/>
    <view class="member-info">
      <view class="member-name-row">
        <text class="member-name">{{member.real_name || member.nick_name || '未知用户'}}</text>
        <text class="member-nick-name" wx:if="{{member.nick_name}}">{{member.nick_name}}</text>
        <view class="edit-name-btn" bindtap="onEditName">
          <text>编辑</text>
        </view>
      </view>
      <view class="member-phone-row">
        <text class="member-phone-label">预留：</text>
        <text class="member-phone">{{member.reserve_phone || member.phone || '未设置'}}</text>
      </view>
      <view class="member-phone-row" wx:if="{{member.wechat_phone}}">
        <text class="member-phone-label secondary">微信：</text>
        <text class="member-phone secondary">{{member.wechat_phone}}</text>
      </view>
      <view class="member-tags">
        <text class="gender-tag">{{member.gender_display}}</text>
        <text class="status-badge {{memberStatusClass}}">{{memberStatusText}}</text>
        <text class="store-tag-sm" wx:for="{{member.linkedStores}}" wx:key="_id">{{item.name}}</text>
      </view>
      <view class="member-actions">
        <view class="toggle-status-btn {{member.status === 'disabled' ? 'enable' : 'disable'}}" bindtap="onToggleMemberStatus">
          <text>{{member.status === 'disabled' ? '解除限制' : '限制账号'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title">基本信息</view>
    <view class="info-list card">
      <view class="info-row">
        <text class="info-label">注册时间</text>
        <text class="info-value">{{member.created_at_display}}</text>
      </view>
      <view class="info-row" wx:if="{{member.package_created_at_display}}">
        <text class="info-label">录入套餐时间</text>
        <text class="info-value">{{member.package_created_at_display}}</text>
      </view>
      <view class="info-row info-row-tap" bindtap="onChangeStore">
        <text class="info-label">所属门店</text>
        <view class="info-value-row">
          <text class="info-value">{{member.store_name || '未指定'}}</text>
          <text class="info-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 套餐信息 -->
  <view class="section">
    <view class="section-title-row">
      <text class="section-title">套餐信息</text>
      <view class="add-package-btn" bindtap="onAddPackage">
        <text>+ 新增套餐</text>
      </view>
    </view>
    <view class="package-list" wx:if="{{packages.length > 0}}">
      <view class="package-item card" wx:for="{{packages}}" wx:key="_id">
        <view class="package-header">
          <view class="package-badges">
            <text class="package-type-badge">{{item.package_type === 'time_card' ? '时间卡' : '次卡'}}</text>
            <text class="package-store-badge" wx:if="{{item.store_id && item.store_id.name}}">{{item.store_id.name}}</text>
            <text class="package-status-badge {{item.is_suspended ? 'suspended' : (item.is_activated ? (item._displayStatus || item.status) : 'pending')}}">{{item.is_suspended ? '已停用' : (item.is_activated ? ((item._displayStatus || item.status) === 'active' ? '使用中' : ((item._displayStatus || item.status) === 'expired' ? '已过期' : '已用完')) : '待激活')}}</text>
          </view>
          <view class="package-actions">
            <view class="package-edit-btn" data-id="{{item._id}}" bindtap="onEditPackage">
              <text>修改</text>
            </view>
            <view class="package-delete-btn" data-id="{{item._id}}" bindtap="onDeletePackage">
              <text>删除</text>
            </view>
          </view>
        </view>
        <view class="package-info">
          <!-- 时间卡 -->
          <block wx:if="{{item.package_type === 'time_card'}}">
            <!-- 限制规则 -->
            <text class="package-credits">{{item.daily_limit ? '每日' + item.daily_limit + '次' : (item.weekly_limit ? '每周' + item.weekly_limit + '次' : '不限次数')}}</text>
            <!-- 未激活：服务有效期 -->
            <text class="package-expire" wx:if="{{!item.is_activated}}">服务有效期：{{item.duration_value}}{{item.duration_unit === 'month' ? '个月' : '天'}}</text>
            <!-- 已激活：服务有效期 + 剩余天数 -->
            <block wx:if="{{item.is_activated && item.start_date}}">
              <text class="package-expire">{{item.start_date_display}} ~ {{item.end_date_display}}</text>
              <text class="package-expire package-remaining" wx:if="{{item.remaining_days >= 0}}">剩余 {{item.remaining_days}} 天</text>
              <text class="package-expire package-expired-soon" wx:if="{{item.remaining_days < 0}}">已超 {{0 - item.remaining_days}} 天</text>
            </block>
          </block>

          <!-- 次卡 -->
          <block wx:if="{{item.package_type === 'count_card'}}">
            <!-- 未激活：次数 + 服务有效期 -->
            <block wx:if="{{!item.is_activated}}">
              <text class="package-credits">套餐次数：{{item.total_credits || 0}} 次</text>
              <text class="package-expire">服务有效期：{{item.duration_value}}{{item.duration_unit === 'month' ? '个月' : '天'}}</text>
            </block>
            <!-- 已激活：剩余次数/总次数 + 剩余有效期/服务有效期 -->
            <block wx:if="{{item.is_activated}}">
              <text class="package-credits">剩余 {{item.remaining_credits || 0}} / {{item.total_credits || 0}} 次</text>
              <block wx:if="{{item.start_date}}">
                <text class="package-expire">{{item.start_date_display}} ~ {{item.end_date_display}}</text>
                <text class="package-expire package-remaining" wx:if="{{item.remaining_days >= 0}}">剩余 {{item.remaining_days}} 天</text>
                <text class="package-expire package-expired-soon" wx:if="{{item.remaining_days < 0}}">已超 {{0 - item.remaining_days}} 天</text>
              </block>
            </block>
          </block>

          <!-- 未激活：待激活倒计时 -->
          <text class="package-expire package-pending" wx:if="{{!item.is_activated && item.auto_activate_at_display}}">待激活 · {{item.auto_activate_at_display}} 自动激活</text>
        </view>
      </view>
    </view>
    <view class="empty-state card" wx:else>
      <text>暂无套餐信息</text>
    </view>
  </view>

  <!-- 预约记录 -->
  <view class="section">
    <view class="section-title">预约记录</view>
    <view class="booking-list" wx:if="{{bookings.length > 0}}">
      <view class="booking-item card" wx:for="{{displayBookings}}" wx:key="_id">
        <view class="booking-info">
          <view class="booking-header">
            <text class="booking-course">{{item.schedule_id ? item.schedule_id.course_name : '未知课程'}}</text>
          </view>
          <view class="booking-details">
            <view class="booking-detail-row">
              <text class="detail-icon">📅</text>
              <text class="detail-label">课程时间</text>
              <view class="detail-value course-time-wrap">
                <text class="course-date">{{item.schedule_id ? item.schedule_id.date : item.booking_date}}</text>
                <text class="course-weekday">{{item._weekday}}</text>
                <text class="course-time">{{item.schedule_id ? item.schedule_id.start_time : item.booking_time}}-{{item.schedule_id ? item.schedule_id.end_time : ''}}</text>
              </view>
            </view>
            <view class="booking-detail-row" wx:if="{{item.schedule_id && item.schedule_id.coach_id && item.schedule_id.coach_id.name}}">
              <text class="detail-icon">👤</text>
              <text class="detail-label">授课教练</text>
              <text class="detail-value coach">{{item.schedule_id.coach_id.name}}</text>
            </view>
            <view class="booking-detail-row" wx:if="{{item.created_at_display}}">
              <text class="detail-icon">🕐</text>
              <text class="detail-label">预约时间</text>
              <text class="detail-value booking-time-text">{{item.created_at_display}}</text>
            </view>
          </view>
        </view>
        <view class="booking-status {{item.status}}">
          <text>{{item.status === 'booked' ? '已预约' : (item.status === 'completed' ? '已完成' : '已取消')}}</text>
        </view>
      </view>
      
      <!-- 查看全部按钮 -->
      <view class="view-all-btn card" wx:if="{{bookings.length > 5}}" bindtap="onViewAllBookings">
        <text>查看全部预约记录 ({{bookings.length}}条)</text>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="empty-state card" wx:else>
      <text>暂无预约记录</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions" wx:if="{{hasActivePackage || hasSuspendedPackage}}">
    <view class="suspend-btn" bindtap="onSuspendCard" wx:if="{{hasActivePackage}}">
      <text>停卡</text>
    </view>
    <view class="unsuspend-btn" bindtap="onUnsuspendCard" wx:if="{{hasSuspendedPackage}}">
      <text>恢复停卡</text>
    </view>
  </view>

  <!-- 危险操作区域（页面底部，与内容有间距） -->
  <view class="danger-zone" wx:if="{{isAdmin}}">
    <view class="danger-zone-title">危险操作</view>
    <view class="danger-zone-desc">删除后该会员的所有数据将无法恢复</view>
    <view class="delete-member-btn" bindtap="onDeleteMember">
      <text>删除此会员</text>
    </view>
  </view>

  <!-- 删除会员确认弹窗 -->
  <view class="modal-mask" wx:if="{{showDeleteModal}}" bindtap="onCloseDeleteModal">
    <view class="delete-modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title delete-modal-title">确认删除会员</text>
        <text class="modal-close" bindtap="onCloseDeleteModal">✕</text>
      </view>

      <view class="delete-warning-box">
        <text class="delete-warning-icon">⚠</text>
        <text class="delete-warning-text">此操作不可恢复，删除后该会员的以下数据将被永久清除：</text>
      </view>

      <view class="delete-data-list">
        <view class="delete-data-item">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">会员基本信息（姓名、手机号等）</text>
        </view>
        <view class="delete-data-item">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">所有套餐记录（{{packages.length}}个）</text>
        </view>
        <view class="delete-data-item">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">所有预约记录（{{bookings.length}}条）</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">请输入会员姓名确认删除</text>
        <input class="input-field delete-confirm-input" placeholder="{{member.real_name || member.nick_name || '未知用户'}}" value="{{deleteConfirmName}}" bindinput="onDeleteConfirmInput" />
      </view>

      <view class="modal-actions">
        <view class="btn-secondary" bindtap="onCloseDeleteModal"><text>取消</text></view>
        <view class="btn-primary btn-danger {{deleteConfirmName !== (member.real_name || member.nick_name) ? 'disabled' : ''}}" bindtap="onConfirmDeleteMember"><text>确认删除</text></view>
      </view>
    </view>
  </view>

  <!-- 删除套餐确认弹窗 -->
  <view class="modal-mask" wx:if="{{showDeletePackageModal}}" bindtap="onCloseDeletePackageModal">
    <view class="delete-modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title delete-modal-title">确认删除套餐</text>
        <text class="modal-close" bindtap="onCloseDeletePackageModal">✕</text>
      </view>

      <view class="delete-warning-box">
        <text class="delete-warning-icon">⚠</text>
        <text class="delete-warning-text">删除后该套餐数据将无法恢复：</text>
      </view>

      <view class="delete-data-list" wx:if="{{deletingPackage}}">
        <view class="delete-data-item">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">套餐类型：{{deletingPackage.package_type === 'time_card' ? '时间卡' : '次卡'}}</text>
        </view>
        <view class="delete-data-item" wx:if="{{deletingPackage.package_type === 'count_card'}}">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">剩余次数：{{deletingPackage.remaining_credits || 0}} / {{deletingPackage.total_credits || 0}} 次</text>
        </view>
        <view class="delete-data-item" wx:if="{{deletingPackage.is_activated && deletingPackage.end_date}}">
          <text class="delete-data-dot">•</text>
          <text class="delete-data-text">有效期至：{{deletingPackage.end_date_display}}</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">请输入"确认删除"以继续</text>
        <input class="input-field delete-confirm-input" placeholder="确认删除" value="{{deletePackageConfirmText}}" bindinput="onDeletePackageConfirmInput" />
      </view>

      <view class="modal-actions">
        <view class="btn-secondary" bindtap="onCloseDeletePackageModal"><text>取消</text></view>
        <view class="btn-primary btn-danger {{deletePackageConfirmText !== '确认删除' ? 'disabled' : ''}}" bindtap="onConfirmDeletePackage"><text>确认删除</text></view>
      </view>
    </view>
  </view>

  <!-- 门店修改弹窗 -->
  <view class="modal-mask" wx:if="{{showStoreModal}}" bindtap="onCloseStoreModal">
    <view class="store-modal-content" catchtap="onModalTap">
      <view class="store-modal-header">
        <text class="store-modal-title">修改门店</text>
        <text class="modal-close" bindtap="onCloseStoreModal">✕</text>
      </view>
      <view class="store-modal-list">
        <view class="store-modal-item {{selectedStoreId === item._id ? 'active' : ''}}"
              wx:for="{{storeList}}" wx:key="_id"
              data-id="{{item._id}}" data-name="{{item.name}}"
              bindtap="onStoreSelect">
          <text>{{item.name}}</text>
        </view>
      </view>
      <button class="btn-primary store-modal-confirm" bindtap="onConfirmStoreChange" disabled="{{!selectedStoreId}}">确认修改</button>
    </view>
  </view>

  <!-- 新增套餐弹窗 -->
  <view class="modal-mask" wx:if="{{showAddPackageModal}}" bindtap="onCloseAddPackageModal">
    <view class="package-modal-content" catchtap="onAddPackageModalTap">
      <view class="modal-header">
        <text class="modal-title">新增套餐</text>
        <text class="modal-close" bindtap="onCloseAddPackageModal">✕</text>
      </view>

      <view class="form-group">
        <text class="form-label">所属门店 *</text>
        <picker mode="selector" range="{{addPackageStoreList}}" range-key="name" value="{{addPackageFormStoreIndex}}" bindchange="onAddPackageStoreChange">
          <view class="picker-field">
            <text class="picker-text">{{addPackageForm.store_name || '请选择门店'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="form-label">套餐类型 *</text>
        <view class="package-type-selector">
          <view class="type-option {{addPackageForm.package_type === 'count_card' ? 'active' : ''}}" data-type="count_card" bindtap="onAddPackageTypeChange">
            <text>次卡</text>
          </view>
          <view class="type-option {{addPackageForm.package_type === 'time_card' ? 'active' : ''}}" data-type="time_card" bindtap="onAddPackageTypeChange">
            <text>时间卡</text>
          </view>
        </view>
      </view>

      <view class="form-group" wx:if="{{addPackageForm.package_type === 'count_card'}}">
        <text class="form-label">次数 *</text>
        <input class="input-field" type="number" placeholder="请输入次数" value="{{addPackageForm.total_credits}}" data-field="total_credits" bindinput="onAddPackageInput" />
      </view>

      <view class="form-group" wx:if="{{addPackageForm.package_type === 'count_card'}}">
        <text class="form-label">服务有效期 *</text>
        <view class="duration-input-row">
          <input class="input-field duration-input" type="number" placeholder="请输入时长" value="{{addPackageForm.duration_value}}" data-field="duration_value" bindinput="onAddPackageInput" />
          <view class="duration-unit-selector">
            <view class="unit-option {{addPackageForm.duration_unit === 'month' ? 'active' : ''}}" data-unit="month" bindtap="onAddPackageDurationUnitChange">
              <text>月</text>
            </view>
            <view class="unit-option {{addPackageForm.duration_unit === 'day' ? 'active' : ''}}" data-unit="day" bindtap="onAddPackageDurationUnitChange">
              <text>天</text>
            </view>
          </view>
        </view>
      </view>

      <view class="form-group" wx:if="{{addPackageForm.package_type === 'time_card'}}">
        <text class="form-label">有效时长 *</text>
        <view class="duration-input-row">
          <input class="input-field duration-input" type="number" placeholder="请输入时长" value="{{addPackageForm.duration_value}}" data-field="duration_value" bindinput="onAddPackageInput" />
          <view class="duration-unit-selector">
            <view class="unit-option {{addPackageForm.duration_unit === 'month' ? 'active' : ''}}" data-unit="month" bindtap="onAddPackageDurationUnitChange">
              <text>月</text>
            </view>
            <view class="unit-option {{addPackageForm.duration_unit === 'day' ? 'active' : ''}}" data-unit="day" bindtap="onAddPackageDurationUnitChange">
              <text>天</text>
            </view>
          </view>
        </view>
      </view>

      <view class="form-group" wx:if="{{addPackageForm.package_type === 'time_card'}}">
        <text class="form-label">限制方式 *</text>
        <view class="package-type-selector">
          <view class="type-option {{addPackageForm.limit_type === 'daily' ? 'active' : ''}}" data-type="daily" bindtap="onAddPackageLimitTypeChange">
            <text>每日限制</text>
          </view>
          <view class="type-option {{addPackageForm.limit_type === 'weekly' ? 'active' : ''}}" data-type="weekly" bindtap="onAddPackageLimitTypeChange">
            <text>每周限制</text>
          </view>
          <view class="type-option {{addPackageForm.limit_type === 'unlimited' ? 'active' : ''}}" data-type="unlimited" bindtap="onAddPackageLimitTypeChange">
            <text>无限次</text>
          </view>
        </view>
      </view>

      <view class="form-group" wx:if="{{addPackageForm.package_type === 'time_card' && addPackageForm.limit_type !== 'unlimited'}}">
        <text class="form-label">{{addPackageForm.limit_type === 'daily' ? '每日限制' : '每周限制'}} *</text>
        <input class="input-field" type="number" placeholder="{{addPackageForm.limit_type === 'daily' ? '每日限制次数' : '每周限制次数'}}" value="{{addPackageForm.limit_value}}" data-field="limit_value" bindinput="onAddPackageInput" />
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="input-field" placeholder="选填" value="{{addPackageForm.remark}}" data-field="remark" bindinput="onAddPackageInput" />
      </view>

      <button class="btn-primary submit-btn" bindtap="onSubmitAddPackage">确认录入</button>
    </view>
  </view>

  <!-- 套餐编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showPackageEditModal}}" bindtap="onClosePackageEditModal">
    <view class="package-modal-content" catchtap="onPackageEditModalTap">
      <view class="modal-header">
        <text class="modal-title">编辑套餐</text>
        <text class="modal-close" bindtap="onClosePackageEditModal">✕</text>
      </view>

      <!-- 套餐类型选择（仅未激活可修改）-->
      <view class="form-group" wx:if="{{!editingPackage.is_activated}}">
        <text class="form-label">套餐类型 *</text>
        <view class="package-type-selector">
          <view class="type-option {{editPackageForm.package_type === 'count_card' ? 'active' : ''}}" data-type="count_card" bindtap="onEditPackageTypeChange">
            <text>次卡</text>
          </view>
          <view class="type-option {{editPackageForm.package_type === 'time_card' ? 'active' : ''}}" data-type="time_card" bindtap="onEditPackageTypeChange">
            <text>时间卡</text>
          </view>
        </view>
      </view>

      <!-- 次卡：课时数量（仅未激活可修改）-->
      <view class="form-group" wx:if="{{!editingPackage.is_activated && editPackageForm.package_type === 'count_card'}}">
        <text class="form-label">次数 *</text>
        <input class="input-field" type="number" placeholder="请输入次数" value="{{editPackageForm.total_credits}}" data-field="total_credits" bindinput="onEditPackageInput" />
      </view>

      <!-- 次卡：剩余课时（可修改） -->
      <view class="form-group" wx:if="{{editPackageForm.package_type === 'count_card'}}">
        <text class="form-label">剩余次数 *</text>
        <input class="input-field" type="number" placeholder="请输入剩余次数" value="{{editPackageForm.remaining_credits}}" data-field="remaining_credits" bindinput="onEditPackageInput" />
      </view>

      <!-- 有效时长（仅未激活可修改）-->
      <view class="form-group" wx:if="{{!editingPackage.is_activated}}">
        <text class="form-label">有效时长 *</text>
        <view class="duration-input-row">
          <input class="input-field duration-input" type="number" placeholder="请输入时长" value="{{editPackageForm.duration_value}}" data-field="duration_value" bindinput="onEditPackageInput" />
          <view class="duration-unit-selector">
            <view class="unit-option {{editPackageForm.duration_unit === 'month' ? 'active' : ''}}" data-unit="month" bindtap="onEditDurationUnitChange">
              <text>月</text>
            </view>
            <view class="unit-option {{editPackageForm.duration_unit === 'day' ? 'active' : ''}}" data-unit="day" bindtap="onEditDurationUnitChange">
              <text>天</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 时间卡：限制方式 -->
      <view class="form-group" wx:if="{{editPackageForm.package_type === 'time_card'}}">
        <text class="form-label">限制方式 *</text>
        <view class="package-type-selector">
          <view class="type-option {{editPackageForm.limit_type === 'daily' ? 'active' : ''}}" data-type="daily" bindtap="onEditLimitTypeChange">
            <text>每日限制</text>
          </view>
          <view class="type-option {{editPackageForm.limit_type === 'weekly' ? 'active' : ''}}" data-type="weekly" bindtap="onEditLimitTypeChange">
            <text>每周限制</text>
          </view>
          <view class="type-option {{editPackageForm.limit_type === 'unlimited' ? 'active' : ''}}" data-type="unlimited" bindtap="onEditLimitTypeChange">
            <text>无限次</text>
          </view>
        </view>
      </view>

      <!-- 时间卡：限制次数 -->
      <view class="form-group" wx:if="{{editPackageForm.package_type === 'time_card' && editPackageForm.limit_type !== 'unlimited'}}">
        <text class="form-label">{{editPackageForm.limit_type === 'daily' ? '每日限制' : '每周限制'}} *</text>
        <input class="input-field" type="number" placeholder="{{editPackageForm.limit_type === 'daily' ? '每日限制次数' : '每周限制次数'}}" value="{{editPackageForm.limit_value}}" data-field="limit_value" bindinput="onEditPackageInput" />
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="input-field" placeholder="选填" value="{{editPackageForm.remark}}" data-field="remark" bindinput="onEditPackageInput" />
      </view>

      <button class="btn-primary submit-btn" bindtap="onSubmitPackageEdit">确认修改</button>
    </view>
  </view>

  <!-- 编辑姓名弹窗 -->
  <view class="modal-mask" wx:if="{{showEditNameModal}}" bindtap="onCloseEditNameModal">
    <view class="name-modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title">编辑会员姓名</text>
        <text class="modal-close" bindtap="onCloseEditNameModal">✕</text>
      </view>
      <view class="form-group">
        <text class="form-label">姓名</text>
        <input class="input-field" placeholder="请输入会员姓名" value="{{editNameForm.real_name}}" bindinput="onEditNameInput" />
      </view>
      <button class="btn-primary submit-btn" bindtap="onSubmitEditName" disabled="{{!editNameForm.real_name || editNameForm.real_name === member.real_name}}">确认修改</button>
    </view>
  </view>

  <!-- 停卡弹窗 -->
  <view class="modal-mask" wx:if="{{showSuspendModal}}" bindtap="onCloseSuspendModal">
    <view class="suspend-modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title">停卡申请</text>
        <text class="modal-close" bindtap="onCloseSuspendModal">✕</text>
      </view>
      
      <view class="suspend-rules">
        <text class="suspend-rules-title">停卡规则</text>
        <view class="suspend-rule-item">
          <text class="rule-dot">•</text>
          <text class="rule-text">停卡期间，套餐有效期将暂停计算</text>
        </view>
        <view class="suspend-rule-item">
          <text class="rule-dot">•</text>
          <text class="rule-text">停卡期间，会员无法预约新课程</text>
        </view>
        <view class="suspend-rule-item">
          <text class="rule-dot">•</text>
          <text class="rule-text">已预约的课程不受影响，可正常上课</text>
        </view>
        <view class="suspend-rule-item">
          <text class="rule-dot">•</text>
          <text class="rule-text">可随时取消停卡，恢复正常使用</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">停卡天数 *</text>
        <view class="suspend-days-options">
          <view class="day-option {{suspendDays === 7 ? 'active' : ''}}" data-days="7" bindtap="onSuspendDaysSelect">
            <text>7天</text>
          </view>
          <view class="day-option {{suspendDays === 14 ? 'active' : ''}}" data-days="14" bindtap="onSuspendDaysSelect">
            <text>14天</text>
          </view>
          <view class="day-option {{suspendDays === 30 ? 'active' : ''}}" data-days="30" bindtap="onSuspendDaysSelect">
            <text>30天</text>
          </view>
        </view>
        <input class="input-field" type="number" placeholder="自定义天数" value="{{customSuspendDays}}" bindinput="onCustomSuspendDaysInput" />
      </view>

      <view class="form-group">
        <text class="form-label">停卡原因</text>
        <input class="input-field" placeholder="选填，如：出差、生病等" value="{{suspendReason}}" bindinput="onSuspendReasonInput" />
      </view>

      <view class="modal-actions">
        <view class="btn-secondary" bindtap="onCloseSuspendModal"><text>取消</text></view>
        <view class="btn-primary" bindtap="onConfirmSuspendCard"><text>确认停卡</text></view>
      </view>
    </view>
  </view>
</view>