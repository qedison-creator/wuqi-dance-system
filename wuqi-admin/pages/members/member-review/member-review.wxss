.review-page {
  padding: 32rpx;
  padding-bottom: 60rpx;
  background-color: var(--bg-root);
  min-height: 100vh;
}

.review-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.review-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.review-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.review-card {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-top {
  display: flex;
  margin-bottom: 20rpx;
}

.card-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: var(--border);
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-right: 12rpx;
}

.card-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag-orange {
  background-color: var(--color-primary-bg);
}

.tag-orange .tag-text {
  color: var(--color-primary);
  font-size: 22rpx;
}

.card-phone {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.card-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.card-store {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 500;
}

.btn-approve {
  background-color: rgba(52, 199, 89, 0.12);
}

.btn-approve .btn-text {
  color: #1D1D1F;
  font-weight: 600;
}

.btn-reject {
  background-color: rgba(0, 122, 255, 0.12);
}

.btn-reject .btn-text {
  color: #1D1D1F;
  font-weight: 600;
}

.btn-delete {
  background-color: rgba(255, 59, 48, 0.12);
}

.btn-delete .btn-text {
  color: #1D1D1F;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.store-modal-content {
  width: 80%;
  background-color: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx;
}

.store-modal-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  position: relative;
  padding-right: 40rpx;
}

.modal-close {
  position: absolute;
  right: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.store-modal-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.store-modal-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.store-modal-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.store-modal-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.store-modal-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.store-modal-item:last-child {
  border-bottom: none;
}

.store-modal-confirm {
  margin-top: 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: var(--text-inverse);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
}

.store-modal-confirm.disabled {
  background-color: var(--border);
  color: var(--text-tertiary);
}
