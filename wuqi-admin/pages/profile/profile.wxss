.profile-page {
  padding: 32rpx 28rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  background: var(--bg-input);
}

/* ===== 个人信息卡片 ===== */
.profile-card {
  background: linear-gradient(145deg, #FFFFFF 0%, #FEF9F8 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.04), 0 8rpx 24rpx rgba(44, 36, 22, 0.04);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  flex-shrink: 0;
}

.avatar-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, rgba(197,116,75,0.12), rgba(197,116,75,0.04));
  box-shadow: 0 4rpx 16rpx rgba(197, 116, 75, 0.10);
}

.avatar-inner {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2rpx solid rgba(197, 116, 75, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-ring-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(197, 116, 75, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(197, 116, 75, 0.10);
}

.avatar-char {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.profile-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profile-role-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(197, 116, 75, 0.08);
}

.profile-role-text {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.profile-store {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 菜单分组 ===== */
.menu-section {
  margin-bottom: 28rpx;
}

.menu-section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  letter-spacing: 0.5rpx;
}

.menu-card {
  background: linear-gradient(145deg, #FFFFFF 0%, #FEF9F8 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid rgba(44, 36, 22, 0.04);
  transition: background 150ms ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-card-hover);
}

/* ===== 图标容器 - 分色 ===== */
.menu-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon-wrap.warm {
  background: rgba(197, 116, 75, 0.10);
  color: #C5744B;
}

.menu-icon-wrap.teal {
  background: rgba(93, 155, 155, 0.10);
  color: #5D9B9B;
}

.menu-icon-wrap.muted {
  background: rgba(148, 130, 132, 0.10);
  color: #948284;
}

.menu-icon {
  width: 26rpx;
  height: 26rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  opacity: 0.3;
}

/* ===== 退出登录 ===== */
.logout-section {
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  background: var(--bg-card);
  border-radius: 24rpx;
  border: none;
  letter-spacing: 1rpx;
  transition: all 150ms ease;
}

.logout-btn:active {
  background: var(--bg-card-hover);
  transform: scale(0.98);
}

/* ===== 版本信息 ===== */
.version-info {
  text-align: center;
  padding: 16rpx 0;
}

.version-info text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.5rpx;
}
