.page {
  min-height: 100vh;
  background: #F6F3F0;
  padding-bottom: 240rpx;
}

.store-filter {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #F6F3F0;
  padding: 20rpx 28rpx 12rpx;
}

.store-scroll {
  white-space: nowrap;
}

.store-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.store-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  font-size: 24rpx;
  color: #6B5D5E;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.06);
}

.store-tab.active {
  background: #D4786E;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(212,120,110,0.3);
}

.content {
  padding: 12rpx 28rpx 24rpx;
}

.year-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.year-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,36,22,0.06);
}

.year-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F0EBE4;
}

.year-label {
  font-size: 34rpx;
  color: #2C2416;
  font-weight: 700;
}

.year-count {
  font-size: 24rpx;
  color: #948284;
}

.month-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.month-group {
  background: #FAF8F5;
  border-radius: 20rpx;
  overflow: hidden;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.month-header-left {
  display: flex;
  align-items: center;
}

.month-toggle {
  font-size: 24rpx;
  color: #B8AFA4;
  margin-right: 12rpx;
  transition: transform 200ms ease;
}

.month-toggle.expanded {
  transform: rotate(90deg);
}

.month-label {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
}

.month-count {
  font-size: 24rpx;
  color: #948284;
}

.month-content {
  padding: 0 20rpx 20rpx;
}

.date-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.date-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(44,36,22,0.04);
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0EBE4;
}

.date-header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.date-label {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 700;
}

.date-weekday {
  font-size: 22rpx;
  color: #D4786E;
  font-weight: 500;
  background: rgba(212,120,110,0.1);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.date-count {
  font-size: 22rpx;
  color: #948284;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.course-item {
  background: #FAF8F5;
  border-radius: 16rpx;
  overflow: hidden;
}

.course-main {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.course-name {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.course-time {
  font-size: 22rpx;
  color: #948284;
}

.course-store {
  font-size: 20rpx;
  color: #D4786E;
  background: rgba(212,120,110,0.08);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.course-stats {
  display: flex;
  gap: 12rpx;
  margin-right: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  min-width: 60rpx;
}

.stat-item.booked {
  background: #E8F4F0;
}

.stat-item.completed {
  background: #EEF4FC;
}

.stat-item.cancelled {
  background: #FCF0EC;
}

.stat-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #2C2416;
}

.stat-label {
  font-size: 16rpx;
  color: #6B5D5E;
  margin-top: 2rpx;
}

.toggle-icon {
  font-size: 22rpx;
  color: #B8AFA4;
  transition: transform 200ms ease;
}

.toggle-icon.expanded {
  transform: rotate(180deg);
}

.member-list {
  padding: 0 20rpx 20rpx;
}

.member-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.member-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.member-tab.active {
  background: #D4786E;
  color: #FFFFFF;
}

.tab-badge {
  font-size: 16rpx;
  background: rgba(212,120,110,0.15);
  color: #D4786E;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-left: 4rpx;
}

.member-tab.active .tab-badge {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
}

.members {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.04);
}

.member-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  background: #F0EBE4;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.member-name {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
}

.member-phone {
  font-size: 20rpx;
  color: #948284;
  margin-top: 2rpx;
}

.member-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.member-status-badge.status-booked {
  background: #E8F4F0;
  color: #5B8C5A;
}

.member-status-badge.status-completed {
  background: #EEF4FC;
  color: #5B6BA3;
}

.member-status-badge.status-cancelled {
  background: #FCF0EC;
  color: #D4786E;
}

.member-timeline {
  margin-left: 28rpx;
  padding-left: 24rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 16rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 16rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  position: relative;
}

.timeline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6rpx;
  position: relative;
  z-index: 2;
}

.timeline-dot.dot-booked {
  background: #5B8C5A;
}

.timeline-dot.dot-completed {
  background: #5B6BA3;
}

.timeline-dot.dot-cancelled {
  background: #D4786E;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #E8E2DA;
  margin-top: 4rpx;
}

.timeline-content {
  flex: 1;
  padding-bottom: 4rpx;
}

.timeline-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.timeline-action {
  font-size: 22rpx;
  font-weight: 600;
}

.timeline-action.action-booked {
  color: #5B8C5A;
}

.timeline-action.action-completed {
  color: #5B6BA3;
}

.timeline-action.action-cancelled {
  color: #D4786E;
}

.timeline-time {
  font-size: 20rpx;
  color: #B8AFA4;
}

.timeline-detail {
  margin-top: 4rpx;
}

.detail-text {
  font-size: 18rpx;
  color: #948284;
}

.detail-warn {
  color: #D4786E;
}

.load-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-top: 6rpx;
}

.load-more-btn text {
  font-size: 22rpx;
  color: #D4786E;
}

.empty-members {
  text-align: center;
  padding: 32rpx 0;
}

.empty-members text {
  font-size: 22rpx;
  color: #B8AFA4;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8AFA4;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #B8AFA4;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  margin-top: 20rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #D4786E;
}
