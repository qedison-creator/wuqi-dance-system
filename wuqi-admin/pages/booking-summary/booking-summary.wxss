.page {
  min-height: 100vh;
  background: #F6F3F0;
  padding-bottom: 240rpx;
}

.content {
  padding: 24rpx 28rpx;
}

.date-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.date-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,36,22,0.06);
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0EBE4;
}

.date-label {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
}

.date-count {
  font-size: 24rpx;
  color: #948284;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-item {
  background: #FAF8F5;
  border-radius: 20rpx;
  overflow: hidden;
}

.course-main {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.course-name {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.course-time {
  font-size: 24rpx;
  color: #948284;
}

.course-stats {
  display: flex;
  gap: 16rpx;
  margin-right: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  min-width: 80rpx;
}

.stat-item.booked {
  background: #E8F4F0;
}

.stat-item.completed {
  background: #EEF4FC;
}

.stat-item.cancelled {
  background: #FCF0EC;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C2416;
}

.stat-label {
  font-size: 18rpx;
  color: #6B5D5E;
  margin-top: 2rpx;
}

.toggle-icon {
  font-size: 24rpx;
  color: #B8AFA4;
  transition: transform 200ms ease;
}

.toggle-icon.expanded {
  transform: rotate(180deg);
}

.member-list {
  padding: 0 24rpx 24rpx;
}

.member-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.member-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.member-tab.active {
  background: #D4786E;
  color: #FFFFFF;
}

.tab-badge {
  font-size: 18rpx;
  background: rgba(212,120,110,0.15);
  color: #D4786E;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-left: 6rpx;
}

.member-tab.active .tab-badge {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
}

.members {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-row {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #F0EBE4;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.member-name {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
}

.member-phone {
  font-size: 22rpx;
  color: #948284;
  margin-top: 4rpx;
}

.member-booking-time {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 16rpx;
}

.booking-label {
  font-size: 18rpx;
  color: #B8AFA4;
}

.booking-value {
  font-size: 22rpx;
  color: #6B5D5E;
  margin-top: 4rpx;
}

.member-status {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.member-status.status-booked {
  background: #E8F4F0;
  color: #5B8C5A;
}

.member-status.status-completed {
  background: #EEF4FC;
  color: #5B6BA3;
}

.member-status.status-cancelled {
  background: #FCF0EC;
  color: #D4786E;
}

.load-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-top: 8rpx;
}

.load-more-btn text {
  font-size: 24rpx;
  color: #D4786E;
}

.empty-members {
  text-align: center;
  padding: 40rpx 0;
}

.empty-members text {
  font-size: 24rpx;
  color: #B8AFA4;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8AFA4;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #B8AFA4;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  margin-top: 20rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #D4786E;
}
