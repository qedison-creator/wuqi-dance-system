<view class="videos-page">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-left">
      <text class="page-title">教练作品</text>
      <text class="page-desc">管理教练舞蹈视频作品</text>
    </view>
    <view class="add-btn" bindtap="onAddVideo">
      <text class="add-icon">+</text>
      <text>添加作品</text>
    </view>
  </view>

  <!-- 视频列表 -->
  <view class="video-list" wx:if="{{videos.length > 0}}">
    <view class="video-item" wx:for="{{videos}}" wx:key="_id">
      <view class="video-preview">
        <image class="video-cover" src="{{item.cover_url || '/images/default-cover.png'}}" mode="aspectFill" />
        <view class="play-overlay">
          <view class="play-icon">▶</view>
        </view>
        <view class="video-duration" wx:if="{{item.duration}}">
          <text>{{item.duration}}</text>
        </view>
        <view class="video-status {{item.status}}">
          <text>{{item.status === 'active' ? '已发布' : '已下架'}}</text>
        </view>
      </view>
      <view class="video-info">
        <text class="video-title">{{item.title}}</text>
        <text class="video-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="video-meta">
          <view class="meta-item" wx:if="{{item.coach_id}}">
            <text class="meta-label">教练</text>
            <text class="meta-value">{{item.coach_id.name || '未知'}}</text>
          </view>
          <view class="meta-item" wx:if="{{item.view_count}}">
            <text class="meta-label">播放</text>
            <text class="meta-value">{{item.view_count}}次</text>
          </view>
        </view>
      </view>
      <view class="video-actions">
        <view class="action-btn primary" data-id="{{item._id}}" bindtap="onEditVideo">
          <text>编辑</text>
        </view>
        <view class="action-btn {{item.status === 'active' ? 'warning' : 'success'}}" data-id="{{item._id}}" data-index="{{index}}" bindtap="onToggleStatus">
          <text>{{item.status === 'active' ? '下架' : '上架'}}</text>
        </view>
        <view class="action-btn danger" data-id="{{item._id}}" bindtap="onDeleteVideo">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">🎬</view>
    <text class="empty-title">暂无视频作品</text>
    <text class="empty-desc">点击上方按钮添加教练作品</text>
    <view class="empty-btn" bindtap="onAddVideo">
      <text>添加作品</text>
    </view>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-header">
        <text class="modal-title">{{editingVideo ? '编辑作品' : '添加作品'}}</text>
        <text class="modal-close" bindtap="onCloseModal">✕</text>
      </view>

      <scroll-view scroll-y class="modal-body">
        <!-- 视频上传区域 -->
        <view class="upload-section">
          <text class="section-title">视频文件 *</text>
          <view class="upload-area video-upload" bindtap="onChooseVideo">
            <view wx:if="{{formData.video_url}}" class="uploaded-info">
              <text class="uploaded-icon">✓</text>
              <text class="uploaded-text">视频已上传</text>
            </view>
            <view wx:else class="upload-placeholder">
              <text class="upload-icon">🎥</text>
              <text class="upload-text">点击上传视频</text>
              <text class="upload-tip">支持 MP4 格式，最多100MB</text>
            </view>
          </view>
        </view>

        <!-- 封面上传区域 -->
        <view class="upload-section">
          <text class="section-title">封面图片</text>
          <view class="upload-area cover-upload" bindtap="onChooseCover">
            <image wx:if="{{formData.cover_url}}" class="preview-cover" src="{{formData.cover_url}}" mode="aspectFill" />
            <view wx:else class="upload-placeholder">
              <text class="upload-icon">🖼️</text>
              <text class="upload-text">点击上传封面</text>
              <text class="upload-tip">建议尺寸: 16:9</text>
            </view>
          </view>
        </view>

        <!-- 表单 -->
        <view class="form-group">
          <text class="form-label">标题 *</text>
          <input class="form-input" placeholder="请输入视频标题" value="{{formData.title}}" data-field="title" bindinput="onInputChange" />
        </view>

        <view class="form-group">
          <text class="form-label">简介</text>
          <textarea class="form-textarea" placeholder="请输入视频简介（可选）" value="{{formData.description}}" data-field="description" bindinput="onInputChange" maxlength="200" />
        </view>

        <view class="form-row">
          <view class="form-group half">
            <text class="form-label">关联教练</text>
            <picker mode="selector" range="{{coaches}}" range-key="name" bindchange="onCoachChange">
              <view class="form-picker">
                <text class="{{formData.coach_id ? '' : 'placeholder'}}">{{formData.coachName || '选择教练'}}</text>
              </view>
            </picker>
          </view>
          <view class="form-group half">
            <text class="form-label">时长</text>
            <input class="form-input" placeholder="如 3:30" value="{{formData.duration}}" data-field="duration" bindinput="onInputChange" />
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">状态</text>
          <view class="switch-row">
            <text class="switch-label">{{formData.status === 'active' ? '已发布' : '已下架'}}</text>
            <switch checked="{{formData.status === 'active'}}" color="#FFCC00" bindchange="onStatusChange" />
          </view>
        </view>
      </scroll-view>

      <view class="modal-buttons">
        <view class="btn-secondary" bindtap="onCloseModal"><text>取消</text></view>
        <view class="btn-primary" bindtap="onSubmit"><text>保存</text></view>
      </view>
    </view>
  </view>
</view>