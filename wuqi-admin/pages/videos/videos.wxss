.videos-page {
  padding: 24rpx;
  padding-bottom: 40rpx;
  background-color: var(--bg-input);
  min-height: 100vh;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.header-left {
  flex: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-primary);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(197, 116, 75, 0.3);
}

.add-btn text {
  font-size: 28rpx;
  color: var(--bg-card);
  font-weight: 600;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 700;
}

.video-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.video-item {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.06);
}

.video-preview {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.video-cover {
  width: 100%;
  height: 100%;
}

.play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(44, 36, 22, 0.2);
}

.play-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(246, 243, 240, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-primary);
  padding-left: 8rpx;
}

.video-duration {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(44, 36, 22, 0.6);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.video-duration text {
  font-size: 22rpx;
  color: var(--bg-card);
}

.video-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
}

.video-status.active {
  background: rgba(91, 140, 90, 0.9);
  color: var(--bg-card);
}

.video-status.disabled {
  background: rgba(139, 126, 106, 0.9);
  color: var(--bg-card);
}

.video-info {
  padding: 20rpx 24rpx;
}

.video-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.video-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.video-meta {
  display: flex;
  gap: 32rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.meta-value {
  font-size: 22rpx;
  color: var(--text-primary);
}

.video-actions {
  display: flex;
  padding: 16rpx 24rpx 20rpx;
  gap: 16rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: var(--radius-lg);
  text-align: center;
}

.action-btn text {
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: var(--color-primary-bg);
}

.action-btn.primary text {
  color: var(--color-primary);
}

.action-btn.warning {
  background: rgba(196, 102, 62, 0.15);
}

.action-btn.warning text {
  color: var(--color-warning);
}

.action-btn.success {
  background: rgba(91, 140, 90, 0.15);
}

.action-btn.success text {
  color: var(--color-success);
}

.action-btn.danger {
  background: rgba(196, 75, 75, 0.15);
}

.action-btn.danger text {
  color: var(--color-danger);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.06);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 40rpx;
}

.empty-btn {
  background: var(--color-primary);
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 28rpx;
  color: var(--bg-card);
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 85%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(44, 36, 22, 0.12);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
}

.upload-section {
  padding: 24rpx 32rpx 0;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.upload-area {
  width: 100%;
  border: 3rpx dashed var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-upload {
  height: 200rpx;
}

.cover-upload {
  height: 280rpx;
}

.preview-cover {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.upload-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.uploaded-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.uploaded-icon {
  font-size: 48rpx;
  color: var(--color-success);
  margin-bottom: 12rpx;
}

.uploaded-text {
  font-size: 28rpx;
  color: var(--color-success);
}

.form-group {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.form-row {
  display: flex;
  padding: 0 32rpx;
  gap: 24rpx;
}

.form-group.half {
  flex: 1;
  padding: 0;
  margin-top: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-picker {
  height: 88rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.form-picker text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-picker .placeholder {
  color: var(--text-tertiary);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: var(--bg-input);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
}

.switch-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
  flex-shrink: 0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 24rpx 0;
  border-radius: var(--radius-lg);
  text-align: center;
}

.btn-secondary {
  background: var(--border);
}

.btn-secondary text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.btn-primary {
  background: var(--color-primary);
}

.btn-primary text {
  font-size: 28rpx;
  color: var(--bg-card);
  font-weight: 600;
}