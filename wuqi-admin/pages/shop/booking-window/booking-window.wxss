.page {
  padding: 20rpx 30rpx 60rpx;
  background: #F6F3F0;
  min-height: 100vh;
  box-sizing: border-box;
}

.guide-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.guide-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.guide-icon {
  font-size: 40rpx;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.guide-text {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.form-hint {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  margin-bottom: 16rpx;
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-field {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.unit-input {
  max-width: 200rpx;
}

.unit-text {
  font-size: 28rpx;
  color: #888;
}

.preview-box {
  background: #F6F3F0;
  border-radius: 12rpx;
  padding: 24rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  margin-bottom: 12rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.highlight {
  color: #C5744B;
  font-weight: 600;
}

.btn-row {
  display: flex;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #C5744B, #b0633a);
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(197,116,75,0.3);
}

.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.75);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  z-index: 999;
}

.toast-text {
  color: #fff;
  font-size: 28rpx;
}