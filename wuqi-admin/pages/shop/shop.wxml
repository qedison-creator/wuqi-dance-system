<view class="shop-page">
  <view class="shop-hero">
    <view class="hero-glow"></view>
    <text class="hero-title">店务管理</text>
    <text class="hero-sub">门店日常运营 · 一站式管理</text>
  </view>

  <view class="card-grid">
    <view class="menu-card card-coral" bindtap="onGoToStoreMaintenance">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/store.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">门店维护</text>
      <text class="card-desc">管理门店信息</text>
    </view>

    <view class="menu-card card-sage" wx:if="{{permSchedule}}" bindtap="onGoToSchedule">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/settings.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">排课设置</text>
      <text class="card-desc">课程与时间安排</text>
    </view>

    <view class="menu-card card-sky" wx:if="{{permWaitlist}}" bindtap="onGoToWaitlist">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/users.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">候补排队</text>
      <text class="card-desc">等待队列管理</text>
    </view>

    <view class="menu-card card-amber" wx:if="{{permSalary}}" bindtap="onGoToSalary">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/info.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">教练薪酬</text>
      <text class="card-desc">薪资与结算</text>
    </view>

    <view class="menu-card card-lavender" wx:if="{{permPackage}}" bindtap="onGoToPackageLogs">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/file-text.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">套餐记录</text>
      <text class="card-desc">会员套餐明细</text>
    </view>

    <view class="menu-card card-mint" wx:if="{{permCoach}}" bindtap="onGoToCoaches">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/person-dancing.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">教练管理</text>
      <text class="card-desc">师资团队维护</text>
    </view>

    <view class="menu-card card-rose" wx:if="{{permVideo}}" bindtap="onGoToVideos">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/video.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">教练作品</text>
      <text class="card-desc">视频作品集</text>
    </view>

    <view class="menu-card card-peach" wx:if="{{permBanner}}" bindtap="onGoToBanner">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/image.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">轮播图管理</text>
      <text class="card-desc">首页展示配置</text>
    </view>

    <view class="menu-card card-slate" wx:if="{{permHoliday}}" bindtap="onGoToHolidays">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/calendar-off.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">放假管理</text>
      <text class="card-desc">节假日与停课</text>
    </view>

    <view class="menu-card card-gold" bindtap="onGoToAnnouncements">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/bell.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">公告管理</text>
      <text class="card-desc">发布门店公告</text>
    </view>

    <view class="menu-card card-indigo" wx:if="{{isAdmin}}" bindtap="onGoToExemption">
      <view class="card-icon-wrap">
        <image class="card-icon" src="/images/icons/shield.svg" mode="aspectFit"></image>
      </view>
      <text class="card-label">豁免设置</text>
      <text class="card-desc">特殊权限配置</text>
    </view>
  </view>
</view>