.shop-page {
  min-height: 100vh;
  padding: 0 28rpx 200rpx;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FBF8F5 0%, #F5F1EB 40%, #F0ECE6 100%);
}

/* ===== 顶部标题区 ===== */
.shop-hero {
  position: relative;
  padding: 56rpx 8rpx 44rpx;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(197, 116, 75, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #2C2416;
  letter-spacing: 4rpx;
  line-height: 1.15;
}

.hero-sub {
  display: block;
  font-size: 25rpx;
  color: #A8988A;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
  font-weight: 400;
}

/* ===== 菜单分组 ===== */
.menu-section {
  margin-bottom: 28rpx;
}

.menu-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #8A7E72;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
  letter-spacing: 2rpx;
  line-height: 1.5;
}

.menu-card {
  background: linear-gradient(145deg, #FFFFFF 0%, #FEF9F8 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(44, 36, 22, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid rgba(44, 36, 22, 0.04);
  transition: background 150ms ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(197, 116, 75, 0.04);
}

/* ===== 图标容器 ===== */
.menu-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon {
  width: 28rpx;
  height: 28rpx;
}

/* ===== 文字区域 ===== */
.menu-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-label {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 600;
  line-height: 1.3;
}

.menu-desc {
  font-size: 22rpx;
  color: #B8AF9E;
  font-weight: 400;
  line-height: 1.4;
  margin-top: 2rpx;
}

/* ===== 箭头 ===== */
.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  opacity: 0.3;
}
