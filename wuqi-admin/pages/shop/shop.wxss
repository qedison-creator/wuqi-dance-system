.shop-page {
  min-height: 100vh;
  padding: 0 24rpx 200rpx;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FBF8F5 0%, #F5F1EB 40%, #F0ECE6 100%);
}

.shop-hero {
  position: relative;
  padding: 56rpx 8rpx 44rpx;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 120, 110, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #2C2416;
  letter-spacing: 4rpx;
  line-height: 1.15;
}

.hero-sub {
  display: block;
  font-size: 25rpx;
  color: #A8988A;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
  font-weight: 400;
}

.card-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.menu-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx 8rpx;
  padding: 32rpx 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(44, 36, 22, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(44, 36, 22, 0.03), 0 1rpx 2rpx rgba(44, 36, 22, 0.04);
  transition: all 220ms cubic-bezier(0.2, 0, 0, 1);
  position: relative;
  overflow: hidden;
}

.menu-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  opacity: 0;
  transition: opacity 220ms ease;
}

.menu-card:active {
  transform: scale(0.965);
  box-shadow: 0 8rpx 28rpx rgba(44, 36, 22, 0.1);
}

.menu-card:active::before {
  opacity: 1;
}

.card-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.card-icon-wrap::after {
  content: '';
  position: absolute;
  inset: -6rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  pointer-events: none;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  z-index: 2;
}

.card-label {
  font-size: 27rpx;
  color: #2C2416;
  font-weight: 600;
  text-align: center;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 21rpx;
  color: #B8AF9E;
  font-weight: 400;
  text-align: center;
  line-height: 1.4;
}

/* ===== 统一配色方案（所有卡片图标同一暖色系） ===== */

.card-icon-wrap {
  background: linear-gradient(135deg, #FAEEE4 0%, #F5E4D4 100%);
}

.menu-card::before { background: #D4786E; }

.menu-card:active .card-icon-wrap {
  background: linear-gradient(135deg, #F5E4D4 0%, #EDD2BE 100%);
}