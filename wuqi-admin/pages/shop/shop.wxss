.shop-page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  padding-bottom: 180rpx;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  background: #F0ECE6;
}

.page-header {
  padding: 20rpx 0 36rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2C2416;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8B7E6A;
  margin-top: 8rpx;
}

.grid-container {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.grid-item {
  width: calc(50% - 20rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 20rpx 28rpx;
  margin: 0 10rpx 20rpx 10rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #E8E2D8;
  box-shadow: 0 2rpx 8rpx rgba(44, 36, 22, 0.04);
  box-sizing: border-box;
  transition: all 200ms ease-out;
}

.grid-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(44, 36, 22, 0.08);
  background: #FAF8F5;
}

.grid-icon-bg {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.grid-icon-bg.terracotta {
  background: #FAEEE4;
}

.grid-icon-bg.sage {
  background: #EDF5EE;
}

.grid-icon-bg.blue {
  background: #EDF5EE;
}

.grid-icon-bg.warm {
  background: #FAEEE4;
}

.grid-icon {
  width: 52rpx;
  height: 52rpx;
}

.grid-label {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
}