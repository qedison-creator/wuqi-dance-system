<view class="page">
  <view class="page-header">
    <text class="page-title">门店维护</text>
  </view>

  <block wx:if="{{!editingStore}}">
    <view class="store-list">
      <view class="store-card" wx:for="{{storeList}}" wx:key="_id" data-store="{{item}}" bindtap="onEditStore">
        <view class="sc-header">
          <text class="sc-name">{{item.name}}</text>
          <view class="sc-edit-btn">
            <text>编辑</text>
          </view>
        </view>
        <view class="sc-row" wx:if="{{item.address}}">
          <text class="sc-label">地址</text>
          <text class="sc-value">{{item.address}}</text>
        </view>
        <view class="sc-row" wx:if="{{item.phone}}">
          <text class="sc-label">电话</text>
          <text class="sc-value">{{item.phone}}</text>
        </view>
        <view class="sc-row" wx:if="{{item.nav_name}}">
          <text class="sc-label">导航名称</text>
          <text class="sc-value">{{item.nav_name}}</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{storeList.length === 0}}">
      <text>暂无门店数据</text>
    </view>
  </block>

  <block wx:else>
    <view class="section card">
      <view class="section-title">编辑 {{editingStore.name}}</view>
      <view class="form-group">
        <text class="form-label">门店名称</text>
        <input class="form-input" placeholder="请输入门店名称" value="{{editForm.name}}" data-field="name" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">门店地址</text>
        <input class="form-input" placeholder="请输入门店地址" value="{{editForm.address}}" data-field="address" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">联系电话</text>
        <input class="form-input" type="number" placeholder="请输入联系电话" value="{{editForm.phone}}" data-field="phone" bindinput="onFormInput" />
      </view>
    </view>

    <view class="section card">
      <view class="section-title">导航信息</view>
      <view class="form-group">
        <text class="form-label">地点名称</text>
        <text class="form-hint">导航时显示的地点名称</text>
        <input class="form-input" placeholder="如：舞栖舞蹈社（福永店）" value="{{editForm.nav_name}}" data-field="nav_name" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">纬度</text>
        <text class="form-hint">如：22.673711</text>
        <input class="form-input" type="digit" placeholder="请输入纬度" value="{{editForm.latitude}}" data-field="latitude" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">经度</text>
        <text class="form-hint">如：113.807580</text>
        <input class="form-input" type="digit" placeholder="请输入经度" value="{{editForm.longitude}}" data-field="longitude" bindinput="onFormInput" />
      </view>
    </view>

    <view class="action-row">
      <view class="cancel-btn" bindtap="onCancelEdit">
        <text>取消</text>
      </view>
      <view class="save-btn" bindtap="onSave">
        <text>保存</text>
      </view>
    </view>
  </block>
</view>