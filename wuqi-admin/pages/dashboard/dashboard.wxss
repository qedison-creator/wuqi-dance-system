.page {
  min-height: 100vh;
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
  background: #F6F3F0;
  box-sizing: border-box;
  overflow-y: auto;
}

/* ===== Hero ===== */
.hero {
  position: relative;
  margin: 28rpx 28rpx 24rpx;
  padding: 36rpx 32rpx 20rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(185,130,100,0.12);
  /* 默认渐变色背景兜底（图片加载失败时可见） */
  background: linear-gradient(135deg, #3A2D28 0%, #5C4038 40%, #8B5E4B 100%);
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  padding: 20rpx;
}

/* ---- greet: emoji | body(name+role, sub) ---- */
.hero-greet {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.hg-emoji {
  font-size: 60rpx;
  line-height: 1;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.hg-body {
  flex: 1;
  min-width: 0;
  padding-top: 6rpx;
}

.hg-line1 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.hg-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.6);
}

.hg-name {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.6);
}

.hg-role {
  font-size: 20rpx;
  color: #D4786E;
  font-weight: 600;
  padding: 4rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  flex-shrink: 0;
  letter-spacing: 1rpx;
  filter: drop-shadow(0 1rpx 2rpx rgba(185,130,100,0.12));
}

.hg-sub {
  font-size: 25rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  display: block;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.5);
}

/* ---- foot: date | store ---- */
.hero-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hf-date {
  font-size: 20rpx;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.7), 0 0 16rpx rgba(0, 0, 0, 0.4);
}

.hf-store {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx 8rpx 14rpx;
  background: rgba(255,255,255,0.95);
  border: 1rpx solid rgba(185,130,100,0.3);
  border-radius: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.25);
  max-width: 320rpx;
  margin-left: 16rpx;
}

.hf-store:active {
  background: rgba(212,120,110,0.08);
}

.hfs-icon {
  font-size: 22rpx;
  color: #D4786E;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.hfs-label {
  font-size: 21rpx;
  color: #6B5D56;
  font-weight: 500;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 4rpx;
}

.hfs-arrow {
  font-size: 18rpx;
  color: #C4B3A4;
}

/* ===== Bento Stats Grid ===== */
.stats {
  display: flex;
  flex-wrap: wrap;
  margin: 0 20rpx 20rpx;
}

.stat {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.03);
  transition: transform 150ms ease-out;
}

.stat:active {
  transform: scale(0.96);
}

.stat-sched {
  background: linear-gradient(135deg, #FFF8F3 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(197,116,75,0.08);
}

.stat-member {
  background: linear-gradient(135deg, #F8F6F2 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(139,126,106,0.08);
}

.stat-wait {
  background: linear-gradient(135deg, #FFF7F2 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(196,102,62,0.08);
}

.stat-review {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(196,75,75,0.08);
}

.stat-head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.stat-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.dot-sched { background: #C5744B; }
.dot-member { background: #8B7E6A; }
.dot-wait { background: #C4663E; }
.dot-review { background: #C44B4B; }

.stat-title {
  font-size: 24rpx;
  color: #8B7E6A;
  font-weight: 500;
}

.stat-val {
  font-size: 52rpx;
  font-weight: 800;
  color: #2C2416;
  line-height: 1;
  letter-spacing: -2rpx;
}

.val-warn { color: #C4663E; }
.val-danger { color: #C44B4B; }

/* ===== Banner ===== */
.banner-wrap {
  margin: 0 28rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(44,36,22,0.05);
}

.swiper {
  height: 260rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

/* ===== Alert ===== */
.alert {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 28rpx 20rpx;
  padding: 22rpx 24rpx;
  background: #FAEEE4;
  border-radius: 16rpx;
  border: 1rpx solid rgba(196,102,62,0.12);
  transition: transform 150ms ease-out;
}

.alert:active {
  transform: scale(0.985);
}

.alert-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.alert-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #C4663E;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.alert-msg {
  font-size: 26rpx;
  color: #C4663E;
  font-weight: 500;
}

.alert-bold {
  font-weight: 800;
  font-size: 30rpx;
  margin: 0 4rpx;
}

.alert-go {
  font-size: 24rpx;
  color: #C4663E;
  font-weight: 600;
  flex-shrink: 0;
}

/* ===== Section ===== */
.section {
  margin: 0 28rpx 20rpx;
}

.sec-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sec-title {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 700;
}

.sec-more {
  font-size: 24rpx;
  color: #C5744B;
  font-weight: 500;
}

.todos {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.03);
}

.todo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #F0EBE4;
  transition: all 150ms ease-out;
}

.todo:last-child {
  border-bottom: none;
}

.todo:active {
  background: #F8F5F1;
}

.todo-urgent {
  background: rgba(197,116,75,0.025);
}

.todo-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.todo-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.todo-dot-danger { background: #C44B4B; }
.todo-dot-muted { background: #E8E2D8; }

.todo-text {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 500;
}

.todo-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.todo-badge {
  font-size: 22rpx;
  color: #C4663E;
  background: #FAEEE4;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.todo-chevron {
  font-size: 28rpx;
  color: #B8AF9E;
  transition: transform 0.3s ease;
}

.chev-open {
  transform: rotate(90deg);
}

.todo-expand {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  padding: 0 28rpx;
  background: #FAF8F5;
  transform-origin: top center;
  transition:
    max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.3s ease 0.05s,
    padding 0.35s ease;
}

.todo-expand-open {
  max-height: 20000rpx;
  opacity: 1;
  padding: 20rpx 28rpx 8rpx;
}

.todo-expand .member-card {
  padding: 20rpx 0;
}

.todo-expand .empty-modal {
  text-align: center;
  padding: 30rpx 0;
  color: #B8AF9E;
  font-size: 26rpx;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #B8AF9E;
}

/* ===== Bottom Nav ===== */
.bnav {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  height: 104rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  box-shadow: 0 2rpx 16rpx rgba(44,36,22,0.06), 0 8rpx 36rpx rgba(44,36,22,0.04);
  z-index: 10000;
}

.bnav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 150ms ease-out;
}

.bnav-item:active {
  transform: scale(0.94);
}

.bnav-scan {
  margin-top: -20rpx;
}

.bnav-icon {
  font-size: 36rpx;
  color: #B8AF9E;
  margin-bottom: 4rpx;
}

.bnav-scan-icon {
  font-size: 44rpx;
  color: #C5744B;
}

.bnav-label {
  font-size: 22rpx;
  color: #B8AF9E;
  font-weight: 500;
}

.bnav-scan-label {
  color: #C5744B;
  font-weight: 700;
}

/* ===== Modal ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: rgba(44,36,22,0.45);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
}

.modal {
  width: 560rpx;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #E8E2D8;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
}

.modal-close {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #B8AF9E;
  background: #F0ECE6;
  border-radius: 50%;
}

.modal-close:active {
  background: #E8E2D8;
  transform: scale(0.9);
}

.modal-bd {
  padding: 0 28rpx 28rpx;
  max-height: 50vh;
}

.modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0EBE4;
}

.modal-row:last-child {
  border-bottom: none;
}

.modal-cell {
  flex: 1;
  min-width: 0;
}

.modal-name {
  display: block;
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 600;
}

.modal-sub {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 4rpx;
}

.modal-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #2C2416;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.clr-warn { color: #C4663E; }
.clr-ok { color: #5B8C5A; }

/* ===== Member Card in Modal ===== */
.member-card {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0EBE4;
}

.member-card:last-child {
  border-bottom: none;
}

.mc-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF0EA 0%, #FFE0D0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  border: 2rpx solid rgba(197, 116, 75, 0.15);
}

.mc-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.mc-avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #C5744B;
  line-height: 1;
}

.mc-info {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  padding-right: 10rpx;
}

.mc-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2416;
  display: block;
}

.mc-phone {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 6rpx;
  display: block;
}

.mc-detail-row {
  display: flex;
  align-items: flex-start;
  margin-top: 8rpx;
}

.mc-detail-label {
  font-size: 22rpx;
  color: #B8AF9E;
  flex-shrink: 0;
}

.mc-detail-value {
  font-size: 22rpx;
  color: #2C2416;
  font-weight: 500;
  flex: 1;
  min-width: 0;
}

.mc-status {
  flex-shrink: 0;
  text-align: right;
  margin-left: 20rpx;
}

.mc-chevron {
  font-size: 24rpx;
  color: #B8AF9E;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.member-card:active {
  background-color: #FAF8F5;
}

.mc-remaining {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
}

.mc-rem-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #C5744B;
}

.mc-rem-unit {
  font-size: 20rpx;
  color: #C4663E;
  margin-left: 4rpx;
}

.mc-days {
  font-size: 22rpx;
  color: #C4663E;
  display: block;
  margin-top: 4rpx;
}

.mc-days-empty {
  color: #C44B4B;
}

.empty-modal {
  text-align: center;
  padding: 60rpx 0;
  color: #B8AF9E;
  font-size: 26rpx;
}

/* ===== Store Modal ===== */
.store-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 56rpx 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,33,34,0.12);
}

.stm-hd {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.stm-title {
  font-size: 34rpx;
  color: #2C2416;
  font-weight: 700;
  text-align: center;
}

.stm-list {
  margin-bottom: 28rpx;
}

.stm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 20rpx;
  background: #F9F7F5;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.stm-item:last-child {
  margin-bottom: 0;
}

.stm-item:active {
  transform: scale(0.98);
}

.stm-active {
  background: #FDF2EF;
  border-color: #D4786E;
}

.stm-name {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 500;
}

.stm-active .stm-name {
  color: #D4786E;
  font-weight: 700;
}

.stm-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #C05D53);
  position: relative;
}

.stm-check::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%) rotate(45deg);
  width: 10rpx;
  height: 18rpx;
  border-bottom: 3rpx solid #FFFFFF;
  border-right: 3rpx solid #FFFFFF;
}

.stm-bottom {
  display: block;
}

.stm-close-btn {
  width: 100%;
  padding: 22rpx 0;
  background: #F9F7F5;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6B5D5E;
  font-weight: 500;
}

/* ===== 课程卡片（展开区域，与运营管理页面一致） ===== */
.course-card {
  margin: 0 0 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #E8E2D8;
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.04), 0 8rpx 24rpx rgba(44,36,22,0.06);
  transition: all 0.2s ease;
}

.course-card:last-child {
  margin-bottom: 6rpx;
}

.course-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(44,36,22,0.06);
}

.course-card.cancelled,
.course-card.offline {
  opacity: 0.45;
}

.card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-left {
  flex: 1;
  min-width: 0;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.card-name {
  font-size: 30rpx;
  color: #2C2416;
  font-weight: 600;
}

.card-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-meta-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-time {
  font-size: 26rpx;
  color: #2C2416;
  font-weight: 600;
}

.card-date {
  font-size: 24rpx;
  color: #C4663E;
  font-weight: 600;
  padding: 2rpx 10rpx;
  background: #FAEEE4;
  border-radius: 6rpx;
}

.card-coach {
  font-size: 24rpx;
  color: #8B7E6A;
  font-weight: 400;
}

.card-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.schedule-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
}

.card-progress-text {
  font-size: 22rpx;
  color: #8B7E6A;
}

.schedule-status.available {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.schedule-status.full {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.schedule-status.cancelled,
.schedule-status.offline {
  background-color: rgba(184, 175, 158, 0.2);
  color: var(--text-tertiary);
}

.schedule-status.completed {
  background-color: rgba(77, 184, 160, 0.1);
  color: #4DB8A0;
}

.schedule-status.not_open {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.card-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-booked {
  color: #5B8C5A;
}

.stat-checked {
  color: #5B8C5A;
}

.stat-cancelled {
  color: #C44B4B;
}

.stat-exempted {
  color: #8B7E6A;
}

.stat-label {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-top: 4rpx;
}

.card-store-inline {
  font-size: 24rpx;
  color: #8B7E6A;
  font-weight: 500;
}

.stm-close-btn:active {
  opacity: 0.7;
}

/* ===== 会员审核卡片 ===== */
.audit-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.audit-top {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.audit-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FAF5F0;
  flex-shrink: 0;
}

.audit-info {
  flex: 1;
  min-width: 0;
}

.audit-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.audit-name {
  font-size: 28rpx;
  color: #2C2416;
  font-weight: 600;
}

.audit-tag {
  background: linear-gradient(135deg, #E89A6A 0%, #C5744B 100%);
  padding: 4rpx 14rpx;
  border-radius: 14rpx;
}

.audit-tag-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.audit-phone-line {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.audit-phone-item {
  font-size: 24rpx;
  color: #5A4E3F;
}

.audit-phone-label {
  font-size: 22rpx;
  color: #B8AF9E;
  margin-right: 6rpx;
}

.audit-phone {
  font-size: 24rpx;
  color: #B8AF9E;
  margin-top: 8rpx;
  display: block;
}

.audit-date {
  font-size: 22rpx;
  color: #8B7E6A;
  display: block;
  margin-top: 8rpx;
}

.audit-store {
  font-size: 22rpx;
  color: #8B7E6A;
  display: block;
  margin-top: 4rpx;
}

.audit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0EBE4;
}

.audit-btn {
  flex: 1;
  padding: 14rpx 0;
  text-align: center;
  border-radius: 14rpx;
  transition: opacity 150ms ease-out;
}

.audit-btn:active {
  opacity: 0.8;
}

.audit-btn-text {
  font-size: 24rpx;
  font-weight: 500;
}

.audit-btn-delete {
  background: #FAF0EC;
}

.audit-btn-delete .audit-btn-text {
  color: #B89A92;
}

.audit-btn-reject {
  background: #F5E6E2;
}

.audit-btn-reject .audit-btn-text {
  color: #C44B4B;
}

.audit-btn-approve {
  background: #D4786E;
}

.audit-btn-approve .audit-btn-text {
  color: #FFFFFF;
}

/* ===== 会员审核-门店选择弹窗 ===== */
.audit-store-modal {
  width: 560rpx;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.audit-stm-header {
  position: relative;
  padding: 32rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #E8E2D8;
  flex-shrink: 0;
}

.audit-stm-title {
  font-size: 32rpx;
  color: #2C2416;
  font-weight: 700;
  display: block;
}

.audit-stm-subtitle {
  font-size: 24rpx;
  color: #8B7E6A;
  display: block;
  margin-top: 8rpx;
}

.audit-stm-close {
  position: absolute;
  right: 28rpx;
  top: 32rpx;
  font-size: 36rpx;
  color: #B8AF9E;
  line-height: 1;
}

.audit-stm-list {
  max-height: 400rpx;
  padding: 12rpx 0;
  flex: 1;
}

.audit-stm-item {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #5A4E3F;
  border-bottom: 1rpx solid #F5F0EB;
}

.audit-stm-active {
  background: #FAF5F0;
  color: #D4786E;
  font-weight: 600;
}

.audit-stm-confirm {
  margin: 24rpx 28rpx 28rpx;
  padding: 24rpx 0;
  background: #D4786E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  text-align: center;
}

.audit-stm-confirm.disabled {
  background: #E8E2D8;
  color: #B8AF9E;
}

.audit-stm-confirm:active {
  opacity: 0.85;
}
