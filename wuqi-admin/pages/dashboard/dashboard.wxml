<view class="page">
  <view class="hero">
    <image wx:if="{{heroBackgroundUrl}}" class="hero-bg" src="{{heroBackgroundUrl}}" mode="aspectFill" binderror="onHeroImageError"></image>
    <view class="hero-content">
      <view class="hero-greet">
        <text class="hg-emoji">{{greeting.emoji}}</text>
        <view class="hg-body">
          <view class="hg-line1">
            <text class="hg-text">{{greeting.text}}，</text>
            <text class="hg-name">{{userInfo.nick_name || userInfo.name || userInfo.real_name || userInfo.username || '管理员'}}</text>
          </view>
          <text class="hg-sub">{{greeting.sub}}</text>
        </view>
      </view>
      <view class="hero-foot">
        <text class="hf-date">{{currentDate}}</text>
        <view class="hf-store" bindtap="onOpenStoreModal">
          <text class="hfs-icon">⌂</text>
          <text class="hfs-label">{{currentStoreName}}</text>
          <text class="hfs-arrow">▾</text>
        </view>
      </view>
    </view>
  </view>

  <view class="stats">
    <view class="stat stat-sched" bindtap="onStatTap" data-type="today">
      <view class="stat-head">
        <text class="stat-dot dot-sched"></text>
        <text class="stat-title">今日课程</text>
      </view>
      <text class="stat-val">{{stats.todaySchedules || 0}}</text>
    </view>
    <view class="stat stat-member" bindtap="onStatTap" data-type="members">
      <view class="stat-head">
        <text class="stat-dot dot-member"></text>
        <text class="stat-title">会员总数</text>
      </view>
      <text class="stat-val">{{stats.totalMembers || 0}}</text>
    </view>
    <view class="stat stat-wait" bindtap="onStatTap" data-type="waitlist">
      <view class="stat-head">
        <text class="stat-dot dot-wait"></text>
        <text class="stat-title">候补排队</text>
      </view>
      <text class="stat-val val-warn">{{stats.waitlistCount || 0}}</text>
    </view>
    <view class="stat stat-review" bindtap="onStatTap" data-type="reviews">
      <view class="stat-head">
        <text class="stat-dot dot-review"></text>
        <text class="stat-title">待审核</text>
      </view>
      <text class="stat-val val-danger">{{stats.pendingReviews || 0}}</text>
    </view>
  </view>

  <view class="alert" wx:if="{{scheduleEndAlert.visible}}" bindtap="onViewSchedule">
    <view class="alert-left">
      <text class="alert-dot"></text>
      <text class="alert-msg">
        <text wx:if="{{scheduleEndAlert.weeksLeft > 0}}">还剩<text class="alert-bold">{{scheduleEndAlert.weeksLeft}}</text>周</text>
        <text wx:else>还剩<text class="alert-bold">{{scheduleEndAlert.daysLeft}}</text>天</text>
        排课即将到期
      </text>
    </view>
    <text class="alert-go">查看 ›</text>
  </view>

  <view class="section">
    <view class="sec-hd">
      <text class="sec-title">待办事项</text>
      <text class="sec-more" bindtap="onViewAllTodos">全部 ›</text>
    </view>
    <view class="todos" wx:if="{{todos.length > 0}}">
      <block wx:for="{{todos}}" wx:key="_id" wx:if="{{index < 4}}">
        <view class="todo {{item.urgent ? 'todo-urgent' : ''}}" data-item="{{item}}" bindtap="onTodoTap">
          <view class="todo-left">
            <view class="todo-dot {{item.urgent ? 'todo-dot-danger' : 'todo-dot-muted'}}"></view>
            <text class="todo-text">{{item.title}}</text>
          </view>
          <view class="todo-right">
            <text class="todo-badge" wx:if="{{item.count > 0}}">{{item.count}}{{item.unit}}</text>
            <text class="todo-chevron {{expandedTodo === item._id ? 'chev-open' : ''}}">›</text>
          </view>
        </view>
        <view class="todo-expand {{expandedTodo === item._id ? 'todo-expand-open' : ''}}">
          <block wx:if="{{expandedTodo === item._id}}">
            <!-- 会员审核卡片 -->
            <block wx:if="{{item.type === 'member_audit'}}">
              <view class="empty-modal" wx:if="{{auditLoading}}">
                <text>加载中...</text>
              </view>
              <view class="audit-card" wx:for="{{pendingMembers}}" wx:key="_id" wx:for-item="pm">
                <view class="audit-top">
                  <image class="audit-avatar" src="{{pm.avatar_url || '/images/default-avatar.svg'}}" mode="aspectFill"/>
                  <view class="audit-info">
                    <view class="audit-name-row">
                      <text class="audit-name">{{pm.nick_name || pm.nickname || '未知'}}</text>
                      <view class="audit-tag">
                        <text class="audit-tag-text">待审核</text>
                      </view>
                    </view>
                    <view class="audit-phone-line" wx:if="{{pm.wechat_phone_display || pm.reserve_phone_display}}">
                      <text class="audit-phone-item" wx:if="{{pm.wechat_phone_display}}"><text class="audit-phone-label">微信</text>{{pm.wechat_phone_display}}</text>
                      <text class="audit-phone-item" wx:if="{{pm.reserve_phone_display}}"><text class="audit-phone-label">预留</text>{{pm.reserve_phone_display}}</text>
                    </view>
                    <text class="audit-phone" wx:if="{{!pm.wechat_phone_display && !pm.reserve_phone_display}}">未绑定手机号</text>
                    <text class="audit-date">申请时间 {{pm.created_at_formatted}}</text>
                    <text class="audit-store" wx:if="{{pm.store_name}}">用户选择门店：{{pm.store_name}}</text>
                  </view>
                </view>
                <view class="audit-actions">
                  <view class="audit-btn audit-btn-delete" data-id="{{pm._id}}" data-name="{{pm.nick_name || pm.nickname}}" bindtap="onAuditDelete">
                    <text class="audit-btn-text">删除</text>
                  </view>
                  <view class="audit-btn audit-btn-reject" data-id="{{pm._id}}" data-name="{{pm.nick_name || pm.nickname}}" bindtap="onAuditReject">
                    <text class="audit-btn-text">拒绝</text>
                  </view>
                  <view class="audit-btn audit-btn-approve" data-id="{{pm._id}}" data-name="{{pm.nick_name || pm.nickname}}" data-store-id="{{pm.store_id_val}}" bindtap="onAuditApprove">
                    <text class="audit-btn-text">通过</text>
                  </view>
                </view>
              </view>
              <view class="empty-modal" wx:if="{{!auditLoading && pendingMembers.length === 0}}">
                <text>暂无待审核用户</text>
              </view>
            </block>
            <!-- 课程卡片：今日课程 / 近期课程 -->
            <block wx:elif="{{item.type === 'schedule'}}">
              <view class="empty-modal" wx:if="{{scheduleList.length === 0}}">
                <text>暂无数据</text>
              </view>
              <view class="course-card {{sch.status}}" wx:for="{{scheduleList}}" wx:key="_id" wx:for-item="sch" data-schedule-id="{{sch._id}}" bindtap="onScheduleCardTap">
                <view class="card-main">
                  <view class="card-left">
                    <view class="card-name-row">
                      <text class="card-name">{{sch.course_name}}</text>
                      <text class="card-store-inline" wx:if="{{sch.store_name}}">{{sch.store_name}}</text>
                    </view>
                    <view class="card-meta">
                      <view class="card-meta-line">
                        <text class="card-date" wx:if="{{sch.date_display}}">{{sch.date_display}} {{sch.weekday_display}}</text>
                        <text class="card-time">{{sch.start_time}} - {{sch.end_time}}</text>
                      </view>
                      <text class="card-coach" wx:if="{{sch.coach_name}}">教练：{{sch.coach_name}}</text>
                    </view>
                  </view>
                  <view class="card-right">
                    <view class="schedule-status {{sch.status}}">
                      <text>{{sch.statusText}}</text>
                    </view>
                    <text class="card-progress-text" wx:if="{{sch.status !== 'cancelled' && sch.status !== 'offline'}}">{{sch.bookedCount}}/{{sch.capacity}} 已预约</text>
                  </view>
                </view>
                <view class="card-stats" wx:if="{{sch.status !== 'cancelled' && sch.status !== 'offline'}}">
                  <view class="stat-item">
                    <text class="stat-num stat-booked">{{sch.bookedCount}}</text>
                    <text class="stat-label">已预约</text>
                  </view>
                  <view class="stat-item">
                    <text class="stat-num stat-checked">{{sch.checkedInCount}}</text>
                    <text class="stat-label">已签到</text>
                  </view>
                  <view class="stat-item">
                    <text class="stat-num stat-cancelled">{{sch.cancelledCount}}</text>
                    <text class="stat-label">已取消</text>
                  </view>
                  <view class="stat-item">
                    <text class="stat-num stat-exempted">{{sch.exemptedCount}}</text>
                    <text class="stat-label">已豁免</text>
                  </view>
                </view>
              </view>
            </block>
            <!-- 会员卡片：次卡跟进 / 时间卡到期 -->
            <block wx:else>
              <view class="empty-modal" wx:if="{{detailList.length === 0}}">
                <text>暂无数据</text>
              </view>
              <view class="member-card" wx:for="{{detailList}}" wx:key="_id" wx:for-item="member" data-member-id="{{member.member_id}}" bindtap="onMemberCardTap">
                <view class="mc-avatar">
                  <image wx:if="{{member.avatar_url}}" class="mc-avatar-img" src="{{member.avatar_url}}" mode="aspectFill"/>
                  <text wx:else class="mc-avatar-text">{{member.avatar_char}}</text>
                </view>
                <view class="mc-info">
                  <text class="mc-name">{{member.user_name}}</text>
                  <text class="mc-phone" wx:if="{{member.phone}}">{{member.phone}}</text>
                  <view class="mc-detail-row" wx:if="{{member.package_name}}">
                    <text class="mc-detail-label">套餐：</text>
                    <text class="mc-detail-value">{{member.package_name}}</text>
                  </view>
                  <view class="mc-detail-row" wx:if="{{member.store_name}}">
                    <text class="mc-detail-label">门店：</text>
                    <text class="mc-detail-value">{{member.store_name}}</text>
                  </view>
                </view>
                <view class="mc-status">
                  <block wx:if="{{member.remaining > 0}}">
                    <view class="mc-remaining">
                      <text class="mc-rem-num">{{member.remaining}}</text>
                      <text class="mc-rem-unit">次</text>
                    </view>
                  </block>
                  <text class="mc-days" wx:if="{{member.days_left > 0}}">剩{{member.days_left}}天</text>
                  <text class="mc-days mc-days-empty" wx:if="{{member.days_left === 0 && member.remaining === 0}}">已过期</text>
                </view>
              </view>
            </block>
          </block>
        </view>
      </block>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无待办事项</text>
    </view>
  </view>

  <view class="bnav">
    <view class="bnav-item" bindtap="onGoToSchedule">
      <text class="bnav-icon">◷</text>
      <text class="bnav-label">排课</text>
    </view>
    <view class="bnav-item bnav-scan" bindtap="onScanSignIn">
      <text class="bnav-icon bnav-scan-icon">◎</text>
      <text class="bnav-label bnav-scan-label">扫码签到</text>
    </view>
    <view class="bnav-item" bindtap="onGoToBookings">
      <text class="bnav-icon">☰</text>
      <text class="bnav-label">预约记录</text>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showStoreModal}}" bindtap="onCloseStoreModal">
    <view class="store-modal" catchtap="">
      <view class="stm-hd">
        <text class="stm-title">选择门店</text>
      </view>
      <scroll-view class="stm-list" scroll-y>
        <view class="stm-item {{currentStoreIndex === index ? 'stm-active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-index="{{index}}" bindtap="onSelectStore">
          <text class="stm-name">{{item.name}}</text>
          <view class="stm-check" wx:if="{{currentStoreIndex === index}}"></view>
        </view>
      </scroll-view>
      <view class="stm-bottom">
        <view class="stm-close-btn" bindtap="onCloseStoreModal">关闭</view>
      </view>
    </view>
  </view>

  <!-- 会员审核-门店选择弹窗 -->
  <view class="modal-mask" wx:if="{{showAuditStoreModal}}" bindtap="onAuditCloseModal">
    <view class="audit-store-modal" catchtap="onAuditModalTap">
      <view class="audit-stm-header">
        <text class="audit-stm-title">分配门店</text>
        <text class="audit-stm-subtitle">为 {{auditApproveMember.name || '该用户'}} 选择门店</text>
        <text class="audit-stm-close" bindtap="onAuditCloseModal">✕</text>
      </view>
      <scroll-view class="audit-stm-list" scroll-y>
        <view class="audit-stm-item {{auditSelectedStoreId === item._id ? 'audit-stm-active' : ''}}"
              wx:for="{{auditStoreList}}" wx:key="_id"
              data-id="{{item._id}}"
              bindtap="onAuditStoreSelect">
          <text>{{item.name}}</text>
        </view>
      </scroll-view>
      <view class="audit-stm-confirm {{auditSelectedStoreId ? '' : 'disabled'}}" bindtap="onAuditConfirmApprove">确认通过</view>
    </view>
  </view>
</view>
