.checkin-page {
  padding: 20rpx;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page-header {
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.top-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.schedule-scroll {
  flex: 1;
  white-space: nowrap;
}

.schedule-item {
  display: inline-flex;
  flex-direction: column;
  padding: 16rpx 24rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: 10rpx;
  margin-right: 12rpx;
  min-width: 160rpx;
  border: 2rpx solid transparent;
  transition: all var(--transition-normal);
}

.schedule-item.active {
  background-color: var(--color-primary-bg);
  border-color: rgba(197, 116, 75, 0.4);
}

.schedule-time {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.schedule-name {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-top: 4rpx;
}

.schedule-coach {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 2rpx;
}

.bottom-scan-btn {
  position: fixed;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  height: 96rpx;
  background: var(--color-primary);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(197, 116, 75, 0.4);
  z-index: 999;
}

.bottom-scan-btn:active {
  background: var(--color-primary);
  transform: scale(0.98);
}

.scan-icon {
  font-size: 40rpx;
}

.scan-text {
  font-size: 32rpx;
  color: var(--bg-card);
  font-weight: 700;
}

.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  flex: 1;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: 10rpx;
  padding: 0 20rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: var(--color-primary-bg);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--color-primary);
}

.stats-bar {
  display: flex;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.stat-item.checked .stat-num { color: var(--color-success); }
.stat-item.pending .stat-num { color: var(--color-primary); }

.record-list {
  max-height: calc(100vh - 420rpx);
}

.record-card {
  margin-bottom: 12rpx;
  padding: 0;
  overflow: hidden;
}

.record-main {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.record-avatar.pending {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
}

.record-avatar.checked {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.record-avatar.onsite {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.record-avatar.cancelled {
  background-color: rgba(44, 36, 22, 0.04);
  color: var(--text-tertiary);
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.record-nick {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.source-tag {
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.source-tag.checked {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.source-tag.onsite {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.record-phone {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.record-status.pending {
  color: var(--color-primary);
  background-color: var(--color-primary-bg);
}

.record-status.checked {
  color: var(--color-success);
  background-color: var(--color-success-bg);
}

.record-status.onsite {
  color: var(--color-warning);
  background-color: var(--color-warning-bg);
}

.record-status.cancelled {
  color: var(--text-secondary);
  background-color: rgba(44, 36, 22, 0.04);
}

.record-arrow {
  font-size: 20rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.record-detail {
  padding: 0 24rpx 24rpx 24rpx;
  border-top: 1rpx solid var(--border);
  margin-top: 0;
  padding-top: 20rpx;
}

.detail-section-title {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.detail-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 24rpx;
  color: var(--text-primary);
}

.load-profile-btn {
  margin-top: 16rpx;
  padding: 14rpx;
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 24rpx;
  border-radius: var(--radius-sm);
  text-align: center;
  border: none;
}

.empty-state {
  padding: 80rpx 20rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(44, 36, 22, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.profile-modal {
  width: 660rpx;
  max-height: 85vh;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  overflow-y: auto;
}

.modal-warning {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background-color: var(--color-warning-bg);
  border: 1rpx solid rgba(196, 102, 62, 0.3);
  border-radius: var(--radius-sm);
  margin-bottom: 20rpx;
}

.warning-icon { font-size: 32rpx; }
.warning-text { font-size: 26rpx; color: var(--color-warning); flex: 1; }

.profile-section {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.profile-section:last-of-type {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.profile-member {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: var(--color-primary);
  flex-shrink: 0;
}

.profile-member-info {
  flex: 1;
}

.profile-member-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.profile-member-code,
.profile-member-phone,
.profile-member-store {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.pkg-item {
  padding: 14rpx 16rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: var(--radius-sm);
  margin-bottom: 10rpx;
}

.pkg-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.pkg-name { font-size: 26rpx; color: var(--text-primary); }
.pkg-type { font-size: 22rpx; color: var(--color-primary); padding: 2rpx 10rpx; background-color: var(--color-primary-light); border-radius: 4rpx; }
.pkg-detail { font-size: 22rpx; color: var(--text-secondary); }

.no-pkg-text {
  font-size: 24rpx;
  color: var(--color-danger);
}

.booking-check-item {
  display: flex;
  align-items: center;
  padding: 14rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
  gap: 14rpx;
}

.booking-check-item.checked {
  background-color: var(--color-primary-light);
}

.check-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--text-tertiary);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--bg-card);
  flex-shrink: 0;
}

.check-box.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.booking-check-info {
  flex: 1;
}

.booking-check-time {
  font-size: 26rpx;
  color: var(--color-primary);
  display: block;
}

.booking-check-course {
  font-size: 24rpx;
  color: var(--text-primary);
  display: block;
  margin-top: 2rpx;
}

.booking-check-coach {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 2rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
}

.btn-confirm {
  flex: 1;
  padding: 20rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 28rpx;
  color: var(--bg-card);
  font-weight: 500;
}

.btn-confirm.onsite {
  background-color: var(--color-warning);
  color: var(--bg-card);
}

.onsite-confirm-modal {
  width: 560rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
}

.onsite-confirm-icon { font-size: 56rpx; margin-bottom: 16rpx; }

.onsite-confirm-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-warning);
  display: block;
  margin-bottom: 12rpx;
}

.onsite-confirm-desc {
  font-size: 26rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.onsite-confirm-steps {
  text-align: left;
  padding: 16rpx 24rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}

.onsite-confirm-steps text {
  font-size: 26rpx;
  color: var(--text-primary);
  display: block;
  padding: 6rpx 0;
}

.onsite-confirm-info {
  text-align: left;
  padding: 12rpx 16rpx;
  background-color: rgba(44, 36, 22, 0.04);
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
}

.onsite-confirm-info text {
  font-size: 24rpx;
  color: var(--text-secondary);
}