.salary-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.tab-bar {
  display: flex;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all var(--transition-normal);
}

.tab-item.active {
  background: var(--color-primary);
  color: var(--text-inverse);
  font-weight: bold;
}

.tab-content {
  min-height: 400rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.add-btn {
  padding: 12rpx 24rpx;
  background: var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  color: var(--bg-card);
  font-weight: bold;
  transition: background var(--transition-fast);
}

.config-list {
  display: flex;
  flex-direction: column;
}

.config-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.config-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.config-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.config-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-active {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.status-inactive {
  background-color: var(--color-completed-bg);
  color: var(--color-completed);
}

.config-body {
  padding-bottom: 16rpx;
}

.config-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-input);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-md);
}

.config-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.config-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.config-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
}

.action-btn.edit {
  background-color: var(--bg-input);
  color: var(--color-primary);
}

.action-btn.delete {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.summary-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
}

.summary-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.date-range-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  box-shadow: var(--shadow-card);
}

.date-item {
  flex: 1;
  min-width: 200rpx;
}

.date-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.date-picker {
  height: 72rpx;
  background-color: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
}

.date-separator {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 0 8rpx;
}

.generate-btn {
  padding: 16rpx 24rpx;
  background: var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  color: var(--bg-card);
  font-weight: bold;
  white-space: nowrap;
  transition: background var(--transition-fast);
}

.stats-list {
  display: flex;
  flex-direction: column;
}

.stats-item {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.stats-coach {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.stats-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-settled {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.status-pending {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-cancelled {
  background-color: var(--color-completed-bg);
  color: var(--color-completed);
}

.stats-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.stats-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.stats-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.stats-value.highlight {
  color: var(--color-primary);
  font-weight: 700;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
}

.load-more {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.text-heading {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 700;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 36, 22, 0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 200ms ease-out;
}

.modal-content {
  width: min(90%, 600rpx);
  max-height: 80vh;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-modal);
  animation: modalPopIn 280ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}

.modal-title {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 700;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: var(--radius-full);
  background: var(--bg-elevated);
  transition: all var(--transition-fast);
}

.modal-close:active {
  background: var(--border);
  transform: scale(0.9);
}

.modal-body {
  padding: 24rpx 28rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx 28rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-md);
  text-align: center;
  font-size: var(--font-md);
  font-weight: 600;
  transition: all var(--transition-fast);
}

.modal-btn:active { transform: scale(0.96); }

.modal-btn.cancel {
  background: var(--bg-elevated);
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: var(--text-inverse);
  box-shadow: var(--shadow-fab);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.add-item-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 500;
}

.form-picker {
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
  color: var(--text-primary);
}

.form-picker.small {
  padding: 16rpx 20rpx;
  font-size: var(--font-sm);
}

.form-input {
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
  color: var(--text-primary);
}

.form-input.small {
  padding: 16rpx 20rpx;
  font-size: var(--font-sm);
  min-width: 0;
  flex: 1;
}

.config-items-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.config-item-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.divider {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.unit {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  white-space: nowrap;
}

.item-right {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.remove-icon {
  font-size: 24rpx;
  color: var(--color-danger);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.detail-row:last-child { border-bottom: none; }

.detail-row.total {
  padding-top: 20rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid var(--border);
  border-bottom: none;
}

.detail-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.detail-value {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.detail-value.text-green { color: var(--color-success); }
.detail-value.text-red { color: var(--color-danger); }
.detail-value.text-orange { color: var(--color-warning); }

.bill-summary {
  display: flex;
  flex-direction: column;
}

.bill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-light);
  margin-bottom: 20rpx;
}

.bill-title {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.bill-date {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.bill-coaches {
  margin-bottom: 24rpx;
}

.bill-coach-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.coach-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.coach-total {
  font-size: var(--font-md);
  color: var(--color-primary);
  font-weight: 700;
}

.bill-items {
  margin-bottom: 12rpx;
}

.bill-item-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.bill-item-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.bill-item-value {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 600;
}

.bill-item-rate {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  padding: 4rpx 0 8rpx 0;
}

.bill-total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid var(--border);
}

.bill-total-label {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.bill-total-value {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 800;
}

.bill-warning {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-warning-bg);
  border-radius: var(--radius-md);
  margin-top: 20rpx;
  border: 1rpx solid rgba(196, 102, 62, 0.2);
}

.warning-icon {
  font-size: var(--font-md);
  flex-shrink: 0;
}

.warning-text {
  font-size: var(--font-sm);
  color: var(--color-warning);
  line-height: 1.5;
}