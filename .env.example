# ============================================
# 舞栖DANCE 后端环境配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/wuqi_dance
JWT_SECRET=请在此填入一个随机生成的复杂密钥
JWT_EXPIRES_IN=7d

# 微信小程序 - 会员端（舞栖DANCE）
# 从微信公众平台获取: https://mp.weixin.qq.com
WX_MEMBER_APPID=wxeb3b664ce36208ba
WX_MEMBER_SECRET=请在此填入会员端AppSecret

# 微信小程序 - 管理端（舞栖DANCE预约系统管理）
# 从微信公众平台获取: https://mp.weixin.qq.com
WX_ADMIN_APPID=wx3f52761ae85bd5e7
WX_ADMIN_SECRET=请在此填入管理端AppSecret

# 腾讯云COS配置（可选，用于上传文件存储）
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your_bucket
COS_REGION=ap-guangzhou