.vp-page {
  min-height: 100vh;
  background: #000000;
}

.vp-video {
  width: 100%;
  height: 420rpx;
  background: #000000;
}

.vp-info {
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  margin-top: -10rpx;
  position: relative;
  z-index: 1;
}

.vp-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2122;
  display: block;
  margin-bottom: 12rpx;
}

.vp-coach {
  font-size: 26rpx;
  color: #6B5D5E;
  display: block;
}