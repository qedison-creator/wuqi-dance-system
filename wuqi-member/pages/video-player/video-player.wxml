<view class="vp-page">
  <video
    id="videoPlayer"
    class="vp-video"
    src="{{videoUrl}}"
    poster="{{coverUrl}}"
    controls
    show-center-play-btn
    enable-progress-gesture
    binderror="onVideoError"
  >
  </video>

  <view class="vp-info">
    <view class="loading-area" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
    <block wx:else>
      <text class="vp-title">{{title}}</text>
      <text class="vp-coach">教练：{{coachName}}</text>
    </block>
  </view>
</view>