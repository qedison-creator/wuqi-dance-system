<wxs src="../../utils/date-format.wxs" module="df" />
<wxs src="../../utils/dance-colors.wxs" module="dc" />

<view class="booking-page">
    <view class="header-section">
      <view class="store-card" bindtap="onStoreTap">
        <view class="store-card-left">
          <view class="store-icon-wrap">
            <view class="store-icon-shape"></view>
          </view>
          <view class="store-info">
            <text class="store-name">{{currentStore.name || '选择门店'}}</text>
          </view>
        </view>
        <view class="store-arrow-wrap">
          <view class="store-arrow"></view>
        </view>
      </view>
    </view>

    <view class="section-header">
      <view class="section-title-row">
        <view class="section-dot"></view>
        <text class="section-title">{{sectionTitle}}</text>
      </view>
    </view>

    <view class="holiday-notice" wx:if="{{isHolidayToday && holidays.length > 0}}">
      <view class="holiday-notice-icon"></view>
      <text class="holiday-notice-text">放假期间无课程安排</text>
    </view>

    <view class="date-section">
      <view class="date-scroll">
        <view class="date-scroll-inner">
          <block wx:for="{{weekDays}}" wx:key="date">
            <view class="date-item {{selectedDate === item.date ? 'active' : ''}}" data-date="{{item.date}}" data-index="{{index}}" bindtap="onSelectDate">
              <text class="date-md">{{df.formatMD(item.date)}}</text>
              <text class="date-wd">{{item.displayDay}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>



    <scroll-view class="course-list-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:if="{{courses.length > 0}}">
      <view class="course-card" wx:for="{{courses}}" wx:key="_id" bindtap="onCourseTap" data-course="{{item}}">
        <view class="course-accent-bar" style="background: {{dc.getBarColor(index)}};"></view>
        <view class="card-left">
          <image class="coach-avatar" src="{{item.r.coachAvatar}}" mode="aspectFill" wx:if="{{item.r.coachAvatar && !imageErrors['coach_' + item._id]}}" binderror="onCoachImgError" data-id="{{item._id}}" />
          <image class="coach-avatar" src="/images/default-avatar.svg" mode="aspectFill" wx:else />
          <text class="coach-name-below">{{item.r.coachName}}</text>
        </view>
        <view class="card-right">
          <view class="card-right-actions">
            <view class="course-book-btn {{item.r.bookBtnClass}}" data-course="{{item}}" catchtap="onBookCourse">
              <text>{{item.r.bookBtnText}}</text>
            </view>
            <view class="course-book-btn waitlist-btn" wx:if="{{item.r.showWaitlistBtn}}" data-course="{{item}}" data-action="waitlist" catchtap="onBookCourse">
              <text>加入候补</text>
            </view>
          </view>
          <view class="course-time-row">
            <text class="course-time" wx:if="{{item.r.showTime}}">{{item.r.time}}</text>
            <text class="course-time" wx:else>??:?? - ??:??</text>
            <text class="min-capacity-text" wx:if="{{item.r.showMinCapacity}}">{{item.r.minCapacity}}</text>
            <text class="min-capacity-text" wx:else>最低?人成班</text>
          </view>
          <text class="course-title">{{item.course_name || '课程名称'}}</text>
          <view class="course-tag-row">
            <view class="course-tag" wx:if="{{item.r.danceStyle}}" style="background: {{item.r.danceTagBg}}; color: {{item.r.danceTagText}}">{{item.r.danceStyle}}</view>
          </view>
          <text class="course-room" wx:if="{{item.r.showRoom}}">{{item.r.room}}</text>
          <view class="course-deadline-row" wx:if="{{item.r.showDeadline}}">
            <text class="deadline-text">截止预约：{{item.r.deadlineText}}</text>
            <text class="deadline-text deadline-cancel">截止取消：{{item.r.cancelDeadlineText}}</text>
          </view>
          <view class="card-meta-row">
            <view class="card-stats">
              <text class="capacity-text {{item.r.capacityLocked ? 'capacity-locked' : ''}}">{{item.r.capacity}}</text>
            </view>
            <view class="booked-avatars" wx:if="{{item.r.showAvatars}}">
              <block wx:for="{{item.r.avatarList}}" wx:for-item="user" wx:for-index="ui" wx:key="user_id">
                <image class="booked-avatar" src="{{user.avatar_url}}" mode="aspectFill" style="z-index: {{ui + 1}};" lazy-load />
              </block>
              <view class="booked-more" wx:if="{{item.r.avatarMore > 0}}">
                <text>+{{item.r.avatarMore}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="list-bottom-safe"></view>
      <view class="booking-disclaimer">成人零基础・舞蹈健身服务</view>
    </scroll-view>

    <!-- 加载状态提示 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载课程中...</text>
    </view>
    
    <empty-state
      wx:if="{{courses.length === 0 && !loading}}"
      text="暂无场次安排"
      hint="试试切换门店或日期">
    </empty-state>
    <view class="booking-disclaimer" wx:if="{{courses.length === 0 && !loading}}">成人零基础・舞蹈健身服务</view>
</view>

<view class="modal-mask" wx:if="{{showStoreModal}}" bindtap="onCloseStoreModal">
  <view class="modal-content" catchtap="onModalTap">
    <view class="modal-title-text">选择门店</view>
    <view class="modal-subtitle">切换门店后将重新加载课程</view>
    <view class="store-list">
      <view class="store-opt {{currentStore && currentStore._id === item._id ? 'active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-store="{{item}}" bindtap="onSelectStore">
        <view class="store-opt-left">
          <text class="store-opt-name">{{item.name}}</text>
          <text class="store-opt-addr" wx:if="{{item.address}}">{{item.address}}</text>
        </view>
        <view class="store-opt-check" wx:if="{{currentStore && currentStore._id === item._id}}"></view>
      </view>
    </view>
    <view class="modal-close-btn" bindtap="onCloseStoreModal">关闭</view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showBookingModal}}" bindtap="onCancelBookingModal">
  <view class="modal-content modal-confirm" catchtap="onModalTap">
    <view class="booking-confirm-icon-wrap">
      <view class="booking-confirm-icon"></view>
    </view>
    <view class="modal-title-text">确认预约</view>
    <text class="modal-body-text">{{bookingModalText}}</text>
    <view class="modal-actions">
      <view class="modal-btn-outline" bindtap="onCancelBookingModal">取消</view>
      <view class="modal-btn-primary" bindtap="onConfirmBookingModal">确认预约</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showActivateModal}}" bindtap="onCloseActivateModal">
  <view class="modal-content modal-confirm" catchtap="onModalTap">
    <view class="booking-confirm-icon-wrap activate-icon-wrap">
      <view class="activate-icon"></view>
    </view>
    <view class="modal-title-text">套餐激活提醒</view>
    <view class="modal-body-text">您有待激活的套餐，激活后即可预约课程。</view>
    <view class="modal-actions">
      <view class="modal-btn-outline" bindtap="onCancelActivate">暂不激活</view>
      <view class="modal-btn-primary" bindtap="onConfirmActivate">立即激活</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showLimitModal}}" bindtap="onCloseLimitModal">
  <view class="modal-content modal-confirm" catchtap="onModalTap">
    <view class="booking-confirm-icon-wrap limit-icon-wrap">
      <view class="limit-icon"></view>
    </view>
    <view class="modal-title-text">预约提醒</view>
    <view class="modal-body-text">{{limitModalText}}</view>
    <view class="modal-actions modal-actions-single">
      <view class="modal-btn-primary" bindtap="onCloseLimitModal">好的</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showWaitlistModal}}" bindtap="onCancelWaitlist">
  <view class="modal-content modal-confirm" catchtap="onModalTap">
    <view class="booking-confirm-icon-wrap waitlist-icon-wrap">
      <view class="waitlist-icon"></view>
    </view>
    <view class="modal-title-text">加入候补队列</view>
    <text class="modal-body-text">{{waitlistModalText}}</text>
    <view class="modal-actions">
      <view class="modal-btn-outline" bindtap="onCancelWaitlist">取消</view>
      <view class="modal-btn-primary" bindtap="onConfirmWaitlist">确认候补</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showStorePicker}}" bindtap="onCloseStorePicker">
  <view class="modal-content" catchtap="onModalTap">
    <view class="modal-title-text">{{storePickerTitle}}</view>
    <view class="store-list">
      <view class="store-opt {{selectedStoreId === item._id ? 'active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onStoreSelect">
        <text class="store-opt-name">{{item.name}}</text>
        <text class="store-opt-dist" wx:if="{{item.distance !== undefined}}">{{item.distance}}km</text>
      </view>
    </view>
    <view class="btn-primary" bindtap="onStoreConfirm" disabled="{{!selectedStoreId}}">确认</view>
  </view>
</view>

<!-- 时间卡限额已满，确认激活次卡弹窗 -->
<view class="modal-mask" wx:if="{{showCountCardModal}}" bindtap="onCloseCountCardModal">
  <view class="modal-content modal-confirm" catchtap="onModalTap">
    <view class="booking-confirm-icon-wrap countcard-icon-wrap">
      <view class="countcard-icon"></view>
    </view>
    <view class="modal-title-text">时间卡次数已用完</view>
    <view class="modal-body-text">{{countCardModalText}}</view>
    <view class="modal-actions">
      <view class="modal-btn-outline" bindtap="onCancelCountCard">取消</view>
      <view class="modal-btn-primary" bindtap="onConfirmCountCard">激活并预约</view>
    </view>
  </view>
</view>

<!-- 微信授权登录弹窗 -->
<login-modal visible="{{showLoginModal}}" bind:close="onLoginModalClose" bind:success="onLoginSuccess"></login-modal>
