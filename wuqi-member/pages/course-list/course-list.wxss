.cl-page {
  padding: 0 28rpx 200rpx;
  min-height: 100vh;
  background: #FBFAF8;
  box-sizing: border-box;
}

.cl-scroll {
  height: calc(100vh - 80rpx);
}

.course-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 24rpx rgba(42, 33, 34, 0.06);
  transition: all 150ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.course-card:active {
  transform: scale(0.97);
}

.course-thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #FDF2EF;
}

.course-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.course-tag-wrap {
  margin-bottom: 8rpx;
}

.course-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2A2122;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.course-schedule {
  font-size: 24rpx;
  color: #6B5D5E;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.course-teacher {
  font-size: 24rpx;
  color: #6B5D5E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.course-capacity {
  font-size: 22rpx;
  color: #948284;
  flex-shrink: 0;
}