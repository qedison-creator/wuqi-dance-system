<view class="cl-page">
  <view class="section-header">
    <view class="section-title-wrap">
      <view class="section-dot"></view>
      <text class="section-title">近期课程</text>
    </view>
  </view>

  <scroll-view
    class="cl-scroll"
    scroll-y
    wx:if="{{courses.length > 0}}"
  >
    <view
      class="course-card"
      wx:for="{{courses}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onCourseTap"
    >
      <image
        class="course-thumb"
        src="{{imageErrors['course_'+item._id] ? '/images/default-course.svg' : (item.cover || item.cover_url || '/images/default-course.svg')}}"
        binderror="onImgError"
        data-type="course"
        data-id="{{item._id}}"
        mode="aspectFill"
      />
      <view class="course-info">
        <view class="course-tag-wrap">
          <text class="tag tag-rose">{{item.dance_style_name || item.dance_style_id && item.dance_style_id.name || '舞蹈'}}</text>
        </view>
        <text class="course-name">{{item.course_name || item.name || '课程名称'}}</text>
        <view class="course-schedule">
          <text>{{item.schedule_day || item.day || ''}} {{item.start_time || ''}}{{item.end_time ? ' - ' + item.end_time : ''}}</text>
        </view>
        <view class="course-bottom">
          <text class="course-teacher">{{item.coach_name || item.coach_id && item.coach_id.name || '教练'}}</text>
          <text class="course-capacity">{{item.current_bookings || 0}}/{{item.max_bookings || item.capacity || 20}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <empty-state 
    wx:if="{{!loading && courses.length === 0}}" 
    text="暂无课程" 
    hint="下拉刷新试试">
  </empty-state>

  <view class="loading-area" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>