<view class="page">
  <view class="tab-bar">
    <view class="tb-item {{activeTab === 'booking' ? 'active' : ''}}" data-tab="booking" bindtap="onTabChange">
      <text>预约记录</text>
    </view>
    <view class="tb-item {{activeTab === 'waitlist' ? 'active' : ''}}" data-tab="waitlist" bindtap="onTabChange">
      <text>排队轮候</text>
    </view>
    <view class="tb-item {{activeTab === 'class' ? 'active' : ''}}" data-tab="class" bindtap="onTabChange">
      <text>上课记录</text>
    </view>
    <view class="tb-slider {{activeTab === 'waitlist' ? 'mid' : (activeTab === 'class' ? 'right' : '')}}"></view>
  </view>

  <scroll-view class="filter-bar" scroll-x wx:if="{{activeTab !== 'waitlist'}}">
    <view class="fb-item {{item.active ? 'active' : ''}}" wx:for="{{filters}}" wx:key="value" data-value="{{item.value}}" bindtap="onFilterChange">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <view class="record-list" wx:if="{{records.length > 0}}">
    <view class="r-card" wx:for="{{records}}" wx:key="_id">
      <view class="rc-left-line {{activeTab === 'waitlist' ? 'waitlist' : item.status}}"></view>
      <view class="rc-body">
        <view class="rc-top">
          <text class="rc-name">{{item.courseName || '课程名称'}}</text>
          <block wx:if="{{activeTab === 'class'}}">
            <view class="rc-source method-{{item.checkInMethod || item.source}}">{{item.sourceLabel}}</view>
          </block>
          <block wx:elif="{{activeTab === 'waitlist'}}">
            <view class="rc-position-tag">
              <text>排队 {{item.position}}</text>
            </view>
          </block>
          <block wx:else>
            <view class="rc-status {{item.status}}">
              <text>{{item.status === 'completed' ? '已完成' : (item.status === 'cancelled' ? '已取消' : '待上课')}}</text>
            </view>
          </block>
        </view>
        <view class="rc-info">
          <view class="rci-row">
            <view class="rci-icon date"></view>
            <text class="rci-text">{{item.dateStr}} {{item.weekDayStr}}</text>
          </view>
          <view class="rci-row">
            <view class="rci-icon time"></view>
            <text class="rci-text">{{item.startTime}} - {{item.endTime}}</text>
          </view>
          <view class="rci-row" wx:if="{{activeTab === 'class' && item.checkInTime}}">
            <view class="rci-icon checkin"></view>
            <text class="rci-text highlight">签到时间 {{item.checkInTime}}</text>
          </view>
          <view class="rci-row">
            <view class="rci-icon coach"></view>
            <text class="rci-text">{{item.coachName || '教练'}}</text>
          </view>
          <view class="rci-row">
            <view class="rci-icon store"></view>
            <text class="rci-text">{{item.storeName || '门店'}}</text>
          </view>
          <view class="rci-row" wx:if="{{activeTab === 'class' && item.creditsCost > 0}}">
            <view class="rci-icon credit"></view>
            <text class="rci-text highlight">消耗 {{item.creditsCost}} 课时</text>
          </view>
        </view>
        <view class="rc-cancel-reason" wx:if="{{activeTab === 'booking' && item.status === 'cancelled' && item.cancelReason}}">
          <view class="rcr-tag"></view>
          <text class="rcr-text">{{item.cancelReason}}</text>
        </view>
      </view>
      <view class="rca-btn cancel" wx:if="{{activeTab === 'waitlist'}}" data-id="{{item._id}}" catchtap="onCancelWaitlistTap">取消</view>
    </view>
  </view>

  <empty-state 
    wx:if="{{!loading && records.length === 0}}" 
    text="{{activeTab === 'waitlist' ? '暂无排队轮候' : '暂无记录'}}" 
    hint="{{activeTab !== 'waitlist' ? '快去预约喜欢的课程吧' : ''}}">
  </empty-state>

  <view class="load-more" wx:if="{{records.length > 0 && !hasMore}}">
    <view class="lm-line"></view>
    <text>没有更多了</text>
    <view class="lm-line"></view>
  </view>

  <view class="load-more loading" wx:if="{{loading}}">
    <view class="loading-spinner-sm"></view>
    <text>加载中...</text>
  </view>
</view>