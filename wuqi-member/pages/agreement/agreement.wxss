.page {
  min-height: 100vh;
  background: #FBFAF8;
  padding: 32rpx 28rpx 60rpx;
  box-sizing: border-box;
}

.privacy-section {
  padding-bottom: 40rpx;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A2122;
  text-align: center;
  padding: 20rpx 0 12rpx;
}

.privacy-date {
  font-size: 24rpx;
  color: #B5A5A5;
  text-align: center;
  line-height: 1.6;
}

.privacy-heading {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2122;
  margin-top: 40rpx;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #D4786E;
}

.privacy-subheading {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3F3F;
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.privacy-text {
  font-size: 26rpx;
  color: #5A4F4F;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.privacy-text text {
  display: inline;
}
