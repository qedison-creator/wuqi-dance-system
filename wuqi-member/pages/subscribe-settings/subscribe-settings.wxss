.subscribe-settings {
  padding-bottom: 40rpx;
}

.page {
  min-height: 100vh;
  background: #F6F3F0;
  padding-bottom: 60rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.header-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #FFF0ED;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.header-icon-text {
  font-size: 48rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.settings-section {
  margin: 0 24rpx 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.settings-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
}

.setting-info {
  flex: 1;
  margin-right: 24rpx;
}

.setting-name {
  font-size: 30rpx;
  color: #2D2D2D;
  display: block;
  margin-bottom: 8rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.setting-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.setting-status {
  font-size: 26rpx;
  color: #D4786E;
  margin-right: 12rpx;
}

.setting-status.subscribed {
  color: #52C41A;
}

.setting-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #ccc;
  border-right: 3rpx solid #ccc;
  transform: rotate(45deg);
}

.setting-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 32rpx;
}

.tips-section {
  margin: 32rpx 40rpx 0;
  display: flex;
  align-items: flex-start;
  background: #FFF9F0;
  padding: 24rpx;
  border-radius: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
