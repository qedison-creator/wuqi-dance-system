.splash-container {
  width: 100%;
  height: 100vh;
  background: #121212;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.logo-wrapper {
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.4s ease-out, transform 0.4s ease-out;
}

.logo-wrapper.logo-show {
  opacity: 1;
  transform: scale(1);
}

.logo-img {
  width: 100%;
  height: 100%;
}
