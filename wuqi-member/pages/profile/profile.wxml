<view class="page-scroll">
<view class="profile-page">
  <block wx:if="{{isLoggedIn}}">
    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-avatar-wrap" bindtap="onHeroAvatarTap">
          <image class="hero-avatar" src="{{avatarSrc}}" binderror="onImgError" data-type="avatar" data-id="user" mode="aspectFill" decoding="async"></image>
          <view class="hero-avatar-ring"></view>
          <view class="hero-avatar-tip" wx:if="{{isOfficialMember && (!userInfo.avatar && !userInfo.avatar_url || avatarImageError)}}">
            <text class="hero-avatar-tip-text">点击更换</text>
          </view>
        </view>
        <view class="hero-info">
          <view class="hero-name-row">
            <text class="hero-name">{{userInfo.real_name || userInfo.nickname || (isOfficialMember ? '舞栖会员' : '注册用户')}}</text>
            <view class="hero-gender male" wx:if="{{userInfo.gender === 1}}">
              <view class="hero-gender-icon-m"></view>
            </view>
            <view class="hero-gender female" wx:if="{{userInfo.gender === 2}}">
              <view class="hero-gender-icon-f"></view>
            </view>
          </view>
          <text class="hero-member-id" wx:if="{{userInfo.member_code}}">会员编号：{{userInfo.member_code}}</text>
          <text class="hero-since">加入{{memberSinceDays}}天</text>
        </view>
        <view class="hero-action" wx:if="{{userInfo.member_status === 'official'}}">
          <view class="qr-btn" bindtap="onShowQRCode">
            <view class="qr-btn-icon"></view>
            <text class="qr-btn-text">会员码</text>
          </view>
        </view>
      </view>
      <view class="hero-status-row" wx:if="{{userInfo.member_status === 'official'}}">
        <view class="status-chip {{memberStatus}}">
          <text>{{memberStatusText}}</text>
        </view>
        <text class="status-sub" wx:if="{{currentPackageType}}">当前套餐：{{currentPackageType}}</text>
      </view>
    </view>

    <view class="pending-section" wx:if="{{userInfo.member_status === 'registered'}}">
      <view class="pending-card">
        <view class="pending-icon-wrap">
          <view class="pending-icon"></view>
        </view>
        <view class="pending-text">
          <text class="pending-title">审核中</text>
          <text class="pending-desc">您的会员申请正在审核中，请耐心等待</text>
        </view>
      </view>
    </view>

    <view class="setup-guide-section" wx:if="{{userInfo.member_status === 'official' && !userInfo.info_completed && !isPreRegistered}}">
      <view class="setup-guide-card" bindtap="onGoSetup">
        <view class="setup-guide-icon-wrap">
          <view class="setup-guide-icon"></view>
        </view>
        <view class="setup-guide-text">
          <text class="setup-guide-title">审核已通过，请完善个人资料</text>
          <text class="setup-guide-desc">完善资料后即可预约课程</text>
        </view>
        <view class="setup-guide-arrow">
          <text>›</text>
        </view>
      </view>
    </view>

    <view class="stats-section" wx:if="{{userInfo.member_status === 'official'}}">
      <view class="stats-row">
        <view class="stat-card stat-clickable" bindtap="onStatTap" data-tab="booking">
          <text class="stat-num">{{stats.totalBookings}}</text>
          <text class="stat-label">待上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card stat-clickable" bindtap="onStatTap" data-tab="attendance">
          <text class="stat-num">{{stats.completedClasses}}</text>
          <text class="stat-label">已上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card">
          <text class="stat-num {{stats.remainingClasses === -1 ? 'stat-infinity' : ''}}">{{stats.remainingClasses === -1 ? '∞' : stats.remainingClasses}}</text>
          <text class="stat-label">{{stats.remainingClasses === -1 ? '不限次数' : '本周剩余'}}</text>
        </view>
      </view>
    </view>

    <view class="stats-section guest-stats" wx:if="{{userInfo.member_status !== 'official'}}">
      <view class="stats-row">
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">待上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">已上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">本周剩余</text>
        </view>
      </view>
    </view>

    <view class="package-section" wx:if="{{userInfo.member_status === 'official'}}">
      <block wx:if="{{allPackages.length > 0}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-left-bar"></view>
            <text class="section-title">我的套餐</text>
          </view>
        </view>

        <!-- 使用中套餐卡片（支持多个） -->
        <block wx:for="{{activePackages}}" wx:key="_id" wx:if="{{activePackages.length > 0}}">
        <view class="pkg-card-new {{item.status}} {{item.package_type}}" bindtap="onPackageTap" data-id="{{item._id}}">
          <view class="pkg-new-decorate-circle"></view>
          <view class="pkg-new-content">
            <view class="pkg-new-header">
              <view class="pkg-tag pkg-tag-store" wx:if="{{item._storeName}}">
                <text class="pkg-tag-text">{{item._storeName}}</text>
              </view>
              <view class="pkg-tag pkg-tag-type-{{item.package_type}}" wx:if="{{item._typeLabel}}">
                <text class="pkg-tag-text">{{item._typeLabel}}</text>
              </view>
            </view>
            <view class="pkg-new-main">
              <view class="pkg-new-main-left">
                <!-- 次卡：双列大数字 -->
                <view class="pkg-new-main-value-wrap pkg-new-dual-wrap" wx:if="{{item.package_type === 'count_card'}}">
                  <view class="pkg-new-dual-col">
                    <view class="pkg-new-dual-value-wrap">
                      <text class="pkg-new-main-value">{{item.remaining_credits || 0}}</text>
                      <text class="pkg-new-main-unit">次</text>
                    </view>
                    <text class="pkg-new-main-label">剩余次数</text>
                  </view>
                  <view class="pkg-new-dual-col">
                    <view class="pkg-new-dual-value-wrap">
                      <text class="pkg-new-main-value pkg-new-days-value">{{item.remaining_days || 0}}</text>
                      <text class="pkg-new-main-unit pkg-new-days-unit">天</text>
                    </view>
                    <text class="pkg-new-main-label">剩余天数</text>
                  </view>
                </view>
                <!-- 时间卡：单列大数字 -->
                <view class="pkg-new-main-value-wrap" wx:elif="{{item.package_type === 'time_card'}}">
                  <text class="pkg-new-main-value">{{item.remaining_days || 0}}</text>
                  <text class="pkg-new-main-unit">天</text>
                </view>
                <text class="pkg-new-main-label" wx:if="{{item.package_type === 'time_card'}}">剩余天数</text>
                <view class="pkg-new-status-dot-wrap {{item.status}} {{item.is_suspended ? 'suspended' : ''}}">
                  <view class="pkg-new-status-dot"></view>
                  <text class="pkg-new-status-label">{{item._statusText}}</text>
                </view>
              </view>
              <view class="pkg-new-main-right">
                <view class="pkg-new-info-capsule" wx:if="{{item.package_type === 'time_card'}}">
                  <text class="pkg-new-info-capsule-label">服务有效期</text>
                  <text class="pkg-new-info-capsule-value">{{item._durationText}}</text>
                </view>
                <view class="pkg-new-info-capsule" wx:if="{{item.package_type === 'count_card'}}">
                  <text class="pkg-new-info-capsule-label">{{item._totalLabel}}</text>
                  <text class="pkg-new-info-capsule-value">{{item._totalValue}}</text>
                </view>
                <view class="pkg-new-info-capsule" wx:if="{{item.package_type === 'time_card' && item._weekRemaining !== undefined}}">
                  <text class="pkg-new-info-capsule-label">{{item._periodLabel || '本周'}}剩余</text>
                  <text class="pkg-new-info-capsule-value">{{item._weekRemaining}} 次</text>
                </view>
              </view>
            </view>
            <view class="pkg-new-progress" wx:if="{{item._hasProgress}}">
              <view class="pkg-new-progress-bar">
                <view class="pkg-new-progress-fill {{item._progressFillClass}}" style="{{item._progressWidthStyle}}"></view>
              </view>
              <view class="pkg-new-progress-info">
                <text class="pkg-new-progress-label">{{item._progressLabel}}</text>
                <text class="pkg-new-progress-pct">{{item._progressPercent}}%</text>
              </view>
            </view>
            <view class="pkg-new-footer" wx:if="{{item.is_activated && item.start_date_display}}">
              <text class="pkg-new-date-text">服务有效期：{{item.start_date_display}}至{{item.end_date_display}}</text>
            </view>
          </view>
        </view>
        </block>

        <!-- 待激活套餐卡片（仅新会员会出现，老会员套餐创建时已直接 active） -->
        <view class="pkg-card-new pending {{item.package_type}}" wx:for="{{pendingPackages}}" wx:key="_id" wx:if="{{pendingPackages.length > 0}}" bindtap="onPackageTap" data-id="{{item._id}}">
          <view class="pkg-new-decorate-circle"></view>
          <view class="pkg-new-content">
            <view class="pkg-new-header">
              <view class="pkg-tag pkg-tag-store" wx:if="{{item._storeName}}">
                <text class="pkg-tag-text">{{item._storeName}}</text>
              </view>
              <view class="pkg-tag pkg-tag-type-{{item.package_type}}" wx:if="{{item._typeLabel}}">
                <text class="pkg-tag-text">{{item._typeLabel}}</text>
              </view>
            </view>
            <view class="pkg-new-main">
              <view class="pkg-new-main-left pkg-new-pending-main">
                <!-- 套餐类型图标 + 静待开启状态 -->
                <view class="pkg-new-pending-hero">
                  <view class="pkg-new-pending-icon pkg-new-pending-icon-{{item.package_type}}"></view>
                </view>
                <view class="pkg-new-status-dot-wrap pending">
                  <view class="pkg-new-status-dot"></view>
                  <text class="pkg-new-status-label">静待开启</text>
                </view>
              </view>
              <view class="pkg-new-main-right">
                <view class="pkg-new-info-capsule" wx:if="{{item.package_type === 'count_card'}}">
                  <text class="pkg-new-info-capsule-label">套餐次数</text>
                  <text class="pkg-new-info-capsule-value">{{item._pendingCreditsValue}}</text>
                </view>
                <view class="pkg-new-info-capsule">
                  <text class="pkg-new-info-capsule-label">服务有效期</text>
                  <text class="pkg-new-info-capsule-value">{{item._durationText}}</text>
                </view>
              </view>
            </view>
            <!-- 强制激活倒计时 -->
            <view class="pkg-new-auto-activate" wx:if="{{item._autoActivateDate}}">
              <text class="pkg-new-auto-text">距强制激活还剩 {{item._autoActivateDays}} 天</text>
              <text class="pkg-new-auto-countdown">将于 {{item._autoActivateDate}} 自动激活，服务有效期开始计算</text>
            </view>
            <view class="pkg-new-footer">
              <text class="pkg-new-date-text">服务有效期：激活后开始计算</text>
              <text class="pkg-new-date-text pkg-new-footer-hint">录入后2个月未激活将自动强制激活</text>
            </view>
          </view>
        </view>

        <!-- 历史套餐区域 -->
        <view class="package-history-section" wx:if="{{historyPackages.length > 0}}">
          <view class="phs-toggle" bindtap="onTogglePackageHistory">
            <text class="phs-toggle-text">历史套餐 · {{historyPackages.length}}</text>
            <view class="phs-toggle-arrow {{showPackageHistory ? 'expanded' : ''}}"></view>
          </view>
          <view class="phs-list {{showPackageHistory ? 'show' : ''}}">
            <view class="pkg-card-new {{item.status}} {{item.package_type}}" wx:for="{{historyPackages}}" wx:key="_id" bindtap="onPackageTap" data-id="{{item._id}}">
              <view class="pkg-new-decorate-circle"></view>
              <view class="pkg-new-content">
                <view class="pkg-new-header">
                  <view class="pkg-new-header-left">
                    <view class="pkg-tag pkg-tag-store" wx:if="{{item._storeName}}">
                      <text class="pkg-tag-text">{{item._storeName}}</text>
                    </view>
                    <view class="pkg-tag pkg-tag-type-{{item.package_type}}" wx:if="{{item._typeLabel}}">
                      <text class="pkg-tag-text">{{item._typeLabel}}</text>
                    </view>
                  </view>
                </view>
                <view class="pkg-new-main">
                  <view class="pkg-new-main-left">
                    <!-- 次卡：双列大数字 -->
                    <view class="pkg-new-main-value-wrap pkg-new-dual-wrap" wx:if="{{item.package_type === 'count_card'}}">
                      <view class="pkg-new-dual-col">
                        <view class="pkg-new-dual-value-wrap">
                          <text class="pkg-new-main-value">{{item.remaining_credits || 0}}</text>
                          <text class="pkg-new-main-unit">次</text>
                        </view>
                        <text class="pkg-new-main-label">剩余次数</text>
                      </view>
                      <view class="pkg-new-dual-col">
                        <view class="pkg-new-dual-value-wrap">
                          <text class="pkg-new-main-value pkg-new-days-value">{{item.remaining_days || 0}}</text>
                          <text class="pkg-new-main-unit pkg-new-days-unit">天</text>
                        </view>
                        <text class="pkg-new-main-label">剩余天数</text>
                      </view>
                    </view>
                    <!-- 时间卡：单列大数字 -->
                    <view class="pkg-new-main-value-wrap" wx:elif="{{item.package_type === 'time_card'}}">
                      <text class="pkg-new-main-value">{{item.remaining_days || 0}}</text>
                      <text class="pkg-new-main-unit">天</text>
                    </view>
                    <text class="pkg-new-main-label" wx:if="{{item.package_type === 'time_card'}}">剩余天数</text>
                    <view class="pkg-new-status-dot-wrap {{item.status}}">
                      <view class="pkg-new-status-dot"></view>
                      <text class="pkg-new-status-label">{{item._statusText}}</text>
                    </view>
                  </view>
                  <view class="pkg-new-main-right">
                    <view class="pkg-new-info-capsule">
                      <text class="pkg-new-info-capsule-label">{{item._totalLabel}}</text>
                      <text class="pkg-new-info-capsule-value">{{item._totalValue}}</text>
                    </view>
                  </view>
                </view>
                <view class="pkg-new-footer" wx:if="{{item.start_date_display && item.end_date_display}}">
                  <text class="pkg-new-date-text">服务有效期：{{item.start_date_display}}至{{item.end_date_display}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view class="package-empty" wx:else>
        <view class="package-empty-icon"></view>
        <text class="package-empty-title">开启你的舞蹈之旅</text>
        <text class="package-empty-desc">联系门店客服录入套餐后即可开始预约</text>
      </view>
    </view>

    <view class="package-section" wx:if="{{userInfo.member_status !== 'official'}}">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">我的套餐</text>
        </view>
      </view>
      <view class="package-empty guest-empty">
        <text>登录后查看套餐信息</text>
      </view>
    </view>

    <view class="menu-section" wx:if="{{userInfo.member_status === 'official'}}">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">功能</text>
        </view>
      </view>
      <view class="menu-card">
        <view class="menu-item" bindtap="onMyBookings">
          <view class="menu-icon-wrap teal">
            <image class="menu-icon" src="/images/icons/calendar.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">我的记录</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onSubscribeSettings">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/settings.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">消息推送订阅设置</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onMemberInfo">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/document.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">个人信息</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onContactStore">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/phone.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">联系门店</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onAbout">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/info.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">关于系统</text>
          <view class="menu-item-arrow"></view>
        </view>
      </view>
    </view>

    <view class="menu-section" wx:if="{{userInfo.member_status !== 'official'}}">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">功能</text>
        </view>
      </view>
      <view class="menu-card">
        <view class="menu-item" bindtap="handleGuestTap">
          <view class="menu-icon-wrap teal">
            <image class="menu-icon" src="/images/icons/calendar.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">我的记录</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="handleGuestTap">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/document.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">个人信息</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onContactStore">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/phone.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">联系门店</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onAbout">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/info.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">关于系统</text>
          <view class="menu-item-arrow"></view>
        </view>
      </view>
    </view>

    <view class="menu-section menu-section-other" wx:if="{{isLoggedIn}}">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">其他</text>
        </view>
      </view>
      <view class="menu-card">
        <view class="menu-item" bindtap="onPrivacy">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/settings.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">隐私保护指引</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onAgreement">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/document.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">用户协议</text>
          <view class="menu-item-arrow"></view>
        </view>
      </view>
      <view class="menu-logout-row">
        <view class="menu-logout" bindtap="onLogout">退出登录</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="hero-card guest-hero">
      <view class="hero-top">
        <view class="hero-avatar-wrap">
          <view class="guest-avatar-icon-small"></view>
          <view class="hero-avatar-ring"></view>
        </view>
        <view class="hero-info">
          <view class="hero-name-row">
            <text class="hero-name">游客</text>
          </view>
          <text class="hero-since">登录解锁会员特权</text>
        </view>
      </view>
      <view class="guest-login-btn-row">
        <view class="guest-login-btn-small" bindtap="onLogin">
          <text class="guest-login-btn-text-small">一键登录</text>
        </view>
      </view>
    </view>

    <view class="stats-section guest-stats">
      <view class="stats-row">
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">待上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">已上课</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card guest-stat">
          <text class="stat-num">--</text>
          <text class="stat-label">本周剩余</text>
        </view>
      </view>
    </view>

    <view class="package-section">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">我的套餐</text>
        </view>
      </view>
      <view class="package-empty guest-empty">
        <text>登录后查看套餐信息</text>
      </view>
    </view>

    <view class="menu-section">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">功能</text>
        </view>
      </view>
      <view class="menu-card">
        <view class="menu-item" bindtap="handleGuestTap">
          <view class="menu-icon-wrap teal">
            <image class="menu-icon" src="/images/icons/calendar.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">我的记录</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="handleGuestTap">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/document.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">个人信息</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onContactStore">
          <view class="menu-icon-wrap rose">
            <image class="menu-icon" src="/images/icons/phone.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">联系门店</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onAbout">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/info.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">关于系统</text>
          <view class="menu-item-arrow"></view>
        </view>
      </view>
    </view>

    <view class="menu-section menu-section-other">
      <view class="section-header">
        <view class="section-header-left">
          <view class="section-left-bar"></view>
          <text class="section-title">其他</text>
        </view>
      </view>
      <view class="menu-card">
        <view class="menu-item" bindtap="onPrivacy">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/settings.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">隐私保护指引</text>
          <view class="menu-item-arrow"></view>
        </view>
        <view class="menu-item" bindtap="onAgreement">
          <view class="menu-icon-wrap muted">
            <image class="menu-icon" src="/images/icons/document.svg" mode="aspectFit"></image>
          </view>
          <text class="menu-item-title">用户协议</text>
          <view class="menu-item-arrow"></view>
        </view>
      </view>
    </view>
  </block>
</view>
</view>

<!-- 套餐详情 Sheet -->
<view class="pkg-sheet-mask {{showPackageDetail ? 'show' : ''}}" bindtap="onClosePackageDetail" catchtouchmove="preventTouchMove">
  <view class="pkg-sheet {{showPackageDetail ? 'show' : ''}} {{sheetDragging ? 'dragging' : ''}}" style="{{sheetDragY > 0 ? 'transform: translateY(' + sheetDragY + 'px)' : ''}}" catchtouchmove="preventTouchMove">
    <view class="pkg-sheet-handle" catchtouchstart="onHandleTouchStart" catchtouchmove="onHandleTouchMove" catchtouchend="onHandleTouchEnd">
      <view class="pkg-sheet-handle-bar"></view>
    </view>
    <scroll-view class="pkg-sheet-body" scroll-y wx:if="{{detailPackage}}">
      <view class="pkg-sheet-section">
        <text class="pkg-sheet-label">所属门店</text>
        <text class="pkg-sheet-value">{{detailPackage._storeName || '未指定'}}</text>
      </view>
      <view class="pkg-sheet-section">
        <text class="pkg-sheet-label">套餐类型</text>
        <text class="pkg-sheet-value">{{detailPackage._typeLabel}}</text>
      </view>
      <view class="pkg-sheet-section">
        <text class="pkg-sheet-label">使用状态</text>
        <view class="pkg-status-badge {{detailPackage.status}} pkg-sheet-badge">
          <text>{{detailPackage._statusText}}</text>
        </view>
      </view>
      <view class="pkg-sheet-section" wx:if="{{detailPackage.package_type === 'count_card'}}">
        <text class="pkg-sheet-label">套餐次数</text>
        <text class="pkg-sheet-value">共 {{detailPackage.total_credits || 0}} 次，剩余 {{detailPackage.remaining_credits || 0}} 次</text>
      </view>
      <view class="pkg-sheet-section" wx:if="{{detailPackage.package_type === 'time_card' && detailPackage._periodLabel}}">
        <text class="pkg-sheet-label">{{detailPackage._periodLabel}}预约</text>
        <text class="pkg-sheet-value">已约 {{detailPackage._weekUsed}}/{{detailPackage._weekLimit}} 次</text>
      </view>
      <view class="pkg-sheet-section">
        <text class="pkg-sheet-label">服务有效期</text>
        <text class="pkg-sheet-value">
          <block wx:if="{{detailPackage.is_activated && detailPackage.start_date_display}}">{{detailPackage.start_date_display}} 至 {{detailPackage.end_date_display}}</block>
          <block wx:else>{{detailPackage.duration_value || '-'}}{{detailPackage.duration_unit === 'month' ? '个月' : '天'}}</block>
        </text>
      </view>
      <view class="pkg-sheet-section" wx:if="{{detailPackage.is_activated && detailPackage.status === 'active' && detailPackage.remaining_days !== undefined && detailPackage.remaining_days !== null}}">
        <text class="pkg-sheet-label">剩余服务有效期</text>
        <text class="pkg-sheet-value">{{detailPackage.remaining_days}} 天</text>
      </view>
      <view class="pkg-sheet-section" wx:if="{{detailPackage._autoActivateDate}}">
        <text class="pkg-sheet-label">自动激活日期</text>
        <text class="pkg-sheet-value">将于 {{detailPackage._autoActivateDate}} 自动激活套餐，服务有效期开始计算</text>
      </view>
    </scroll-view>
  </view>
</view>

  <view class="modal-mask" wx:if="{{showStorePicker}}" bindtap="onCloseStorePicker">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-title-text">{{storePickerTitle}}</view>
      <view class="store-list">
        <view class="store-opt {{selectedStoreId === item._id ? 'active' : ''}}" wx:for="{{storeList}}" wx:key="_id" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onStoreSelect">
          <text class="store-opt-name">{{item.name}}</text>
          <text class="store-opt-dist" wx:if="{{item.distance !== undefined}}">{{item.distance}}km</text>
        </view>
      </view>
      <view class="btn-primary" bindtap="onStoreConfirm" disabled="{{!selectedStoreId}}">确认</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showForceProfileModal}}" bindtap="onCloseForceProfileModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-title-text">完善个人信息</view>
      <view class="modal-hint-text">为了更好地为您服务，请完善以下信息</view>
      <view class="form-group">
        <text class="form-label">真实姓名 *</text>
        <input class="form-input" type="text" placeholder="请输入真实姓名" placeholder-class="ph" value="{{profileForm.real_name}}" bindinput="onRealNameInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">预留手机号 *</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入预留手机号" placeholder-class="ph" value="{{profileForm.phone}}" bindinput="onPhoneInput"></input>
      </view>
      <view class="form-group">
        <text class="form-label">性别 *</text>
        <view class="gender-picker">
          <view class="gp-option {{profileForm.gender === 1 ? 'active' : ''}}" data-gender="1" bindtap="onGenderSelect">男</view>
          <view class="gp-option {{profileForm.gender === 2 ? 'active' : ''}}" data-gender="2" bindtap="onGenderSelect">女</view>
        </view>
      </view>
      <view class="btn-primary" bindtap="onSaveProfile">确认保存</view>
    </view>
  </view>

  <view class="modal-mask qr-modal" wx:if="{{showQRModal}}" bindtap="onCloseQRModal">
    <view class="modal-content qr" catchtap="onModalTap">
      <view class="modal-title-text">会员码</view>
      <view class="qr-user">
        <text class="qr-name">{{userInfo.real_name || userInfo.nickname || (isOfficialMember ? '会员' : '注册用户')}}</text>
        <text class="qr-code-txt" wx:if="{{userInfo.member_code}}">{{userInfo.member_code}}</text>
      </view>
      <view class="qr-img-area">
        <canvas type="2d" id="qrCheckInCanvas" class="qr-canvas" wx:if="{{showQRModal && qrCodeToken}}"></canvas>
        <image class="qr-canvas" src="{{qrCodeUrl}}" mode="aspectFit" decoding="async" wx:elif="{{qrCodeUrl && !qrCodeToken}}"></image>
        <view class="qr-loading" wx:else>
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>
      </view>
      <view class="qr-timer">{{qrCountdown}}秒后自动刷新</view>
      <view class="qr-tip-box">此码为动态码，每60秒自动刷新，截图无效</view>
      <!-- 签到状态文案区域（二维码下方，非结果类状态） -->
      <view class="qr-status-area" wx:if="{{checkInStatusText}}">
        <view class="qr-status-spinner" wx:if="{{checkInStatusType === 'scanned'}}"></view>
        <text class="qr-status-text {{checkInStatusType}}">{{checkInStatusText}}</text>
      </view>
    </view>
  </view>

  <!-- 签到成功弹窗（结果类强弹窗，3秒自动关闭） -->
  <view class="modal-mask success" wx:if="{{showCheckInSuccess}}">
    <view class="modal-content checkin">
      <view class="checkin-icon-wrap">
        <view class="checkin-ok"></view>
      </view>
      <text class="checkin-title">签到成功</text>
      <view class="checkin-list">
        <view class="chk-item" wx:for="{{checkInCourses}}" wx:key="course_name">
          <text class="chk-name">{{item.course_name}}</text>
          <view class="chk-meta">
            <text class="chk-time">{{item.time}}</text>
            <view class="chk-source">{{item.source}}</view>
          </view>
        </view>
      </view>
      <view class="pkg-resumed-tip" wx:if="{{packageResumedText}}">
        <text class="pkg-resumed-tip-text">{{packageResumedText}}</text>
      </view>
      <view class="btn-primary" bindtap="onCloseCheckInSuccess">关闭</view>
    </view>
  </view>

  <!-- 签到失败弹窗（结果类强弹窗，手动关闭） -->
  <view class="modal-mask" wx:if="{{showCheckInFailed}}">
    <view class="modal-content checkin">
      <view class="checkin-icon-wrap failed">
        <view class="checkin-fail"></view>
      </view>
      <text class="checkin-title failed">签到失败</text>
      <view class="checkin-failed-text">{{checkInFailedText}}</view>
      <view class="btn-primary" bindtap="onCloseCheckInFailed">关闭</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showChangePhoneModal}}" bindtap="onCloseChangePhoneModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-title-text">修改预留手机号</view>
      <view class="form-group">
        <text class="form-label">当前预留手机号</text>
        <text class="current-phone">{{userInfo.reserve_phone || userInfo.phone || '未设置'}}</text>
      </view>
      <view class="audit-status-box audit-pending" wx:if="{{phoneAuditStatus === 'pending'}}">
        <text class="audit-badge audit-badge-pending">审核中</text>
        <text class="audit-text">待审核新号码：{{phoneAuditPendingPhone || '未设置'}}</text>
      </view>
      <view class="audit-status-box audit-rejected" wx:if="{{phoneAuditStatus === 'rejected'}}">
        <text class="audit-badge audit-badge-rejected">审核未通过</text>
        <text class="audit-text">上次申请未通过，可重新提交</text>
      </view>
      <view class="form-group">
        <text class="form-label">新手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入新的手机号" placeholder-class="ph" value="{{newPhone}}" bindinput="onNewPhoneInput" disabled="{{phoneAuditStatus === 'pending'}}"></input>
      </view>
      <view class="tip-box">修改手机号需要管理员审核通过后生效</view>
      <view class="btn-primary {{phoneAuditStatus === 'pending' ? 'btn-primary-disabled' : ''}}" bindtap="onSubmitChangePhone">提交审核</view>
    </view>
  </view>

  <!-- 微信授权登录弹窗 -->
  <login-modal visible="{{showLoginModal}}" bind:close="onLoginModalClose" bind:success="onLoginSuccess"></login-modal>

<!-- 头像选择面板 -->
<view class="avatar-sheet-mask" wx:if="{{showAvatarSheet}}" bindtap="onCloseAvatarSheet">
  <view class="avatar-sheet" catchtap="onSheetTap">
    <view class="as-header">
      <text class="as-title">更换头像</text>
    </view>
    <button class="as-item" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <text>获取微信头像</text>
    </button>
    <view class="as-item" bindtap="onChooseFromCamera">
      <text>拍照</text>
    </view>
    <view class="as-item" bindtap="onChooseFromAlbum">
      <text>本地上传</text>
    </view>
    <view class="as-cancel" bindtap="onCloseAvatarSheet">
      <text>取消</text>
    </view>
  </view>
</view>