  background: rgba(197, 116, 75, 0.08);
}

.pkg-card-new.time_card .pkg-new-info-capsule:nth-child(2) {
  background: rgba(93, 155, 155, 0.08);
}

/* 次卡胶囊颜色 */
.pkg-card-new.count_card .pkg-new-info-capsule {
  background: rgba(93, 155, 155, 0.08);
}

.pkg-card-new.count_card .pkg-new-info-capsule:nth-child(2) {
  background: rgba(197, 116, 75, 0.08);
}

/* 待激活胶囊 */
.pkg-card-new.pending .pkg-new-info-capsule {
  background: rgba(139, 126, 172, 0.08);
}

/* 已结束胶囊 */
.pkg-card-new.expired .pkg-new-info-capsule,
.pkg-card-new.exhausted .pkg-new-info-capsule {
  background: rgba(184, 175, 158, 0.08);
}

/* 暂停胶囊 */
.pkg-card-new.suspended .pkg-new-info-capsule {
  background: rgba(197, 116, 75, 0.08);
}

.pkg-card-new.suspended .pkg-new-info-capsule:nth-child(2) {
  background: rgba(93, 155, 155, 0.08);
}

.pkg-new-info-capsule-label {
  display: block;
  font-size: 22rpx;
  color: #A69294;
}

.pkg-new-info-capsule-value {
