  height: 32rpx;
  position: relative;
}

.checkin-fail::before,
.checkin-fail::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 32rpx;
  height: 4rpx;
  background: #D4786E;
  border-radius: 2rpx;
}

.checkin-fail::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.checkin-fail::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

