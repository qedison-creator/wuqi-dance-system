  font-size: 26rpx;
  color: #2A2122;
  font-weight: 500;
}

.pkg-card-new.expired .pkg-new-info-capsule-value,
.pkg-card-new.exhausted .pkg-new-info-capsule-value {
  color: #8B7E6A;
}

/* ========== 进度条区 ========== */
.pkg-new-progress {
  margin-bottom: 20rpx;
}

.pkg-new-progress-bar {
  height: 12rpx;
  background: #F6F3F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.pkg-new-progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 时间卡进度条 - 暖棕 */
.pkg-card-new.time_card .pkg-new-progress-fill.pkg-progress-fill-active {
  background: linear-gradient(90deg, #E8985E, #C5744B);
}

/* 次卡进度条 - 青碧 */
.pkg-card-new.count_card .pkg-new-progress-fill.pkg-progress-fill-active {
  background: linear-gradient(90deg, #8DC5C5, #5D9B9B);
}

.pkg-new-progress-fill.pkg-progress-fill-pending {
  background: linear-gradient(90deg, #B8A8D0, #8B7EAC);
}

.pkg-new-progress-fill.pkg-progress-fill-expired,
.pkg-new-progress-fill.pkg-progress-fill-exhausted {
  background: linear-gradient(90deg, #D4C8CA, #B8AF9E);
}

.pkg-new-progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pkg-new-progress-label {
  font-size: 22rpx;
  color: #B8AF9E;
}

.pkg-new-progress-pct {
  font-size: 22rpx;
  font-weight: 500;
}

.pkg-card-new.time_card .pkg-new-progress-pct {
  color: #C5744B;
}

.pkg-card-new.count_card .pkg-new-progress-pct {
  color: #5D9B9B;
}

/* ========== 底部日期信息 ========== */
.pkg-new-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(197, 116, 75, 0.08);
}

.pkg-card-new.count_card .pkg-new-footer {
  border-top-color: rgba(93, 155, 155, 0.08);
}

.pkg-card-new.pending .pkg-new-footer {
  border-top-color: rgba(139, 126, 172, 0.08);
}

.pkg-card-new.expired .pkg-new-footer,
.pkg-card-new.exhausted .pkg-new-footer {
  border-top-color: rgba(184, 175, 158, 0.08);
}

.pkg-new-date-text {
  font-size: 24rpx;
  color: #8B7E6A;
  line-height: 1.5;
}

/* 待激活卡片底部说明文字（强制激活提示） */
.pkg-new-footer-hint {
  color: #A69294;
  margin-top: 4rpx;
}

/* ========== 强制激活倒计时 ========== */
.pkg-new-auto-activate {
  background: rgba(139, 126, 172, 0.06);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

/* 主倒计时文案：距强制激活还剩 XX 天（暖橙强调紧迫感） */
.pkg-new-auto-text {
  font-size: 26rpx;
  color: #C5744B;
  font-weight: 500;
  line-height: 1.6;
  display: block;
}

/* 次要说明：将于 XX 自动激活，服务有效期开始计算 */
.pkg-new-auto-countdown {
  font-size: 24rpx;
  color: #6B5E8A;
  margin-top: 6rpx;
  display: block;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-header-left {
