}

.cih-min-capacity-text {
  font-size: 20rpx;
  color: #948284;
}

/* ===== 此间画面：相框横向滚动 ===== */
.gallery-section {
  margin: 0 0 40rpx;
  padding: 40rpx 0 0;
}

.gs-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.gs-title-line {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.gs-accent {
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 120, 110, 0.6));
}

.gs-accent + .gs-accent {
  background: linear-gradient(90deg, rgba(212, 120, 110, 0.6), transparent);
}

.gs-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A2122;
  letter-spacing: 4rpx;
}

.gs-subtitle {
  font-size: 22rpx;
  color: #948284;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.gs-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 24rpx 28rpx 32rpx;
}

.gs-frame {
  display: inline-block;
  margin-right: 20rpx;
  vertical-align: top;
  background: #FFFFFF;
  border-radius: 8rpx;
  box-shadow:
    -8rpx 0 24rpx rgba(42, 33, 34, 0.12),
    8rpx 0 24rpx rgba(42, 33, 34, 0.12),
    0 -8rpx 24rpx rgba(42, 33, 34, 0.12),
    0 8rpx 24rpx rgba(42, 33, 34, 0.12),
    0 24rpx 48rpx rgba(42, 33, 34, 0.18),
    0 -24rpx 40rpx rgba(42, 33, 34, 0.10),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
  transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 250ms ease;
  position: relative;
}

.gs-frame:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow:
    0 2rpx 10rpx rgba(42, 33, 34, 0.1),
    0 8rpx 20rpx rgba(42, 33, 34, 0.08);
}

/* 横屏相框：宽屏 */
.gs-landscape {
  width: 560rpx;
  padding: 20rpx;
}

.gs-landscape .gs-frame-inner {
  width: 100%;
  height: 400rpx;
  background: #E8E3DE;
  border-radius: 4rpx;
  overflow: hidden;
}

/* 竖屏相框：窄高 */
.gs-portrait {
  width: 320rpx;
  padding: 20rpx;
}

.gs-portrait .gs-frame-inner {
  width: 100%;
  height: 400rpx;
  background: #E8E3DE;
  border-radius: 4rpx;
  overflow: hidden;
}

.gs-img {
  width: 100%;
  height: 100%;
  display: block;
}

.empty-inline {
  padding: 48rpx 0;
  text-align: center;
}

.eit {
  font-size: 26rpx;
  color: #948284;
}

.store-list {
  margin-bottom: 24rpx;
}

.store-opt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 20rpx;
  background: #F9F7F5;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.store-opt:active {
  transform: scale(0.98);
}

.store-opt.active {
  background: #FDF2EF;
  border-color: #D4786E;
}

.store-opt-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.store-opt-name {
  font-size: 28rpx;
  color: #2A2122;
  font-weight: 500;
}

.store-opt-distance {
  font-size: 22rpx;
  color: #948284;
  background: #F0EBE9;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.store-opt-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #C05D53);
  position: relative;
}

.store-opt-check::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%) rotate(45deg);
  width: 10rpx;
  height: 18rpx;
  border-bottom: 3rpx solid #FFFFFF;
  border-right: 3rpx solid #FFFFFF;
}

.modal-title-text {
  font-size: 34rpx;
  color: #2A2122;
  font-weight: 700;
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-close-btn {
  width: 100%;
  padding: 22rpx 0;
  background: #F9F7F5;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6B5D5E;
  font-weight: 500;
}

.modal-close-btn:active {
  opacity: 0.7;
}

.announce-modal {
  z-index: 1000;
  background: rgba(42,33,34,0.6);
}

.am-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 600rpx;
  overflow: visible;
}

.am-stack {
  position: relative;
  width: 100%;
  height: 620rpx;
  overflow: visible;
}

.am-card-below {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.am-card-return {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.am-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(42,33,34,0.12);
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 620rpx;
  box-sizing: border-box;
}

.am-card-front {
  position: relative;
  z-index: 20;
  width: 100%;
  height: 620rpx;
}

.am-card-drag {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  touch-action: pan-y;
}

.am-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.am-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #D4786E, #E8985E);
  padding: 10rpx 20rpx 10rpx 12rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(212,120,110,0.3);
}

.am-badge-icon {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  flex-shrink: 0;
}

.am-badge-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 20rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 3rpx;
  border-bottom-left-radius: 7rpx;
  border-bottom-right-radius: 7rpx;
}

.am-badge-icon::after {
  content: '';
  position: absolute;
  top: 5rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 9rpx;
  height: 6rpx;
  border: 3rpx solid #FFFFFF;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}

.am-badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.am-page {
  font-size: 24rpx;
  font-weight: 600;
  color: #D4786E;
}

.am-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.am-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2122;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.am-line {
  width: 48rpx;
  height: 4rpx;
  background: #D4786E;
  border-radius: 2rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.am-content {
  flex: 1;
  min-height: 0;
  margin-bottom: 20rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.am-text {
  font-size: 26rpx;
  color: #6B5D5E;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.am-footer {
  margin-top: auto;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F0EE;
  flex-shrink: 0;
}

.am-date-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.am-date-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #E8985E);
}

.am-date {
  font-size: 22rpx;
  color: #948284;
  font-weight: 500;
}

.am-close-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  margin-top: 32rpx;
  transition: all 150ms ease;
}

.am-close-btn:active {
  transform: scale(0.92);
  opacity: 0.7;
}

.am-close-ring {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  border: 3rpx solid rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.am-close-x {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.am-close-x::before,
.am-close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 4rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.am-close-x::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.am-close-x::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.am-close-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
}

.lam-card {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(42,33,34,0.15);
  text-align: center;
  animation: lam-pop-in 350ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes lam-pop-in {
  0% { opacity: 0; transform: translate(-50%, -55%) scale(0.85); }
  100% { opacity: 1; transform: translate(-50%, -55%) scale(1); }
}

.lam-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 28rpx;
  background: #FDF2EF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lam-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.lam-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  background: #D4786E;
  border-radius: 50%;
}

.lam-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(212,120,110,0.2);
  border-radius: 50%;
  animation: lam-ripple 2s ease-out infinite;
}

@keyframes lam-ripple {
  0% { width: 18rpx; height: 18rpx; opacity: 1; }
  100% { width: 56rpx; height: 56rpx; opacity: 0; }
}

.lam-title {
  display: block;
  font-size: 36rpx;
  color: #2A2122;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.lam-desc {
  display: block;
  font-size: 26rpx;
  color: #6B5D5E;
  line-height: 1.6;
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}

.lam-btns {
  display: flex;
}

.lam-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.lam-btn:active {
  transform: scale(0.96);
}

.lam-btn-cancel {
  background: #F9F7F5;
  color: #6B5D5E;
  margin-right: 16rpx;
}

.lam-btn-confirm {
  background: linear-gradient(135deg, #D4786E, #C05D53);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(212,120,110,0.3);
}
