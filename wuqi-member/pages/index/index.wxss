page {
  background: #FBFAF8;
  color: #2A2122;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.page {
  min-height: 100vh;
  background: #FBFAF8;
}

/* ===== 骨架屏 ===== */
@keyframes sk-pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.sk-page {
  min-height: 100vh;
  background: #FBFAF8;
}

.sk-banner {
  height: 620rpx;
  background: linear-gradient(160deg, #FDF2EF 0%, #EEF5F4 50%, #F8F4FC 100%);
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-content {
  padding: 0 28rpx 200rpx;
  margin-top: -70rpx;
  position: relative;
  z-index: 3;
}

.sk-hero-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 32rpx rgba(42,33,34,0.10);
  overflow: hidden;
  margin-bottom: 16rpx;
  margin-top: 150rpx;
}

.sk-greeting {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.sk-emoji {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F0EBE9;
  margin-right: 16rpx;
  flex-shrink: 0;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-greet-main {
  width: 120rpx;
  height: 32rpx;
  border-radius: 8rpx;
  background: #F0EBE9;
  margin-right: 12rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-greet-sub {
  width: 160rpx;
  height: 24rpx;
  border-radius: 6rpx;
  background: #F5F0EE;
  animation: sk-pulse 1.5s ease-in-out infinite 0.2s;
}

.sk-store {
  padding: 20rpx 28rpx;
}

.sk-store-inner {
  display: flex;
  align-items: flex-start;
}

.sk-store-icon {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  border-radius: 14rpx;
  background: #F5F0EE;
  margin-right: 16rpx;
  margin-top: 2rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-store-info {
  flex: 1;
  min-width: 0;
}

.sk-store-name {
  width: 200rpx;
  height: 30rpx;
  border-radius: 8rpx;
  background: #F0EBE9;
  margin-bottom: 12rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-store-addr {
  width: 280rpx;
  height: 24rpx;
  border-radius: 6rpx;
  background: #F5F0EE;
  margin-bottom: 10rpx;
  animation: sk-pulse 1.5s ease-in-out infinite 0.2s;
}

.sk-store-phone {
  width: 160rpx;
  height: 24rpx;
  border-radius: 6rpx;
  background: #F5F0EE;
  animation: sk-pulse 1.5s ease-in-out infinite 0.3s;
}

.sk-announce {
  height: 72rpx;
  border-radius: 24rpx;
  background: #F9F7F5;
  margin-bottom: 32rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-section {
  margin-bottom: 36rpx;
}

.sk-section-header {
  display: flex;
  align-items: center;
  padding: 0 0 20rpx;
}

.sk-section-dot {
  width: 6rpx;
  height: 26rpx;
  border-radius: 3rpx;
  background: #F0EBE9;
  margin-right: 14rpx;
}

.sk-section-dot.course {
  background: #E0EEED;
}

.sk-section-dot.video {
  background: #E8DDF0;
}

.sk-section-title {
  width: 140rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #F0EBE9;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-coach-row {
  display: flex;
  gap: 24rpx;
}

.sk-coach {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.sk-coach-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  background: #F0EBE9;
  margin-bottom: 14rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-coach-name {
  width: 80rpx;
  height: 26rpx;
  border-radius: 6rpx;
  background: #F5F0EE;
  animation: sk-pulse 1.5s ease-in-out infinite 0.2s;
}

.sk-course-row {
  display: flex;
  gap: 18rpx;
}

.sk-course-card {
  width: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(42,33,34,0.06);
}

.sk-course-thumb {
  width: 100%;
  height: 180rpx;
  background: #F0EBE9;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-course-info {
  padding: 18rpx 20rpx 20rpx;
}

.sk-course-tag {
  width: 80rpx;
  height: 28rpx;
  border-radius: 10rpx;
  background: #F5F0EE;
  margin-bottom: 10rpx;
  animation: sk-pulse 1.5s ease-in-out infinite;
}

.sk-course-name {
  width: 180rpx;
  height: 26rpx;
  border-radius: 6rpx;
  background: #F0EBE9;
  margin-bottom: 10rpx;
  animation: sk-pulse 1.5s ease-in-out infinite 0.2s;
}

.sk-course-meta {
  width: 140rpx;
  height: 20rpx;
  border-radius: 6rpx;
  background: #F5F0EE;
  animation: sk-pulse 1.5s ease-in-out infinite 0.4s;
}

/* ===== Banner ===== */
.banner-section {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 620rpx;
  z-index: 1;
  overflow: hidden;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-dots {
  position: absolute;
  bottom: 120rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.bdot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(255,255,255,0.45);
  margin: 0 6rpx;
  transition: all 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bdot.active {
  width: 24rpx;
  border-radius: 4rpx;
  background: #FFFFFF;
}

.banner-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 260rpx;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(251,250,248,0.2) 30%,
    rgba(251,250,248,0.7) 65%,
    #FBFAF8 100%
  );
  z-index: 2;
  pointer-events: none;
}

.banner-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 620rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #FDF2EF 0%, #EEF5F4 50%, #F8F4FC 100%);
}

.bp-greeting {
  display: flex;
  align-items: center;
}

.bp-emoji {
  font-size: 52rpx;
  margin-right: 14rpx;
}

.bp-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #2A2122;
}

.bp-sub {
  font-size: 26rpx;
  color: #6B5D5E;
  margin-top: 12rpx;
}

.content-section {
  position: relative;
  z-index: 3;
  padding: 0 28rpx 200rpx;
}

.hero-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 32rpx rgba(42,33,34,0.10);
  overflow: hidden;
  margin-bottom: 16rpx;
  margin-top: 150rpx;
}

.hc-greeting {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.hc-greet-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.hc-greet-text {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.hc-greet-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2122;
}

.hc-greet-sub {
  font-size: 24rpx;
  color: #6B5D5E;
  margin-left: 12rpx;
}

.hc-store-wrap {
  padding: 20rpx 28rpx;
}

.hc-store-top {
  padding-bottom: 0;
  border-bottom: none;
}

.hc-store-name-row {
  display: flex;
  align-items: flex-start;
}

.hc-store-icon {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  border-radius: 14rpx;
  background: #FDF2EF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  margin-top: 2rpx;
}

.hcs-icon-shape {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #D4786E;
  border-radius: 6rpx;
  border-bottom-left-radius: 14rpx;
  border-bottom-right-radius: 14rpx;
  border-top: none;
}

.hc-store-info {
  flex: 1;
  min-width: 0;
}

.hc-store-name-wrap {
  display: flex;
  align-items: center;
}

.hc-store-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2122;
}

.hc-switch-btn {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(212,120,110,0.08);
  margin-left: 14rpx;
  flex-shrink: 0;
}

.hc-switch-btn:active {
  background: rgba(212,120,110,0.16);
}

.hc-switch-btn text {
  font-size: 22rpx;
  color: #D4786E;
  font-weight: 500;
}

.hcs-sw-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid #D4786E;
  border-right: 2rpx solid #D4786E;
  transform: rotate(45deg);
  margin-left: 4rpx;
  margin-top: -2rpx;
}

.hc-store-addr-wrap {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  padding: 6rpx 0;
}

.hc-store-addr {
  font-size: 24rpx;
  color: #6B5D5E;
  line-height: 1.4;
  flex: 1;
}

.hca-nav-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(93,155,155,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.hca-nav-icon::after {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5D9B9B;
  box-shadow: 0 0 0 4rpx rgba(93,155,155,0.15);
}

.hc-store-phone-wrap {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  padding: 6rpx 0;
}

.hc-store-phone {
  font-size: 24rpx;
  color: #6B5D5E;
  font-weight: 500;
  flex: 1;
}

.hca-call-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(212,120,110,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.hca-call-icon::after {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D4786E;
}

.hc-no-store {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 28rpx;
}

.hcn-text {
  font-size: 28rpx;
  color: #948284;
  margin-bottom: 20rpx;
}

.hcn-btn {
  padding: 14rpx 40rpx;
  border-radius: 32rpx;
  background: #D4786E;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

.announce-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FDF2EF 0%, #FFFFFF 100%);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(212,120,110,0.08);
  border: 1rpx solid rgba(212,120,110,0.1);
}

.announce-bar:active {
  transform: scale(0.98);
  transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
}

.ab-dot {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #D4786E, #E8985E);
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(212,120,110,0.25);
  position: relative;
  flex-shrink: 0;
}

.ab-dot::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 18rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 3rpx;
  border-bottom-left-radius: 6rpx;
  border-bottom-right-radius: 6rpx;
}

.ab-dot::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 5rpx;
  border: 3rpx solid #FFFFFF;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}

.ab-flip-wrap {
  flex: 1;
  overflow: hidden;
  min-width: 0;
  height: 40rpx;
  position: relative;
}

.ab-flip-text {
  font-size: 24rpx;
  color: #6B5D5E;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 40rpx;
  display: block;
}

.ab-flip-text.anim-out {
  animation: announceOut 400ms ease forwards;
}

.ab-flip-text.anim-in {
  animation: announceIn 400ms ease forwards;
}

@keyframes announceOut {
  from { transform: translateY(0); opacity: 1; }
  to { transform: translateY(-100%); opacity: 0; }
}

@keyframes announceIn {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.ab-badge {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #E8985E);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(212,120,110,0.25);
}

.ab-badge text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.section {
  margin-bottom: 36rpx;
}

.section-dot.course-dot {
  background: #5D9B9B;
}

.section-dot.video-dot {
  background: #B89CDA;
}

.coach-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.coach-scroll::-webkit-scrollbar {
  display: none;
}

.coach-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  margin-right: 24rpx;
  transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.coach-item:active {
  transform: scale(0.94);
}

.coach-avatar-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 14rpx;
}

.coach-avatar {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  border: 3rpx solid rgba(212,120,110,0.15);
  position: relative;
  z-index: 2;
}

.coach-avatar-ring {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border-radius: 46rpx;
  border: 2rpx dashed rgba(212,120,110,0.35);
  animation: ringRotate 8s linear infinite;
  z-index: 1;
}

@keyframes ringRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.coach-name {
  font-size: 26rpx;
  color: #2A2122;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.coach-tag {
  font-size: 20rpx;
  color: #6B5D5E;
  background: #F9F7F5;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.course-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.course-scroll::-webkit-scrollbar {
  display: none;
}

.course-card-h {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  margin-right: 18rpx;
  background: linear-gradient(135deg, #F0E8FF 0%, #FDF2EF 45%, #EEF5F4 100%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(42,33,34,0.06);
  transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.course-card-h:active {
  transform: scale(0.96);
}

.course-thumb {
  width: 100%;
  height: 180rpx;
  background: linear-gradient(135deg, #EEF5F4, #E8F0F5);
}

.course-info-h {
  padding: 18rpx 20rpx 20rpx;
}

.cih-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.cih-name {
  font-size: 26rpx;
  color: #2A2122;
  font-weight: 600;
  line-height: 1.3;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
}

.cih-meta {
  display: flex;
  align-items: center;
}

.cih-day {
  font-size: 20rpx;
