.page {
  background: #FAF8F6;
  min-height: 100vh;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.cover-section {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 56.25%;
  overflow: hidden;
}

.cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.cover-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #FDF2EF 0%, #EEF5F4 40%, #F8F4FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cover-placeholder::before {
  content: '';
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,120,110,0.15), transparent 70%);
  top: -100rpx;
  left: -100rpx;
}

.cover-placeholder::after {
  content: '';
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(93,155,155,0.12), transparent 70%);
  bottom: -80rpx;
  right: -60rpx;
}

.cp-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.25), rgba(93,155,155,0.2));
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 32rpx rgba(212,120,110,0.15);
}

.cp-icon::after {
  content: '';
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4786E, #5D9B9B);
  box-shadow: 0 0 0 6rpx rgba(212,120,110,0.15);
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(250,248,246,0.95), rgba(250,248,246,0.4), transparent);
  z-index: 2;
}

.content {
  padding: 0 28rpx;
  margin-top: -32rpx;
  position: relative;
  z-index: 3;
}

.course-title-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(61,44,46,0.06);
  position: relative;
  overflow: hidden;
}

.course-title-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #D4786E, #EBA89F, #E8985E);
  border-radius: 3rpx 3rpx 0 0;
}

.ctc-store-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx;
  background: rgba(212, 165, 116, 0.08);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #E8985E;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.cst-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #E8985E;
}

.ctc-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.ctc-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.ctc-name {
  display: block;
  font-size: 38rpx;
  color: #3D2C2E;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(61,44,46,0.05);
  border: 1rpx solid rgba(212,120,110,0.05);
}

.ic-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(212,120,110,0.06);
}

.ic-row:last-child {
  border-bottom: none;
}

.ic-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ic-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(212,120,110,0.10);
}

.ic-icon::after {
  content: '';
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D4786E;
}

.ic-icon.time { background: rgba(196,181,253,0.18); }
.ic-icon.time::after { background: #C4B5FD; }

.ic-icon.room { background: rgba(77,184,160,0.12); }
.ic-icon.room::after { background: #4DB8A0; }

.ic-icon.people { background: rgba(212,120,110,0.10); }
.ic-icon.people::after { background: #D4786E; }

.ic-icon.min-people { background: rgba(93,155,155,0.12); }
.ic-icon.min-people::after { background: #5D9B9B; }

.ic-icon.credit { background: rgba(232,152,94,0.15); }
.ic-icon.credit::after { background: #E8985E; }

.ic-icon.coach { background: rgba(196,181,253,0.18); }
.ic-icon.coach::after { background: #C4B5FD; }

.ic-label {
  font-size: 26rpx;
  color: #948284;
  min-width: 100rpx;
  font-weight: 500;
}

.ic-value {
  font-size: 26rpx;
  color: #6B5D5E;
  text-align: right;
  flex: 1;
  font-weight: 500;
}

.ic-value.link {
  color: #000;
  font-weight: 700;
}

.ic-value-highlight {
  font-size: 28rpx;
  color: #D4786E;
  font-weight: 700;
}

.ic-value-highlight.gold {
  color: #E8985E;
}

.ic-val-unit {
  font-size: 24rpx;
  color: #948284;
  font-weight: 400;
  margin-left: 2rpx;
}

.desc-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(61,44,46,0.06);
}

.dc-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.dc-dot {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #D4786E, #EBA89F);
}

.dc-dot.lavender {
  background: linear-gradient(180deg, #C4B5FD, #A78BFA);
}

.dc-title {
  font-size: 32rpx;
  color: #3D2C2E;
  font-weight: 700;
}

.dc-text {
  font-size: 28rpx;
  color: #7A6B6D;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 28rpx 120rpx;
  background: rgba(255,255,255,0.98);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 20rpx rgba(61,44,46,0.05);
  z-index: 100;
  border-top: 1rpx solid rgba(212,120,110,0.06);
}

.bb-btns {
  display: flex;
  gap: 16rpx;
}

.bb-primary {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: linear-gradient(135deg, #D4786E, #E8985E);
  color: #FFFFFF;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  box-shadow: 0 6rpx 20rpx rgba(212,120,110,0.30);
  transition: all 150ms cubic-bezier(0.34,1.56,0.64,1);
}

.bb-primary:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 12rpx rgba(212,120,110,0.20);
}

.bb-primary.disabled {
  background: linear-gradient(135deg, #E5E0DC, #D5CFCA);
  color: #B5A5A5;
  box-shadow: none;
}

.bb-primary.state-booked {
  background: rgba(77,184,160,0.12);
  color: #4DB8A0;
  box-shadow: none;
  border: 1rpx solid rgba(77,184,160,0.18);
}

.bb-primary.state-waitlist {
  background: rgba(232,152,94,0.12);
  color: #E8985E;
  box-shadow: none;
  border: 1rpx solid rgba(232,152,94,0.18);
}

.bb-primary.state-waitlist-btn {
  background: linear-gradient(135deg, #E8985E, #C49A64);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(232,152,94,0.30);
}

.bb-btns .bb-secondary { width: 36%; }
.bb-btns .bb-primary { width: 60%; flex: none; }
.bb-btns .bb-primary.state-booked,
.bb-btns .bb-primary.state-waitlist {
  width: auto;
  flex: 1;
}

.bb-secondary {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #FFFFFF;
  color: #6B5D5E;
  border: 1.5rpx solid rgba(212,120,110,0.20);
  border-radius: 46rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 150ms ease;
}

.bb-secondary:active {
  border-color: #D4786E;
  color: #D4786E;
  transform: scale(0.97);
  background: rgba(212,120,110,0.04);
}

.bb-secondary.disabled {
  background: #F2F0EE;
  color: #B5A5A5;
  border-color: rgba(181,165,165,0.20);
  opacity: 0.7;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61,44,46,0.7);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: modalFade 0.15s ease;
}

@keyframes modalFade {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: #FFFFFF;
  border-radius: 36rpx;
  width: min(90%, 620rpx);
  padding: 40rpx 36rpx;
  box-shadow: 0 12rpx 48rpx rgba(61,44,46,0.12);
  animation: modalPop 0.35s cubic-bezier(0.34,1.56,0.64,1);
}

@keyframes modalPop {
  from { opacity: 0; transform: scale(0.9) translateY(30rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.mc-title {
  font-size: 34rpx;
  color: #3D2C2E;
  font-weight: 700;
  text-align: center;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(232,152,94,0.12);
}

.mc-body {
  font-size: 28rpx;
  color: #7A6B6D;
  line-height: 1.6;
  text-align: center;
  padding: 32rpx 0;
}

.mc-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(232,152,94,0.12);
}

.mc-footer.single { border-top: none; }

.mcf-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 29rpx;
  font-weight: 600;
  transition: all 0.15s ease;
}

.mcf-btn:active { transform: scale(0.97); }

.mcf-btn.secondary {
  background: rgba(181,165,165,0.08);
  color: #7A6B6D;
}

.mcf-btn.primary {
  background: linear-gradient(135deg, #D4786E, #EBA89F);
  color: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(212,120,110,0.3);
}

.mcf-btn.primary.full {
  flex: none;
  width: 100%;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 20rpx;
  background: #FAF8F6;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(212,120,110,0.15);
  border-top-color: #D4786E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #B5A5A5;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  background: #FAF8F6;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.08), rgba(232,152,94,0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-icon-inner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.2), rgba(232,152,94,0.15));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-text {
  font-size: 30rpx;
  color: #B5A5A5;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC0C0;
}
