.page {
  background: #FAF8F6;
  min-height: 100vh;
  padding: calc(20rpx + env(safe-area-inset-top)) 28rpx 100rpx;
}

.pkg-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(61,44,46,0.06);
  overflow: hidden;
  position: relative;
}

.pkg-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #D4786E, #EBA89F, #E8985E);
}

.pkg-card.active .pkg-top-bar {
  background: linear-gradient(90deg, #4DB8A0, #6BC5B0);
}

.pkg-card.expired .pkg-top-bar,
.pkg-card.depleted .pkg-top-bar {
  background: linear-gradient(90deg, #D5CFCA, #E5E0DC);
}

.pkg-card.paused .pkg-top-bar {
  background: linear-gradient(90deg, #E8985E, #E8C9A0);
}

.pkg-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx 20rpx;
}

.pkg-type-badge {
  padding: 8rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #D4786E;
  background: rgba(212,120,110,0.08);
}

.pkg-status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pkg-status-badge.active {
  background: rgba(77,184,160,0.1);
  color: #4DB8A0;
}

.pkg-status-badge.pending {
  background: rgba(232,152,94,0.1);
  color: #E8985E;
}

.pkg-status-badge.expired,
.pkg-status-badge.depleted {
  background: rgba(181,165,165,0.1);
  color: #B5A5A5;
}

.pkg-status-badge.paused {
  background: rgba(212,120,110,0.08);
  color: #D4786E;
}

.pkg-body {
  padding: 0 28rpx 24rpx;
}

.pkg-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(232,152,94,0.08);
}

.pkg-row:last-child {
  border-bottom: none;
}

.pkg-label {
  font-size: 26rpx;
  color: #B5A5A5;
}

.pkg-val {
  font-size: 26rpx;
  color: #7A6B6D;
  font-weight: 500;
}

.pkg-val.accent {
  color: #D4786E;
  font-weight: 700;
}

.pkg-actions {
  padding: 0 28rpx 28rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #D4786E, #EBA89F);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 18rpx rgba(212,120,110,0.25);
  transition: all 0.15s ease;
}

.btn-primary:active {
  transform: scale(0.97);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 50vh;
  gap: 20rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(212,120,110,0.15);
  border-top-color: #D4786E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #B5A5A5;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.08), rgba(232,152,94,0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-icon-inner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.2), rgba(232,152,94,0.15));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-text {
  font-size: 30rpx;
  color: #B5A5A5;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC0C0;
}