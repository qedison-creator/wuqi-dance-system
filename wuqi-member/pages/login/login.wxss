.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 60rpx;
  background: #FBFAF8;
  box-sizing: border-box;
}

.login-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  padding-bottom: 120rpx;
}

.login-logo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.login-logo-img {
  width: 100%;
  height: 100%;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2122;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #6B5D5E;
  margin-bottom: 64rpx;
}

.login-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 520rpx;
  min-height: 96rpx;
  line-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #D4786E, #C05D53);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 6rpx 24rpx rgba(212, 120, 110, 0.3);
  letter-spacing: 1rpx;
  transition: all 150ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(212, 120, 110, 0.2);
}

.login-btn.btn-disabled {
  background: #D9D9D9;
  box-shadow: none;
}

.login-btn.btn-disabled:active {
  transform: none;
}

.login-btn-text {
  color: #FFFFFF;
}

.login-agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  flex-wrap: wrap;
}

.agreement-check {
  margin-right: 8rpx;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
}

.check-box.checked {
  border-color: #D4786E;
  background: #D4786E;
}

.check-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.agreement-text {
  font-size: 22rpx;
  color: #B5A2A4;
}

.agreement-link {
  font-size: 22rpx;
  color: #D4786E;
}