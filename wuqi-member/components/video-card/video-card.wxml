<view class="video-card card" bindtap="onVideoTap">
  <view class="video-cover">
    <image class="cover-img" src="{{imageErrors['cover_video'] ? '/images/default-course.svg' : (video.cover_url || '/images/default-course.svg')}}" binderror="onImgError" data-type="cover" data-id="video" mode="aspectFill" />
    <view class="play-btn">
      <text class="play-icon">▶</text>
    </view>
    <view class="video-duration" wx:if="{{video.duration}}">
      <text class="duration-text">{{video.duration}}</text>
    </view>
  </view>
  <view class="video-info">
    <text class="video-title">{{video.title || '视频标题'}}</text>
    <view class="video-meta">
      <image class="coach-avatar-small" src="{{imageErrors['coach_'+video._id] ? '/images/default-avatar.svg' : (video.coach_id && video.coach_id.avatar_url || '/images/default-avatar.svg')}}" binderror="onImgError" data-type="coach" data-id="{{video._id}}" mode="aspectFill" />
      <text class="coach-name">{{video.coach_id && video.coach_id.name || '教练'}}</text>
    </view>
  </view>
</view>