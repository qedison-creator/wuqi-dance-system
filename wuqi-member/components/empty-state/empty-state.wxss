.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.08), rgba(232,152,94,0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-icon-inner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.2), rgba(232,152,94,0.15));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-text {
  font-size: 30rpx;
  color: #B5A5A5;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC0C0;
  margin-bottom: 30rpx;
}

.empty-action {
  padding: 16rpx 48rpx;
  border: 1rpx solid #D4786E;
  border-radius: 30rpx;
}

.action-text {
  font-size: 26rpx;
  color: #D4786E;
}