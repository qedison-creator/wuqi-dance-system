.cc-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(42, 33, 34, 0.06);
  transition: all 150ms cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.cc-card:active {
  transform: scale(0.97);
}

.cc-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  min-height: 120rpx;
  position: relative;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.cc-avatar {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  border: 3rpx solid rgba(212, 120, 110, 0.15);
  background: #FDF2EF;
}

.cc-avatar-ring {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  width: calc(100% + 12rpx);
  height: calc(100% + 12rpx);
  border-radius: 30rpx;
  border: 2rpx dashed rgba(212, 120, 110, 0.22);
  pointer-events: none;
}

.cc-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.cc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2122;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cc-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}

.cc-tags .tag {
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.cc-bio {
  font-size: 24rpx;
  color: #948284;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}