.cc-card {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(42, 33, 34, 0.06);
  transition: all 150ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.cc-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 16rpx rgba(42, 33, 34, 0.08);
}

.cc-thumb {
  width: 100%;
  height: 160rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FDF2EF, #EEF5F4);
}

.cc-thumb-img {
  width: 100%;
  height: 100%;
}

.cc-accent {
  height: 4rpx;
  background: linear-gradient(90deg, #D4786E, #5D9B9B, #B89CDA);
}

.cc-body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
}

.cc-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #2A2122;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cc-meta-row {
  margin-bottom: 4rpx;
}

.cc-meta {
  font-size: 22rpx;
  color: #6B5D5E;
}

.cc-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.cc-capacity {
  font-size: 22rpx;
  color: #948284;
}