.page {
  min-height: 100vh;
  background-color: #FBFAF8;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A2122;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #B5A5A5;
}

.content {
  padding: 0 32rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2122;
  margin-bottom: 16rpx;
}

.info-text {
  font-size: 26rpx;
  color: #5A4F4F;
  line-height: 1.6;
}

.menu-list {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  margin-top: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0EDE9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 28rpx;
  color: #2A2122;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #B5A5A5;
  border-right: 2rpx solid #B5A5A5;
  transform: rotate(45deg);
}
