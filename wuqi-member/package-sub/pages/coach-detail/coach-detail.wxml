<wxs src="../../../utils/compare.wxs" module="cmp" />

<view class="cd-page">
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="sk-avatar"></view>
    <view class="sk-name"></view>
    <view class="sk-tags">
      <view class="sk-tag"></view>
      <view class="sk-tag-short"></view>
    </view>
    <view class="sk-section-title"></view>
    <view class="sk-line"></view>
    <view class="sk-line short"></view>
    <view class="sk-line mid"></view>
    <view class="sk-section-title"></view>
    <view class="sk-photo-row">
      <view class="sk-photo"></view>
      <view class="sk-photo"></view>
      <view class="sk-photo"></view>
    </view>
    <view class="sk-section-title"></view>
    <view class="sk-course-card"></view>
    <view class="sk-course-card"></view>
  </view>

  <view wx:if="{{!loading && coach && coach._id}}">
    <view class="cd-hero">
      <view class="cd-hero-bg"></view>
      <view class="cd-hero-content">
        <view class="cd-avatar-wrap">
          <image class="cd-avatar" src="{{imageErrors['coach_'+coach._id] ? '/images/default-avatar.svg' : (coach.avatar_url || '/images/default-avatar.svg')}}" binderror="onImgError" data-type="coach" data-id="{{coach._id}}" mode="aspectFill" />
          <view class="cd-avatar-ring"></view>
        </view>
        <text class="cd-name">{{coach.name}}</text>
        <view class="cd-tags" wx:if="{{danceStyleText}}">
          <text class="cd-tag">{{danceStyleText}}</text>
        </view>
      </view>
    </view>

    <view class="cd-bio-section" wx:if="{{coach.introduction}}">
      <view class="cd-section-header">
        <view class="cd-section-dot"></view>
        <text class="cd-section-title">个人简介</text>
      </view>
      <text class="cd-bio">{{coach.introduction}}</text>
    </view>

    <view class="cd-photo-section" wx:if="{{images.length > 0}}">
      <view class="cd-section-header">
        <view class="cd-section-dot accent"></view>
        <text class="cd-section-title">教练相册</text>
        <text class="cd-section-hint">{{images.length}}张</text>
      </view>
      <scroll-view class="cd-photo-scroll" scroll-x show-scrollbar="{{false}}">
        <image class="cd-photo" wx:for="{{images}}" wx:key="_id" src="{{imageErrors['img_'+index] ? '/images/default-course.svg' : (item.thumbnail_url || item.image_url)}}" binderror="onImgError" data-type="img" data-id="{{index}}" mode="aspectFill" bindtap="onPhotoTap" data-index="{{index}}" />
      </scroll-view>
    </view>

    <view class="cd-course-section">
      <view class="cd-section-header">
        <view class="cd-section-dot"></view>
        <text class="cd-section-title">相关场次</text>
      </view>
      <view wx:if="{{courses.length > 0}}">
        <view class="cd-course-card" wx:for="{{courses}}" wx:key="_id" data-id="{{item._id}}" bindtap="onCourseTap">
          <view class="cd-course-accent"></view>
          <view class="cd-course-body">
            <text class="cd-course-name">{{item.course_name || '课程名称'}}</text>
            <view class="cd-course-tag" wx:if="{{item.danceStyleName}}" style="background: {{item.danceTagBg}}; color: {{item.danceTagText}}">{{item.danceStyleName}}</view>
            <view class="cd-course-meta">
              <view class="cd-course-meta-dot"></view>
              <text>{{item.date}} {{item.weekday}} {{item.start_time}}-{{item.end_time}}</text>
            </view>
            <view class="cd-course-meta" wx:if="{{item.classroom}}">
              <view class="cd-course-meta-dot room"></view>
              <text>{{item.classroom}}</text>
            </view>
            <view class="cd-course-deadline" wx:if="{{isOfficial && item.booking_deadline_text}}">
              <text class="cd-deadline-text">截止预约：{{item.booking_deadline_text}}</text>
              <text class="cd-deadline-text cancel">截止取消：{{item.cancel_deadline_text}}</text>
            </view>
            <view class="cd-card-meta-row">
              <view class="cd-course-count" wx:if="{{isOfficial && canViewCapacity}}">
                <text class="cdc-label">已约</text>
                <text class="cdc-num">{{item.current_bookings || 0}}</text>
                <text class="cdc-total">/{{item.max_bookings || 20}}人</text>
              </view>
              <view class="cd-course-count" wx:elif="{{isOfficial && !canViewCapacity}}">
                <text class="cdc-label">已约</text>
                <text class="cdc-num">?</text>
                <text class="cdc-total">/?人</text>
              </view>
              <text class="cdc-min-capacity" wx:if="{{item.min_bookings}}">最低{{item.min_bookings}}人成班</text>
              <view class="cd-booked-avatars" wx:if="{{canViewCapacity && item.booked_users && item.booked_users.length > 0}}">
                <block wx:for="{{item.booked_users}}" wx:for-item="bu" wx:for-index="bui" wx:key="user_id" wx:if="{{bui < 10}}">
                  <image class="cd-booked-avatar" src="{{bu.avatar_url}}" mode="aspectFill" style="z-index: {{bui + 1}};" />
                </block>
                <view class="cd-booked-more" wx:if="{{item.booked_users.length > 10}}">
                  <text>+{{item.booked_users.length - 10}}</text>
                </view>
              </view>
            </view>
          </view>
          <view class="cd-course-action">
            <!-- 受限用户：已结束 / 未开放预约 / 已预约（可取消）/ 不可预约 -->
            <block wx:if="{{isRestrictedUser}}">
              <view class="cd-book-btn disabled" wx:if="{{item._ended}}">
                <text>已结束</text>
              </view>
              <view class="cd-book-btn disabled-clickable" wx:elif="{{!item.bookingOpen}}">
                <text>未开放预约</text>
              </view>
              <view class="cd-book-btn booked" wx:elif="{{cmp.contains(bookedScheduleIds, item._id)}}" data-course="{{item}}" catchtap="onBookTap">
                <text>已预约</text>
              </view>
              <view class="cd-book-btn disabled-clickable" wx:else data-course="{{item}}" catchtap="onBookTap">
                <text>不可预约</text>
              </view>
            </block>
            <!-- 正式会员：显示完整状态 -->
            <block wx:else>
              <view class="cd-book-btn disabled" wx:if="{{item.status === 'cancelled'}}">
                <text>已取消</text>
              </view>
              <view class="cd-book-btn state-done" wx:elif="{{item._ended && cmp.contains(completedScheduleIds, item._id)}}">
                <text>已完成</text>
              </view>
              <view class="cd-book-btn disabled" wx:elif="{{item._ended}}">
                <text>已结束</text>
              </view>
              <view class="cd-book-btn state-ongoing" wx:elif="{{item._ongoing}}">
                <text>进行中</text>
              </view>
              <view class="cd-book-btn booked" wx:elif="{{cmp.contains(bookedScheduleIds, item._id)}}" data-course="{{item}}" catchtap="onBookTap">
                <text>已预约</text>
              </view>
              <view class="cd-book-btn waitlist-btn waitlisted" wx:elif="{{cmp.contains(waitlistedScheduleIds, item._id)}}">
                <text>候补中</text>
              </view>
              <block wx:elif="{{item.status === 'full'}}">
                <view class="cd-book-btn state-full">
                  <text>已满</text>
                </view>
                <view class="cd-book-btn waitlist-btn" wx:if="{{!cmp.contains(waitlistedScheduleIds, item._id)}}" data-course="{{item}}" catchtap="onBookTap">
                  <text>加入候补</text>
                </view>
              </block>
              <view class="cd-book-btn disabled-clickable" wx:elif="{{!item.bookingOpen}}">
                <text>未开放预约</text>
              </view>
              <view class="cd-book-btn disabled-clickable" wx:elif="{{item.courseStoreMatched === false}}" data-course="{{item}}" catchtap="onBookTap">
                <text>不可预约</text>
              </view>
              <view class="cd-book-btn" wx:else data-course="{{item}}" catchtap="onBookTap">
                <text>预约</text>
              </view>
            </block>
          </view>
        </view>
      </view>
      <empty-state wx:else text="暂无未来课程"></empty-state>
    </view>
  </view>

  <empty-state wx:if="{{!loading && !coach}}" text="教练信息不存在" hint="请检查后重试"></empty-state>

  <view class="modal-mask" wx:if="{{showBookingModal}}" bindtap="onCancelBookingModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="mc-title">确认预约</view>
      <view class="mc-body">{{bookingModalText}}</view>
      <view class="mc-footer">
        <view class="mcf-btn secondary" bindtap="onCancelBookingModal">取消</view>
        <view class="mcf-btn primary" bindtap="onConfirmBookingModal">确定</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showWaitlistModal}}" bindtap="onCancelWaitlist">
    <view class="modal-content" catchtap="onModalTap">
      <view class="mc-title">加入候补</view>
      <text class="mc-body">{{waitlistModalText}}</text>
      <view class="mc-footer">
        <view class="mcf-btn secondary" bindtap="onCancelWaitlist">取消</view>
        <view class="mcf-btn primary" bindtap="onConfirmWaitlist">确定</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{isLoggedInShowing}}" bindtap="onCancelLoginModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="mc-title">登录提示</view>
      <view class="mc-body">请先登录后再进行预约操作</view>
      <view class="mc-footer">
        <view class="mcf-btn secondary" bindtap="onCancelLoginModal">取消</view>
        <view class="mcf-btn primary" bindtap="onGoLogin">去登录</view>
      </view>
    </view>
  </view>
</view>