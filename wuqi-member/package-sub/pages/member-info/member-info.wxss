.page {
  background: #FAF8F6;
  min-height: 100vh;
  height: 100vh;
  overflow: hidden;
  padding: calc(20rpx + env(safe-area-inset-top)) 28rpx 100rpx;
  box-sizing: border-box;
}

.info-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(61,44,46,0.06);
}

.ic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(232,152,94,0.1);
  margin-bottom: 16rpx;
}

.ic-title {
  font-size: 32rpx;
  color: #3D2C2E;
  font-weight: 700;
}

.ic-edit {
  font-size: 26rpx;
  color: #D4786E;
  padding: 8rpx 22rpx;
  border: 1rpx solid rgba(212,120,110,0.25);
  border-radius: 20rpx;
  transition: all 0.15s ease;
}

.ic-edit:active {
  background: rgba(212,120,110,0.06);
}

.ic-pending {
  font-size: 24rpx;
  color: #E8985E;
  padding: 6rpx 18rpx;
  background: rgba(232,152,94,0.1);
  border-radius: 20rpx;
  font-weight: 500;
}

.ic-row-avatar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(232,152,94,0.06);
}

.ic-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F0EB;
}

.ic-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(232,152,94,0.06);
}

.avatar-edit-row {
  display: flex;
  justify-content: center;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F0EB;
}

.avatar-tip {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: #fff;
  background: rgba(0,0,0,0.5);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.ic-row:last-child {
  border-bottom: none;
}

.ic-label {
  font-size: 26rpx;
  color: #B5A5A5;
  width: 140rpx;
}

.ic-val {
  font-size: 26rpx;
  color: #7A6B6D;
  flex: 1;
  text-align: right;
}

.ic-val-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.ic-val-status.official {
  color: #4DB8A0;
  background: rgba(77,184,160,0.08);
}

.ic-val-status.registered {
  color: #E8985E;
  background: rgba(232,152,94,0.1);
}

.ic-val-status.guest {
  color: #B5A5A5;
  background: rgba(181,165,165,0.08);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #B5A5A5;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 520rpx;
  height: 72rpx;
  background: #F5F0EB;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3D2C2E;
  border: 1rpx solid rgba(232,152,94,0.15);
  box-sizing: border-box;
}

.ph {
  color: #CCC0C0;
}

.gender-segment {
  display: inline-flex;
  background: #F5F0EB;
  border-radius: 40rpx;
  padding: 6rpx;
  border: 1rpx solid rgba(232,152,94,0.15);
  gap: 4rpx;
}

.gender-segment-opt {
  padding: 14rpx 56rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #B5A5A5;
  transition: all 0.2s ease;
}

.gender-segment-opt.active {
  background: #FFFFFF;
  color: #D4786E;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(61,44,46,0.06);
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.fa-cancel {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: rgba(181,165,165,0.08);
  color: #7A6B6D;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.15s ease;
}

.fa-cancel:active {
  transform: scale(0.97);
}

.fa-submit {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: linear-gradient(135deg, #D4786E, #EBA89F);
  color: #FFFFFF;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 18rpx rgba(212,120,110,0.25);
  transition: all 0.15s ease;
}

.fa-submit:active {
  transform: scale(0.97);
}

.fa-submit.disabled {
  background: linear-gradient(135deg, #E5E0DC, #D5CFCA);
  color: #B5A5A5;
  box-shadow: none;
}

.form-tip {
  font-size: 22rpx;
  color: #CCC0C0;
  text-align: center;
  margin-top: 16rpx;
}

/* 头像选择面板 */
.avatar-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.avatar-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  padding: 12rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 32rpx rgba(61, 44, 46, 0.12);
  animation: as-slide-up 0.22s ease;
}

@keyframes as-slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.as-header {
  padding: 24rpx 0 20rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(232, 152, 94, 0.08);
}

.as-title {
  font-size: 28rpx;
  color: #B5A5A5;
  font-weight: 500;
}

.as-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
  color: #3D2C2E;
  background: #FFFFFF;
  border: none;
  border-radius: 0;
  margin: 0;
  padding: 0;
}

.as-item::after {
  border: none;
}

.as-item + .as-item {
  border-top: 1rpx solid rgba(232, 152, 94, 0.06);
}

.as-item:active {
  background: rgba(232, 152, 94, 0.06);
}

.as-cancel {
  margin-top: 16rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
  color: #B5A5A5;
  background: #F5F0EB;
  border-top: 1rpx solid rgba(232, 152, 94, 0.08);
}

.as-cancel:active {
  background: rgba(181, 165, 165, 0.12);
}