<view class="page">
  <view class="info-card" wx:if="{{userInfo && !editing}}">
    <view class="ic-header">
      <text class="ic-title">个人信息</text>
      <view class="ic-edit" bindtap="onEditTap" wx:if="{{changeRequestStatus !== 'pending'}}">修改</view>
      <view class="ic-pending" wx:if="{{changeRequestStatus === 'pending'}}">审核中</view>
    </view>

    <view class="ic-row">
      <text class="ic-label">姓名</text>
      <text class="ic-val">{{userInfo.real_name || '未填写'}}</text>
    </view>
    <view class="ic-row">
      <text class="ic-label">预留手机</text>
      <text class="ic-val">{{userInfo.reserve_phone || userInfo.phone || '未设置'}}</text>
    </view>
    <view class="ic-row" wx:if="{{userInfo.wechat_phone}}">
      <text class="ic-label">微信绑定</text>
      <text class="ic-val">{{userInfo.wechat_phone}}</text>
    </view>
    <view class="ic-row">
      <text class="ic-label">性别</text>
      <text class="ic-val">{{userInfo.gender === 1 ? '男' : userInfo.gender === 2 ? '女' : '未填写'}}</text>
    </view>
    <view class="ic-row">
      <text class="ic-label">门店</text>
      <text class="ic-val">{{userInfo.store_id && userInfo.store_id.name ? userInfo.store_id.name : '未选择'}}</text>
    </view>
    <view class="ic-row">
      <text class="ic-label">会员状态</text>
      <text class="ic-val-status official" wx:if="{{userInfo.member_status === 'official'}}">正式会员</text>
      <text class="ic-val-status registered" wx:elif="{{userInfo.member_status === 'registered'}}">审核中</text>
      <text class="ic-val-status guest" wx:else>游客</text>
    </view>
  </view>

  <view class="info-card" wx:if="{{userInfo && editing}}">
    <view class="ic-header">
      <text class="ic-title">修改个人信息</text>
    </view>

    <view class="form-group">
      <text class="form-label">姓名</text>
      <input class="form-input" value="{{editForm.real_name}}" placeholder="请输入真实姓名" placeholder-class="ph" bindinput="onRealNameInput" />
    </view>
    <view class="form-group">
      <text class="form-label">预留手机号</text>
      <input class="form-input" type="number" maxlength="11" value="{{editForm.phone}}" placeholder="请输入预留手机号" placeholder-class="ph" bindinput="onPhoneInput" />
    </view>
    <view class="form-group">
      <text class="form-label">性别</text>
      <view class="gender-segment">
        <view class="gender-segment-opt {{editForm.gender === 1 ? 'active' : ''}}" data-gender="1" bindtap="onGenderSelect">
          <text class="gender-segment-text">男</text>
        </view>
        <view class="gender-segment-opt {{editForm.gender === 2 ? 'active' : ''}}" data-gender="2" bindtap="onGenderSelect">
          <text class="gender-segment-text">女</text>
        </view>
      </view>
    </view>

    <view class="form-actions">
      <view class="fa-cancel" bindtap="onCancelEdit">取消</view>
      <view class="fa-submit {{submitting ? 'disabled' : ''}}" bindtap="onSubmitChange">{{submitting ? '提交中...' : '提交修改'}}</view>
    </view>

    <view class="form-tip">姓名、手机号需管理端审核后生效</view>
  </view>
</view>
