.page {
  background: #FAF8F6;
  min-height: 100vh;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  padding-bottom: 100rpx;
}

.tab-bar {
  display: flex;
  margin: 0 28rpx 20rpx;
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(61,44,46,0.04);
}

.tb-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: #B5A5A5;
  border-radius: 20rpx;
  position: relative;
  z-index: 2;
  transition: color 0.3s ease;
}

.tb-item.active {
  color: #FFFFFF;
}

.tb-item.active text {
  font-weight: 600;
}

.tb-slider {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(33.333% - 4rpx);
  height: calc(100% - 12rpx);
  background: linear-gradient(135deg, #D4786E, #EBA89F);
  border-radius: 20rpx;
  z-index: 1;
  transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 4rpx 16rpx rgba(212,120,110,0.25);
}

.tb-slider.pos1 {
  transform: translateX(100%);
}

.tb-slider.pos2 {
  transform: translateX(200%);
}

/* 展开/收起按钮 */
.expand-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  margin: 0 28rpx;
  font-size: 26rpx;
  color: #D4786E;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(61,44,46,0.04);
}

.expand-toggle text {
  margin-right: 10rpx;
}

.toggle-arrow {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  transition: all 0.3s ease;
}

.toggle-arrow.down {
  border-top: 12rpx solid #D4786E;
}

.toggle-arrow.up {
  border-bottom: 12rpx solid #D4786E;
}

.filter-bar {
  padding: 0 28rpx;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.fb-item {
  display: inline-block;
  padding: 14rpx 30rpx;
  margin-right: 14rpx;
  font-size: 24rpx;
  color: #7A6B6D;
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 1rpx solid rgba(232,152,94,0.12);
  transition: all 0.2s ease;
}

.fb-item:active {
  transform: scale(0.95);
}

.fb-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #D4786E, #EBA89F);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(212,120,110,0.25);
}

.record-list {
  padding: 0 28rpx;
}

.r-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(61,44,46,0.05);
  display: flex;
  align-items: stretch;
  position: relative;
  overflow: hidden;
}

.rc-left-line {
  width: 6rpx;
  flex-shrink: 0;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #D4786E, #EBA89F);
  margin: 24rpx 0 24rpx 0;
}

.rc-left-line.upcoming {
  background: linear-gradient(180deg, #D4786E, #EBA89F);
}

.rc-left-line.completed {
  background: linear-gradient(180deg, #4DB8A0, #6BC5B0);
}

.rc-left-line.cancelled {
  background: linear-gradient(180deg, #D5CFCA, #E5E0DC);
}

.rc-left-line.absent {
  background: linear-gradient(180deg, #D4786E, #EBA89F);
}

.rc-left-line.waitlist {
  background: linear-gradient(180deg, #E8985E, #E0C9A8);
}

.rc-body {
  flex: 1;
  padding: 28rpx 24rpx;
  min-width: 0;
}

.rc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  gap: 16rpx;
}

.rc-name {
  font-size: 30rpx;
  color: #3D2C2E;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rc-status {
  padding: 6rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.rc-status.upcoming {
  background: rgba(212,120,110,0.08);
  color: #D4786E;
}

.rc-status.completed {
  background: rgba(77,184,160,0.08);
  color: #4DB8A0;
}

.rc-status.cancelled {
  background: rgba(181,165,165,0.1);
  color: #B5A5A5;
}

.rc-source {
  padding: 6rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.source-member,
.source-booking {
  background: rgba(77,184,160,0.08);
  color: #4DB8A0;
}

.source-onsite {
  background: rgba(232,152,94,0.1);
  color: #E8985E;
}

.source-admin {
  background: rgba(196,181,253,0.15);
  color: #C4B5FD;
}

.method-scan {
  background: rgba(77,184,160,0.08);
  color: #4DB8A0;
}

.method-auto {
  background: rgba(212,120,110,0.1);
  color: #D4786E;
}

.method-exempt_cancel {
  background: rgba(181,165,165,0.12);
  color: #9A8C8D;
}

.method-cancelled_after_checkin {
  background: rgba(181,165,165,0.12);
  color: #9A8C8D;
}

.cancelled-tag {
  opacity: 0.85;
}

.rc-position-tag {
  padding: 6rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  background: rgba(232,152,94,0.1);
  color: #E8985E;
}

.rc-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rci-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.rci-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(212,120,110,0.06);
}

.rci-icon::after {
  content: '';
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #D4786E;
}

.rci-icon.time { background: rgba(196,181,253,0.12); }
.rci-icon.time::after { background: #C4B5FD; }

.rci-icon.checkin { background: rgba(77,184,160,0.1); }
.rci-icon.checkin::after { background: #4DB8A0; }

.rci-icon.coach { background: rgba(232,152,94,0.1); }
.rci-icon.coach::after { background: #E8985E; }

.rci-icon.store { background: rgba(196,181,253,0.12); }
.rci-icon.store::after { background: #C4B5FD; }

.rci-icon.credit { background: rgba(77,184,160,0.1); }
.rci-icon.credit::after { background: #4DB8A0; }

.rci-icon.date { background: rgba(212,120,110,0.06); }
.rci-icon.date::after { background: #D4786E; }

.rci-text {
  font-size: 24rpx;
  color: #7A6B6D;
}

.rci-text.highlight {
  color: #D4786E;
  font-weight: 600;
}

.rc-cancel-reason {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  background: rgba(181,165,165,0.06);
  border-radius: 14rpx;
  border-left: 3rpx solid rgba(181,165,165,0.25);
}

.rcr-tag {
  width: 28rpx;
  height: 28rpx;
  min-width: 28rpx;
  border-radius: 8rpx;
  background: rgba(181,165,165,0.15);
  position: relative;
  margin-top: 2rpx;
}

.rcr-tag::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4rpx;
  height: 12rpx;
  border-radius: 2rpx;
  background: #B5A5A5;
}

.rcr-text {
  font-size: 22rpx;
  color: #9A8C8D;
  line-height: 1.6;
  flex: 1;
}

.rca-btn {
  width: 88rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  writing-mode: vertical-rl;
  padding: 24rpx 0;
  letter-spacing: 3rpx;
}

.rca-btn.cancel {
  color: #B5A5A5;
  background: rgba(181, 165, 165, 0.06);
}

.rca-btn.cancel:active {
  background: rgba(181, 165, 165, 0.15);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.08), rgba(232,152,94,0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-icon-inner {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,120,110,0.2), rgba(232,152,94,0.15));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-text {
  font-size: 30rpx;
  color: #B5A5A5;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCC0C0;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 48rpx 32rpx;
}

.lm-line {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212,120,110,0.12), transparent);
}

.load-more text {
  font-size: 24rpx;
  color: #B5A5A5;
}

.load-more.loading {
  gap: 16rpx;
}

.loading-spinner-sm {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(212,120,110,0.15);
  border-top-color: #D4786E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more.loading text {
  font-size: 24rpx;
  color: #7A6B6D;
}
